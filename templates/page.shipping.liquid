{% comment %} Shipping Policy Page Template {% endcomment %}

<div class="amz-page-hero" style="background:linear-gradient(135deg,#131921,#232f3e);padding:50px 20px;text-align:center;color:#fff;">
  <div class="page-width">
    <div style="width:64px;height:64px;background:#ff9900;border-radius:50%;display:flex;align-items:center;justify-content:center;margin:0 auto 20px;">
      <svg width="32" height="32" viewBox="0 0 24 24" fill="white" aria-hidden="true"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
    </div>
    <h1 style="font-size:34px;font-weight:800;margin-bottom:12px;">Shipping Policy</h1>
    <p style="font-size:15px;color:#ccc;">Fast, reliable delivery across India</p>
  </div>
</div>

<div class="page-width" style="padding:60px 16px;max-width:900px;">

  <!-- Shipping Options Table -->
  <div style="margin-bottom:50px;">
    <h2 style="font-size:22px;font-weight:700;color:#0f1111;margin-bottom:20px;">Shipping Methods & Rates</h2>
    <div style="overflow-x:auto;">
      <table style="width:100%;border-collapse:collapse;font-size:14px;">
        <thead>
          <tr style="background:#131921;color:#fff;">
            <th style="padding:14px 18px;text-align:left;border-radius:8px 0 0 0;">Shipping Method</th>
            <th style="padding:14px 18px;text-align:left;">Delivery Time</th>
            <th style="padding:14px 18px;text-align:left;">Order Value</th>
            <th style="padding:14px 18px;text-align:left;border-radius:0 8px 0 0;">Cost</th>
          </tr>
        </thead>
        <tbody>
          <tr style="background:#fff3e0;">
            <td style="padding:14px 18px;border-bottom:1px solid #eee;font-weight:700;color:#e65c00;">⚡ Express Delivery</td>
            <td style="padding:14px 18px;border-bottom:1px solid #eee;">1–2 Business Days</td>
            <td style="padding:14px 18px;border-bottom:1px solid #eee;">Any</td>
            <td style="padding:14px 18px;border-bottom:1px solid #eee;font-weight:600;">₹99</td>
          </tr>
          <tr>
            <td style="padding:14px 18px;border-bottom:1px solid #eee;font-weight:700;color:#007600;">🆓 FREE Standard Shipping</td>
            <td style="padding:14px 18px;border-bottom:1px solid #eee;">3–5 Business Days</td>
            <td style="padding:14px 18px;border-bottom:1px solid #eee;">Orders ₹499+</td>
            <td style="padding:14px 18px;border-bottom:1px solid #eee;font-weight:700;color:#007600;">FREE</td>
          </tr>
          <tr style="background:#f8f8f8;">
            <td style="padding:14px 18px;border-bottom:1px solid #eee;font-weight:700;">📦 Standard Shipping</td>
            <td style="padding:14px 18px;border-bottom:1px solid #eee;">3–5 Business Days</td>
            <td style="padding:14px 18px;border-bottom:1px solid #eee;">Under ₹499</td>
            <td style="padding:14px 18px;border-bottom:1px solid #eee;font-weight:600;">₹49</td>
          </tr>
          <tr>
            <td style="padding:14px 18px;font-weight:700;">🔴 Same Day Delivery</td>
            <td style="padding:14px 18px;">Same Day (Order by 12 PM)</td>
            <td style="padding:14px 18px;">Select Cities</td>
            <td style="padding:14px 18px;font-weight:600;">₹149</td>
          </tr>
        </tbody>
      </table>
    </div>
  </div>

  <!-- Info Cards -->
  <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:20px;margin-bottom:50px;">
    <div style="background:#f0f9f0;border:1px solid #c3e6cb;border-radius:12px;padding:24px;text-align:center;">
      <div style="font-size:32px;margin-bottom:10px;">📍</div>
      <h3 style="font-size:15px;font-weight:700;color:#155724;margin-bottom:8px;">Pan India Delivery</h3>
      <p style="font-size:13px;color:#333;">We ship to all 29 states and 7 union territories across India.</p>
    </div>
    <div style="background:#fff3e0;border:1px solid #ffd180;border-radius:12px;padding:24px;text-align:center;">
      <div style="font-size:32px;margin-bottom:10px;">📦</div>
      <h3 style="font-size:15px;font-weight:700;color:#e65c00;margin-bottom:8px;">Secure Packaging</h3>
      <p style="font-size:13px;color:#333;">All items are carefully packed to prevent damage during transit.</p>
    </div>
    <div style="background:#e3f2fd;border:1px solid #90caf9;border-radius:12px;padding:24px;text-align:center;">
      <div style="font-size:32px;margin-bottom:10px;">🔍</div>
      <h3 style="font-size:15px;font-weight:700;color:#0d47a1;margin-bottom:8px;">Live Tracking</h3>
      <p style="font-size:13px;color:#333;">Track your order in real-time via SMS, email, and your account dashboard.</p>
    </div>
  </div>

  <!-- FAQ -->
  <h2 style="font-size:22px;font-weight:700;color:#0f1111;margin-bottom:20px;">Shipping FAQs</h2>

  {% assign faqs = "When will my order ship?|How do I track my order?|Can I change my delivery address?|What if my order is delayed?|Do you ship internationally?" | split: "|" %}
  {% assign answers = "Orders placed before 2 PM on business days typically ship the same day. Orders placed after 2 PM or on weekends ship on the next business day.|Once your order ships, you'll receive an email and SMS with a tracking number. You can track it from your account page.|Address changes can be made within 2 hours of placing the order. Contact our support team immediately.|In case of delays beyond the estimated delivery window, please contact us. We'll investigate and keep you updated.|Currently, we ship within India only. We are working on expanding internationally soon." | split: "|" %}

  {% for faq in faqs %}
  <details style="margin-bottom:12px;border:1px solid #eee;border-radius:8px;overflow:hidden;">
    <summary style="padding:16px 18px;font-size:14px;font-weight:600;color:#0f1111;cursor:pointer;background:#f8f8f8;list-style:none;display:flex;justify-content:space-between;align-items:center;">
      {{ faq }}
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#555" stroke-width="2" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
    </summary>
    <div style="padding:16px 18px;font-size:14px;color:#333;line-height:1.7;background:#fff;border-top:1px solid #eee;">{{ answers[forloop.index0] }}</div>
  </details>
  {% endfor %}

  <div style="margin-top:40px;padding:24px;background:#f8f9fa;border-radius:12px;text-align:center;">
    <p style="font-size:14px;color:#333;margin-bottom:14px;">Still have questions about shipping?</p>
    <a href="/pages/contact" style="display:inline-block;background:#FFD814;border:1px solid #FCD200;border-radius:8px;padding:10px 28px;font-size:14px;font-weight:700;color:#0f1111;text-decoration:none;">Contact Us</a>
  </div>

</div>

<style>
@media (max-width: 768px) {
  .page-width > div[style*="grid-template-columns:repeat(3"] { grid-template-columns: 1fr !important; }
}
</style>
