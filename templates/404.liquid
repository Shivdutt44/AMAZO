{% comment %} Amazo Premium — 404 Not Found Page {% endcomment %}

<div style="background:#fff; min-height:70vh; display:flex; align-items:center; justify-content:center; padding:40px 20px;">
  <div style="text-align:center; max-width:580px; padding:40px 30px;">
    <div style="font-size:80px; font-weight:800; color:var(--amz-orange); line-height:1; margin-bottom:8px;">404</div>
    <h1 style="font-size:28px; font-weight:700; color:var(--amz-text); margin-bottom:12px;">Page Not Found</h1>
    <p style="font-size:15px; color:var(--amz-gray); margin-bottom:8px; line-height:1.6;">
      Sorry, we couldn't find the page you were looking for.
    </p>
    <p style="font-size:14px; color:var(--amz-gray); margin-bottom:28px;">
      The page may have been moved, deleted, or may never have existed.
    </p>

    <div style="display:flex; gap:12px; justify-content:center; flex-wrap:wrap; margin-bottom:32px;">
      <a href="{{ routes.root_url }}"
         style="display:inline-block; background:linear-gradient(to bottom,#f7dfa5,var(--amz-yellow)); border:1px solid #a88734; border-radius:3px; padding:11px 24px; color:var(--amz-text); font-size:14px; font-weight:600; text-decoration:none;">
        Go to Homepage
      </a>
      <a href="/collections/all"
         style="display:inline-block; background:linear-gradient(to bottom,#f7f8f8,#e7e9ec); border:1px solid #adb1b8; border-radius:3px; padding:11px 24px; color:var(--amz-text); font-size:14px; font-weight:600; text-decoration:none;">
        Browse All Products
      </a>
    </div>

    <!-- Search box on 404 -->
    <div style="max-width:480px; margin:0 auto;">
      <p style="font-size:13px; color:var(--amz-gray); margin-bottom:10px;">Or try searching:</p>
      <form action="{{ routes.search_url }}" method="get" style="display:flex; border-radius:4px; overflow:hidden; box-shadow:0 1px 4px rgba(0,0,0,0.12);">
        <input type="hidden" name="type" value="product">
        <input type="search" name="q" placeholder="Search products..."
               style="flex:1; padding:11px 14px; border:1px solid var(--amz-border); border-right:none; font-size:14px; outline:none;"
               aria-label="Search">
        <button type="submit"
                style="background:var(--amz-orange); border:1px solid var(--amz-orange); padding:0 18px; cursor:pointer; display:flex; align-items:center;"
                aria-label="Search">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="#000" aria-hidden="true"><path d="M15.5 14h-.79l-.28-.27A6.471 6.471 0 0 0 16 9.5 6.5 6.5 0 1 0 9.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z"/></svg>
        </button>
      </form>
    </div>
  </div>
</div>
