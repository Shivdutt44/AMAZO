{% comment %}
  Amazo Premium — Product Page Template
  Full responsive Amazon-style product detail page
{% endcomment %}

{%- assign current_variant = product.selected_or_first_available_variant -%}
{%- liquid
  assign review_rating = product.metafields.reviews.rating.value | default: 4.3
  assign review_count = product.metafields.reviews.rating_count | default: 0
  if review_count == 0
    assign review_count = product.id | modulo: 8000 | plus: 200
  endif
  if current_variant.compare_at_price > current_variant.price
    assign savings = current_variant.compare_at_price | minus: current_variant.price
    assign discount_pct = savings | times: 100 | divided_by: current_variant.compare_at_price | round
  else
    assign discount_pct = 0
  endif
-%}

<!-- Structured Data -->
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Product",
  "name": {{ product.title | json }},
  "url": {{ shop.url | append: product.url | json }},
  "image": {{ product.featured_image | image_url: width: 800 | json }},
  "description": {{ product.description | strip_html | truncate: 500 | json }},
  "brand": { "@type": "Brand", "name": {{ product.vendor | json }} },
  "offers": {
    "@type": "Offer",
    "url": {{ shop.url | append: product.url | json }},
    "priceCurrency": {{ shop.currency | json }},
    "price": {{ current_variant.price | divided_by: 100.0 | json }},
    "availability": "{% if product.available %}https://schema.org/InStock{% else %}https://schema.org/OutOfStock{% endif %}"
  }
}
</script>

<div class="product-page-wrapper">

  <!-- Breadcrumb -->
  <div style="background:#fff; padding:8px 0; border-bottom:1px solid #f0f0f0;">
    <div class="page-width" style="max-width:1500px;">
      {%- render 'breadcrumb' -%}
    </div>
  </div>

  <!-- Main Product Layout -->
  <div class="product-page__inner">

    <!-- Column 1: Thumbnails -->
    <div class="product-thumbnails" id="ProductThumbs">
      {%- for image in product.images limit: 8 -%}
        <button
          class="product-thumbnail{% if forloop.first %} active{% endif %}"
          data-thumb
          data-image-src="{{ image | image_url: width: 700 }}"
          data-image-srcset="{{ image | image_url: width: 400 }} 400w, {{ image | image_url: width: 700 }} 700w"
          aria-label="{{ image.alt | default: product.title | escape }} - image {{ forloop.index }}"
        >
          <img
            src="{{ image | image_url: width: 60 }}"
            alt="{{ image.alt | default: product.title | escape }}"
            width="60" height="60"
            loading="lazy">
        </button>
      {%- else -%}
        <button class="product-thumbnail active">
          {{ 'product-1' | placeholder_svg_tag: '' }}
        </button>
      {%- endfor -%}
    </div>

    <!-- Column 2: Main Image -->
    <div class="product-main-image" id="ProductMainImage">
      {%- assign featured_image = current_variant.featured_image | default: product.featured_image -%}
      {%- if featured_image -%}
        <img
          src="{{ featured_image | image_url: width: 700 }}"
          srcset="{{ featured_image | image_url: width: 400 }} 400w, {{ featured_image | image_url: width: 700 }} 700w"
          alt="{{ featured_image.alt | default: product.title | escape }}"
          class="product-main-image__img"
          id="MainProductImage"
          width="700" height="700"
          loading="eager"
          fetchpriority="high">
      {%- else -%}
        <div style="width:100%; aspect-ratio:1/1; background:#f5f5f5; display:flex; align-items:center; justify-content:center;">
          {{ 'product-1' | placeholder_svg_tag: 'product-main-image__img' }}
        </div>
      {%- endif -%}
    </div>

    <!-- Column 3: Product Info -->
    <div class="product-info">

      <!-- Brand -->
      {%- if product.vendor != blank -%}
        <a href="/collections/vendor?q={{ product.vendor | url_encode }}" class="product-info__brand">
          Visit the {{ product.vendor }} Store
        </a>
      {%- endif -%}

      <!-- Title -->
      <h1 class="product-info__title" itemprop="name">{{ product.title }}</h1>

      <!-- Rating Row -->
      <div class="product-info__rating">
        <div class="product-info__stars" aria-label="{{ review_rating }} out of 5 stars">
          {%- assign full = review_rating | floor -%}
          {%- assign dec = review_rating | minus: full -%}
          {%- for s in (1..5) -%}
            {%- if s <= full -%}
              <span style="color:var(--amz-orange);">★</span>
            {%- elsif dec >= 0.3 and s == full | plus: 1 -%}
              <span style="color:var(--amz-orange);">★</span>
            {%- else -%}
              <span style="color:#ccc;">☆</span>
            {%- endif -%}
          {%- endfor -%}
        </div>
        <a href="#reviews" class="product-info__rating-count" style="font-weight:600; color:var(--amz-orange);">{{ review_rating | round: 1 }}</a>
        <a href="#reviews" class="product-info__rating-count">{{ review_count | number_with_delimiter }} ratings</a>
        {%- if product.tags contains 'bestseller' or product.tags contains 'best-seller' -%}
          <span style="background:var(--amz-orange); border-radius:3px; padding:3px 10px; font-size:11px; font-weight:700; color:#000; text-transform:uppercase;">
            #1 Best Seller
          </span>
        {%- endif -%}
        {%- if product.tags contains 'amazon-choice' -%}
          <span style="background:#232f3e; border-radius:3px; padding:3px 10px; font-size:11px; font-weight:700; color:#fff;">
            Amazon's Choice
          </span>
        {%- endif -%}
      </div>

      <!-- Price -->
      <div class="product-info__price">
        <div style="display:flex; align-items:baseline; gap:8px; flex-wrap:wrap; margin-bottom:4px;">
          {%- if discount_pct > 0 -%}
            <span style="font-size:14px; color:var(--amz-deal-red); font-weight:700;">-{{ discount_pct }}%</span>
          {%- endif -%}
          <span class="product-price__current" data-product-price>
            <span class="product-price__fraction">$</span>
            <span>{{ current_variant.price | money_without_currency | split: '.' | first }}</span>
            <span class="product-price__fraction">.{{ current_variant.price | money_without_currency | split: '.' | last }}</span>
          </span>
        </div>
        {%- if discount_pct > 0 -%}
          <div style="font-size:13px; color:var(--amz-gray);">
            List Price: <del>{{ current_variant.compare_at_price | money }}</del>
          </div>
          <div style="font-size:14px; color:var(--amz-deal-red); font-weight:600;">
            You Save: {{ savings | money }} ({{ discount_pct }}%)
          </div>
        {%- endif -%}
        <div style="display:flex; align-items:center; gap:6px; margin-top:8px; font-size:13px;">
          <span style="color:var(--amz-prime-blue); font-weight:700; font-style:italic; font-size:15px;">prime</span>
          <span style="color:var(--amz-gray);">FREE Returns &nbsp;|&nbsp; FREE Delivery</span>
        </div>
      </div>

      <!-- Variants -->
      {%- unless product.has_only_default_variant -%}
      <div class="product-info__variants">
        {%- for option in product.options_with_values -%}
          <div class="variant-label">{{ option.name }}: <span>{{ option.selected_value }}</span></div>

          {%- if option.name == 'Color' or option.name == 'Colour' -%}
            <div class="swatch-grid" data-variant-group>
              {%- for value in option.values -%}
                <button
                  class="swatch{% if option.selected_value == value %} active{% endif %}"
                  data-swatch
                  data-value="{{ value }}"
                  data-option="{{ option.name }}"
                  style="background: {{ value | downcase }};"
                  title="{{ value }}"
                  aria-label="{{ option.name }}: {{ value }}"
                  aria-pressed="{{ option.selected_value == value }}"></button>
              {%- endfor -%}
            </div>
          {%- elsif option.name == 'Size' -%}
            <div class="size-grid" data-variant-group>
              {%- for value in option.values -%}
                <button
                  class="size-btn{% if option.selected_value == value %} active{% endif %}"
                  data-size-option
                  data-value="{{ value }}"
                  data-option="{{ option.name }}"
                  aria-label="{{ option.name }}: {{ value }}"
                  aria-pressed="{{ option.selected_value == value }}">{{ value }}</button>
              {%- endfor -%}
            </div>
          {%- else -%}
            <select class="form-select" style="margin-bottom:12px; max-width:240px;" data-option-select aria-label="{{ option.name }}">
              {%- for value in option.values -%}
                <option value="{{ value }}" {% if option.selected_value == value %}selected{% endif %}>{{ value }}</option>
              {%- endfor -%}
            </select>
          {%- endif -%}
        {%- endfor -%}
      </div>
      {%- endunless -%}

      <!-- Description -->
      {%- if product.description != blank -%}
      <div class="product-info__description" style="font-size:14px; color:var(--amz-text); line-height:1.6; padding-top:14px; border-top:1px solid #eee;">
        {{ product.description }}
      </div>
      {%- endif -%}

      <!-- Tech Specs Table -->
      <div style="margin-top:20px;">
        <h3 style="font-size:16px; font-weight:700; margin-bottom:10px;">Product Details</h3>
        <table style="width:100%; border-collapse:collapse; font-size:13px; border:1px solid #eee; border-radius:6px; overflow:hidden;">
          <tr style="border-bottom:1px solid #eee;">
            <td style="padding:9px 14px; background:#f7f8f8; font-weight:600; width:40%;">Brand</td>
            <td style="padding:9px 14px;">{{ product.vendor | default: 'N/A' }}</td>
          </tr>
          <tr style="border-bottom:1px solid #eee;">
            <td style="padding:9px 14px; background:#f7f8f8; font-weight:600;">SKU / Model</td>
            <td style="padding:9px 14px;">{{ current_variant.sku | default: product.id }}</td>
          </tr>
          {%- for tag in product.tags limit: 4 -%}
            {%- unless tag contains 'bestseller' or tag contains 'new' or tag contains 'prime' -%}
            <tr style="border-bottom:1px solid #eee;">
              <td style="padding:9px 14px; background:#f7f8f8; font-weight:600;">Feature</td>
              <td style="padding:9px 14px;">{{ tag | replace: '-', ' ' | capitalize }}</td>
            </tr>
            {%- endunless -%}
          {%- endfor -%}
          <tr>
            <td style="padding:9px 14px; background:#f7f8f8; font-weight:600;">Available</td>
            <td style="padding:9px 14px; color:{% if product.available %}var(--amz-green){% else %}var(--amz-deal-red){% endif %}; font-weight:600;">
              {% if product.available %}In Stock{% else %}Out of Stock{% endif %}
            </td>
          </tr>
        </table>
      </div>
    </div>

    <!-- Column 4: Buy Box -->
    <div class="product-buy-box" id="ProductBuyBox">

      <!-- Price in buy box -->
      <div class="product-buy-box__price">
        {%- if discount_pct > 0 -%}
          <span style="font-size:13px; color:var(--amz-deal-red); font-weight:700;">-{{ discount_pct }}%</span>
        {%- endif -%}
        <span style="font-size:28px; font-weight:400;" data-buybox-price>{{ current_variant.price | money }}</span>
        {%- if discount_pct > 0 -%}
          <div style="font-size:13px; color:var(--amz-gray); margin-top:2px;">
            List: <del>{{ current_variant.compare_at_price | money }}</del>
          </div>
          <div style="font-size:13px; color:var(--amz-deal-red);">You save {{ savings | money }} ({{ discount_pct }}%)</div>
        {%- endif -%}
      </div>

      <!-- Prime delivery -->
      <div class="product-buy-box__delivery">
        <span style="color:var(--amz-prime-blue); font-weight:700; font-style:italic;">prime</span>
        FREE delivery
        <strong>
          {%- assign today_num = 'now' | date: '%u' | plus: 0 -%}
          {%- if today_num < 5 -%}Tomorrow{%- else -%}Monday{%- endif -%}
        </strong>
        <br>
        Order within <span style="color:var(--amz-deal-red); font-weight:700;" id="OrderCountdown">2 hrs 30 mins</span>
      </div>

      <!-- Delivery location -->
      <div style="font-size:13px; margin-bottom:12px; color:var(--amz-text);">
        📍 Deliver to <a href="#" style="color:var(--amz-link); font-weight:700; text-decoration:underline;">United States</a>
      </div>

      <!-- Stock status -->
      {%- if current_variant.available -%}
        <div class="product-buy-box__stock">In Stock</div>
      {%- else -%}
        <div class="product-buy-box__stock" style="color:var(--amz-deal-red);">Currently unavailable</div>
      {%- endif -%}

      <!-- Quantity -->
      <div class="product-buy-box__quantity">
        <label style="font-size:13px; font-weight:600; margin-bottom:6px; display:block;" for="ProductQuantity">Quantity:</label>
        <div class="quantity-selector">
          <button class="quantity-btn" data-qty-decrease aria-label="Decrease quantity">−</button>
          <input
            type="number"
            class="quantity-input"
            id="ProductQuantity"
            min="1"
            max="{{ current_variant.inventory_quantity | default: 99 }}"
            value="1"
            data-qty-input
            aria-label="Quantity">
          <button class="quantity-btn" data-qty-increase aria-label="Increase quantity">+</button>
        </div>
      </div>

      <!-- CTA Form -->
      <form action="/cart/add" method="post" data-product-form>
        <input type="hidden" name="id" value="{{ current_variant.id }}" data-variant-input>
        <input type="hidden" name="quantity" value="1" data-qty-hidden>

        <div class="product-buy-box__cta">
          {%- if current_variant.available -%}
            <button
              type="button"
              class="btn btn--add-cart"
              data-add-to-cart
              data-variant-id="{{ current_variant.id }}"
              aria-label="Add {{ product.title | escape }} to cart">
              Add to Cart
            </button>
            <a
              href="/cart"
              class="btn btn--buy-now"
              data-buy-now
              aria-label="Buy {{ product.title | escape }} now"
              onclick="event.preventDefault(); document.querySelector('[data-product-form]').submit();">
              Buy Now
            </a>
          {%- else -%}
            <button type="button" class="btn btn--add-cart" disabled style="opacity:0.55; cursor:not-allowed;">
              Currently Unavailable
            </button>
          {%- endif -%}
        </div>
      </form>

      <!-- Secure transaction -->
      <div class="product-buy-box__secure">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="#555" aria-hidden="true"><path d="M18 8h-1V6c0-2.76-2.24-5-5-5S7 3.24 7 6v2H6c-1.1 0-2 .9-2 2v10c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V10c0-1.1-.9-2-2-2zm-6 9c-1.1 0-2-.9-2-2s.9-2 2-2 2 .9 2 2-.9 2-2 2zm3.1-9H8.9V6c0-1.71 1.39-3.1 3.1-3.1 1.71 0 3.1 1.39 3.1 3.1v2z"/></svg>
        Secure transaction
      </div>

      <!-- Meta info -->
      <div class="product-buy-box__meta">
        <div>Ships from: <span>{{ shop.name }}</span></div>
        <div>Sold by: <span>{{ product.vendor | default: shop.name }}</span></div>
        <div>Returns: <a href="/policies/refund-policy" style="color:var(--amz-link); font-size:12px;">Eligible for Return &amp; Refund</a></div>
      </div>

      <!-- Wishlist + Share -->
      <div style="display:flex; gap:12px; margin-top:14px; font-size:13px; border-top:1px solid #f0f0f0; padding-top:12px;">
        <button
          style="color:var(--amz-link); background:none; border:none; cursor:pointer; font-size:13px; display:flex; align-items:center; gap:4px;"
          data-wishlist-btn
          data-product-id="{{ product.id }}"
          aria-label="Add {{ product.title | escape }} to wishlist">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
          Add to List
        </button>
        <button
          style="color:var(--amz-link); background:none; border:none; cursor:pointer; font-size:13px; display:flex; align-items:center; gap:4px;"
          onclick="if(navigator.share) navigator.share({title:'{{ product.title | escape }}', url:window.location.href});"
          aria-label="Share {{ product.title | escape }}">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/></svg>
          Share
        </button>
      </div>

    </div><!-- /.product-buy-box -->

  </div><!-- /.product-page__inner -->

  <!-- Related Products -->
  <div style="background:#fff; padding:24px 0; margin-top:0; border-top:8px solid var(--amz-bg);">
    <div class="page-width" style="max-width:1500px;">
      <div class="section-wrapper__header">
        <h2 class="section-wrapper__title">Customers who viewed this item also viewed</h2>
        <a href="{{ product.collections.first.url | default: '/collections/all' }}" class="section-wrapper__link">See all &rsaquo;</a>
      </div>
      <div class="products-carousel" id="RelatedProductsCarousel" style="position:relative;">
        <div class="products-carousel__track" id="RelatedProductsTrack">
          {%- assign related_collection = collections[product.collections.first.handle] -%}
          {%- if related_collection -%}
            {%- for related in related_collection.products limit: 12 -%}
              {%- unless related.handle == product.handle -%}
                <div class="products-carousel__item">
                  {%- render 'product-card', product: related -%}
                </div>
              {%- endunless -%}
            {%- endfor -%}
          {%- endif -%}
        </div>
        <button class="products-carousel__nav products-carousel__nav--prev" onclick="document.getElementById('RelatedProductsTrack').scrollBy({left:-600, behavior:'smooth'})" aria-label="Scroll left">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M15.41 7.41L14 6l-6 6 6 6 1.41-1.41L10.83 12z"/></svg>
        </button>
        <button class="products-carousel__nav products-carousel__nav--next" onclick="document.getElementById('RelatedProductsTrack').scrollBy({left:600, behavior:'smooth'})" aria-label="Scroll right">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M10 6L8.59 7.41 13.17 12l-4.58 4.59L10 18l6-6z"/></svg>
        </button>
      </div>
    </div>
  </div>

  <!-- Reviews Section -->
  <div class="reviews-section" id="reviews">
    <div class="page-width" style="max-width:1500px;">
      <h2 style="font-size:24px; font-weight:700; margin-bottom:20px; color:var(--amz-text);">Customer reviews</h2>

      <div class="reviews-summary">
        <div class="reviews-summary__score">
          <div class="reviews-summary__score-number">{{ review_rating | round: 1 }}</div>
          <div class="reviews-summary__score-stars" aria-label="{{ review_rating }} out of 5 stars">
            {%- assign full = review_rating | floor -%}
            {%- for s in (1..5) -%}
              {%- if s <= full -%}★{%- else -%}☆{%- endif -%}
            {%- endfor -%}
          </div>
          <div style="font-size:13px; color:var(--amz-gray);">{{ review_count | number_with_delimiter }} global ratings</div>
        </div>
        <div class="reviews-summary__bars">
          {%- assign star_pcts = "72,18,6,3,1" | split: "," -%}
          {%- for i in (1..5) -%}
            {%- assign star = 6 | minus: i -%}
            {%- assign pct = star_pcts[i | minus: 1] -%}
            <div class="rating-bar">
              <a href="#" class="rating-bar__label">{{ star }} star</a>
              <div class="rating-bar__bar">
                <div class="rating-bar__bar-fill" style="width:{{ pct }}%;"></div>
              </div>
              <span class="rating-bar__count">{{ pct }}%</span>
            </div>
          {%- endfor -%}
        </div>
      </div>

      <div style="margin-top:20px; padding-top:20px; border-top:1px solid #eee;">
        <p style="font-size:14px; color:var(--amz-gray); font-style:italic;">
          Review this product — Share your thoughts with other customers
        </p>
        <a href="{{ routes.account_login_url }}" style="display:inline-block; margin-top:10px; background:linear-gradient(to bottom,#f7f8f8,#e7e9ec); border:1px solid #adb1b8; border-radius:3px; padding:8px 16px; font-size:13px; color:var(--amz-text); text-decoration:none;">
          Write a customer review
        </a>
      </div>
    </div>
  </div>

</div><!-- /.product-page-wrapper -->

<!-- Mobile Sticky Buy Bar -->
<div class="sticky-buy-bar" id="StickyBuyBar" role="complementary" aria-label="Quick purchase actions">
  <div style="flex:1; min-width:0; overflow:hidden;">
    <div style="font-size:13px; font-weight:600; white-space:nowrap; overflow:hidden; text-overflow:ellipsis;">{{ product.title }}</div>
    <div style="font-size:15px; font-weight:700;">{{ current_variant.price | money }}</div>
  </div>
  <button
    class="btn btn--add-cart"
    data-add-to-cart
    data-variant-id="{{ current_variant.id }}"
    style="width:auto; padding:10px 20px; flex-shrink:0;"
    aria-label="Add to cart">
    Add to Cart
  </button>
  <a href="/cart" class="btn btn--buy-now" style="width:auto; padding:10px 20px; flex-shrink:0;">Buy Now</a>
</div>

<style>
/* Product page mobile */
@media (max-width: 900px) {
  .product-page__inner {
    grid-template-columns: 1fr !important;
    gap: 16px;
  }
  .product-thumbnails {
    flex-direction: row !important;
    position: static !important;
    overflow-x: auto;
    padding-bottom: 4px;
    gap: 8px;
    scrollbar-width: none;
  }
  .product-thumbnails::-webkit-scrollbar { display: none; }
  .product-thumbnail { width: 54px !important; height: 54px !important; flex-shrink: 0; }
  .product-main-image { position: static !important; max-height: 60vw; }
  .product-main-image__img { max-height: 60vw; object-fit: contain; }
  .product-buy-box { position: static !important; }
  .reviews-summary { flex-direction: column; }
  .reviews-summary__bars { min-width: 100%; }
}
@media (max-width: 480px) {
  .product-page__inner { padding: 12px 10px; }
  .product-info__title { font-size: 18px !important; }
}
</style>

<script>
// Countdown timer
(function() {
  var el = document.getElementById('OrderCountdown');
  if (!el) return;
  var seconds = 150 * 60;
  setInterval(function() {
    if (seconds <= 0) { el.textContent = 'Order now!'; return; }
    seconds--;
    var h = Math.floor(seconds / 3600);
    var m = Math.floor((seconds % 3600) / 60);
    var s = seconds % 60;
    el.textContent = h > 0 ? h + ' hr ' + m + ' mins' : m + ' mins ' + String(s).padStart(2,'0') + ' secs';
  }, 1000);
})();

// Variant form update
document.querySelectorAll('[data-size-option], [data-swatch]').forEach(function(btn) {
  btn.addEventListener('click', function() {
    var group = this.closest('[data-variant-group]');
    if (group) group.querySelectorAll('button').forEach(function(b) {
      b.classList.remove('active');
      b.setAttribute('aria-pressed', 'false');
    });
    this.classList.add('active');
    this.setAttribute('aria-pressed', 'true');
  });
});
</script>
