{% comment %} Contact Us Page Template {% endcomment %}

<div style="background:linear-gradient(135deg,#131921,#232f3e);padding:50px 20px;text-align:center;color:#fff;">
  <div class="page-width">
    <h1 style="font-size:34px;font-weight:800;color:#ff9900;margin-bottom:12px;">Contact Us</h1>
    <p style="font-size:16px;color:#ccc;">We're here to help. Reach out to us anytime.</p>
  </div>
</div>

<div class="page-width" style="padding:60px 16px;">
  <div style="display:grid;grid-template-columns:1fr 1.4fr;gap:60px;align-items:start;">

    <!-- Contact Info -->
    <div>
      <h2 style="font-size:22px;font-weight:700;margin-bottom:24px;color:#0f1111;">Get in Touch</h2>

      <div style="display:flex;align-items:flex-start;gap:14px;margin-bottom:22px;padding:18px;background:#f8f8f8;border-radius:10px;">
        <div style="width:44px;height:44px;background:#131921;border-radius:8px;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#ff9900" stroke-width="2" aria-hidden="true"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 014.33 12.3a19.79 19.79 0 01-3.07-8.67A2 2 0 013.44 1.5h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L7.91 9a16 16 0 006.09 6.09l1.86-1.84a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 16.92z"/></svg>
        </div>
        <div>
          <div style="font-weight:700;font-size:14px;color:#0f1111;margin-bottom:4px;">Phone Support</div>
          <a href="tel:+911800000000" style="color:#007185;font-size:14px;">+91 1800-000-000</a>
          <div style="font-size:12px;color:#565959;margin-top:2px;">Mon–Sat, 9AM – 6PM IST</div>
        </div>
      </div>

      <div style="display:flex;align-items:flex-start;gap:14px;margin-bottom:22px;padding:18px;background:#f8f8f8;border-radius:10px;">
        <div style="width:44px;height:44px;background:#131921;border-radius:8px;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#ff9900" stroke-width="2" aria-hidden="true"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
        </div>
        <div>
          <div style="font-weight:700;font-size:14px;color:#0f1111;margin-bottom:4px;">Email Us</div>
          <a href="mailto:support@{{ shop.domain }}" style="color:#007185;font-size:14px;">support@{{ shop.domain }}</a>
          <div style="font-size:12px;color:#565959;margin-top:2px;">We reply within 24 hours</div>
        </div>
      </div>

      <div style="display:flex;align-items:flex-start;gap:14px;margin-bottom:22px;padding:18px;background:#f8f8f8;border-radius:10px;">
        <div style="width:44px;height:44px;background:#131921;border-radius:8px;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#ff9900" stroke-width="2" aria-hidden="true"><path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/></svg>
        </div>
        <div>
          <div style="font-weight:700;font-size:14px;color:#0f1111;margin-bottom:4px;">Live Chat</div>
          <div style="font-size:14px;color:#007600;font-weight:600;">● Available Now</div>
          <div style="font-size:12px;color:#565959;margin-top:2px;">Average wait: &lt; 2 minutes</div>
        </div>
      </div>

      <div style="display:flex;align-items:flex-start;gap:14px;padding:18px;background:#f8f8f8;border-radius:10px;">
        <div style="width:44px;height:44px;background:#131921;border-radius:8px;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#ff9900" stroke-width="2" aria-hidden="true"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/></svg>
        </div>
        <div>
          <div style="font-weight:700;font-size:14px;color:#0f1111;margin-bottom:4px;">Our Address</div>
          <div style="font-size:14px;color:#333;line-height:1.6;">{{ shop.name }}<br>India</div>
        </div>
      </div>
    </div>

    <!-- Contact Form -->
    <div style="background:#fff;border:1px solid #eee;border-radius:16px;padding:36px;box-shadow:0 4px 24px rgba(0,0,0,0.07);">
      <h2 style="font-size:22px;font-weight:700;margin-bottom:24px;color:#0f1111;">Send Us a Message</h2>
      <form id="contactForm" action="/contact#contact_form" accept-charset="UTF-8" method="POST">
        <input type="hidden" name="form_type" value="contact">
        <input type="hidden" name="utf8" value="✓">

        <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-bottom:16px;">
          <div>
            <label for="contact_name" style="display:block;font-size:13px;font-weight:600;color:#0f1111;margin-bottom:6px;">Your Name *</label>
            <input type="text" id="contact_name" name="contact[name]" required placeholder="John Doe"
              style="width:100%;padding:10px 14px;border:1px solid #ddd;border-radius:6px;font-size:14px;outline:none;transition:border-color 0.15s;"
              onfocus="this.style.borderColor='#ff9900'" onblur="this.style.borderColor='#ddd'">
          </div>
          <div>
            <label for="contact_email" style="display:block;font-size:13px;font-weight:600;color:#0f1111;margin-bottom:6px;">Email Address *</label>
            <input type="email" id="contact_email" name="contact[email]" required placeholder="john@example.com"
              style="width:100%;padding:10px 14px;border:1px solid #ddd;border-radius:6px;font-size:14px;outline:none;transition:border-color 0.15s;"
              onfocus="this.style.borderColor='#ff9900'" onblur="this.style.borderColor='#ddd'">
          </div>
        </div>

        <div style="margin-bottom:16px;">
          <label for="contact_phone" style="display:block;font-size:13px;font-weight:600;color:#0f1111;margin-bottom:6px;">Phone Number</label>
          <input type="tel" id="contact_phone" name="contact[phone]" placeholder="+91 9876543210"
            style="width:100%;padding:10px 14px;border:1px solid #ddd;border-radius:6px;font-size:14px;outline:none;transition:border-color 0.15s;"
            onfocus="this.style.borderColor='#ff9900'" onblur="this.style.borderColor='#ddd'">
        </div>

        <div style="margin-bottom:16px;">
          <label for="contact_subject" style="display:block;font-size:13px;font-weight:600;color:#0f1111;margin-bottom:6px;">Subject *</label>
          <select id="contact_subject" name="contact[subject]" required
            style="width:100%;padding:10px 14px;border:1px solid #ddd;border-radius:6px;font-size:14px;background:#fff;outline:none;">
            <option value="">Select a subject…</option>
            <option>Order Issue</option>
            <option>Return & Refund</option>
            <option>Product Question</option>
            <option>Shipping Delay</option>
            <option>Payment Issue</option>
            <option>Other</option>
          </select>
        </div>

        <div style="margin-bottom:20px;">
          <label for="contact_message" style="display:block;font-size:13px;font-weight:600;color:#0f1111;margin-bottom:6px;">Message *</label>
          <textarea id="contact_message" name="contact[body]" required rows="5" placeholder="Describe your issue or question in detail…"
            style="width:100%;padding:10px 14px;border:1px solid #ddd;border-radius:6px;font-size:14px;resize:vertical;outline:none;transition:border-color 0.15s;font-family:inherit;"
            onfocus="this.style.borderColor='#ff9900'" onblur="this.style.borderColor='#ddd'"></textarea>
        </div>

        <button type="submit"
          style="width:100%;background:#FFD814;border:1px solid #FCD200;border-radius:8px;padding:13px;font-size:15px;font-weight:700;color:#0f1111;cursor:pointer;transition:background 0.15s;"
          onmouseover="this.style.background='#F7CA00'" onmouseout="this.style.background='#FFD814'">
          Send Message
        </button>

        {%- if form.posted_successfully? -%}
        <div style="margin-top:16px;padding:14px;background:#d4edda;border:1px solid #c3e6cb;border-radius:8px;color:#155724;font-size:14px;">
          ✓ Your message has been sent! We'll get back to you within 24 hours.
        </div>
        {%- endif -%}

      </form>
    </div>

  </div>
</div>

<style>
@media (max-width: 768px) {
  .page-width > div[style*="grid-template-columns:1fr 1.4fr"] { grid-template-columns: 1fr !important; }
}
</style>
