{% comment %} About Us Page Template {% endcomment %}

<div class="amz-page-hero" style="background:linear-gradient(135deg,#131921 0%,#232f3e 100%);color:#fff;text-align:center;padding:60px 20px 50px;">
  <div class="page-width">
    <h1 style="font-size:36px;font-weight:800;margin-bottom:16px;color:#ff9900;">About {{ shop.name }}</h1>
    <p style="font-size:18px;color:#ccc;max-width:600px;margin:0 auto;line-height:1.7;">We are dedicated to bringing you the best products at unbeatable prices — delivered right to your door.</p>
  </div>
</div>

<div class="page-width" style="padding:60px 16px;">

  <!-- Mission -->
  <div style="display:grid;grid-template-columns:1fr 1fr;gap:60px;align-items:center;margin-bottom:70px;">
    <div>
      <h2 style="font-size:28px;font-weight:700;color:#0f1111;margin-bottom:16px;">Our Mission</h2>
      <p style="font-size:15px;color:#333;line-height:1.8;margin-bottom:14px;">At <strong>{{ shop.name }}</strong>, our mission is simple: to be the most customer-centric company in the world. We work every day to earn and keep customer trust by delivering quality products fast, at fair prices, with hassle-free returns.</p>
      <p style="font-size:15px;color:#333;line-height:1.8;">We believe shopping should be easy, secure, and enjoyable for everyone — whether you're buying for yourself, your family, or your business.</p>
    </div>
    <div style="background:linear-gradient(135deg,#fff3e0,#ffe0b2);border-radius:16px;padding:40px;text-align:center;">
      <svg width="80" height="80" viewBox="0 0 24 24" fill="none" stroke="#ff9900" stroke-width="1.5" aria-hidden="true"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
      <p style="font-size:22px;font-weight:700;color:#e65c00;margin-top:16px;">Customer First, Always</p>
    </div>
  </div>

  <!-- Stats -->
  <div style="background:#f8f9fa;border-radius:16px;padding:50px 40px;margin-bottom:70px;text-align:center;">
    <h2 style="font-size:26px;font-weight:700;margin-bottom:40px;color:#0f1111;">By the Numbers</h2>
    <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:30px;">
      <div>
        <div style="font-size:40px;font-weight:800;color:#ff9900;">10K+</div>
        <div style="font-size:14px;color:#565959;margin-top:6px;">Products Available</div>
      </div>
      <div>
        <div style="font-size:40px;font-weight:800;color:#ff9900;">50K+</div>
        <div style="font-size:14px;color:#565959;margin-top:6px;">Happy Customers</div>
      </div>
      <div>
        <div style="font-size:40px;font-weight:800;color:#ff9900;">4.8★</div>
        <div style="font-size:14px;color:#565959;margin-top:6px;">Average Rating</div>
      </div>
      <div>
        <div style="font-size:40px;font-weight:800;color:#ff9900;">99%</div>
        <div style="font-size:14px;color:#565959;margin-top:6px;">On-Time Delivery</div>
      </div>
    </div>
  </div>

  <!-- Why Choose Us -->
  <h2 style="font-size:26px;font-weight:700;margin-bottom:30px;text-align:center;color:#0f1111;">Why Shop With Us?</h2>
  <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:24px;margin-bottom:70px;">
    {% assign reasons = "Lowest Prices|Quality Guarantee|Fast Delivery|Easy Returns|Secure Payments|24/7 Support" | split: "|" %}
    {% assign icons = "price|quality|delivery|return|secure|support" | split: "|" %}
    {% assign descs = "We price match and offer daily deals to ensure you always get the best value.|Every product is quality-checked before it ships to your door.|Free delivery on eligible orders delivered in 3-5 business days.|30-day hassle-free returns with no questions asked.|SSL encrypted checkout with all major payment methods accepted.|Our support team is available 7 days a week to help you." | split: "|" %}
    {% for reason in reasons %}
    <div style="background:#fff;border:1px solid #eee;border-radius:12px;padding:28px 24px;text-align:center;box-shadow:0 2px 12px rgba(0,0,0,0.06);transition:transform 0.2s;" onmouseover="this.style.transform='translateY(-4px)'" onmouseout="this.style.transform=''">
      <div style="width:52px;height:52px;background:linear-gradient(135deg,#fff3e0,#ffe0b2);border-radius:50%;margin:0 auto 16px;display:flex;align-items:center;justify-content:center;">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#ff9900" stroke-width="2" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
      </div>
      <h3 style="font-size:15px;font-weight:700;color:#0f1111;margin-bottom:8px;">{{ reason }}</h3>
      <p style="font-size:13px;color:#565959;line-height:1.6;">{{ descs[forloop.index0] }}</p>
    </div>
    {% endfor %}
  </div>

  <!-- CTA -->
  <div style="background:linear-gradient(135deg,#131921,#232f3e);border-radius:16px;padding:50px;text-align:center;color:#fff;">
    <h2 style="font-size:28px;font-weight:700;margin-bottom:12px;">Ready to Start Shopping?</h2>
    <p style="font-size:16px;color:#ccc;margin-bottom:28px;">Join thousands of happy customers today.</p>
    <a href="/collections/all" style="display:inline-block;background:#FFD814;color:#0f1111;font-weight:700;font-size:16px;padding:14px 40px;border-radius:8px;text-decoration:none;transition:background 0.15s;" onmouseover="this.style.background='#F7CA00'" onmouseout="this.style.background='#FFD814'">Shop All Products</a>
  </div>

</div>

<style>
@media (max-width: 768px) {
  .page-width > div > div[style*="grid-template-columns:1fr 1fr"] { grid-template-columns: 1fr !important; }
  .page-width > div > div[style*="grid-template-columns:repeat(4"] { grid-template-columns: repeat(2,1fr) !important; }
  .page-width > div > div[style*="grid-template-columns:repeat(3"] { grid-template-columns: 1fr !important; }
}
</style>
