<div class="cro-comparison page-width" style="padding:{{ section.settings.padding_top }}px 16px {{ section.settings.padding_bottom }}px;background:{{ section.settings.bg_color }};">
  {%- if section.settings.heading != blank -%}
    <h2 class="cro-section-title" style="text-align:center;font-size:22px;font-weight:700;margin-bottom:20px;color:{{ section.settings.heading_color }};">{{ section.settings.heading }}</h2>
  {%- endif -%}
  <div style="overflow-x:auto;">
    <table class="cro-comparison__table" style="width:100%;border-collapse:collapse;background:#fff;border-radius:8px;overflow:hidden;border:1px solid #e7e7e7;min-width:500px;">
      <thead>
        <tr>
          <th style="text-align:left;padding:12px 16px;background:{{ section.settings.header_bg }};color:{{ section.settings.header_text }};font-size:13px;font-weight:600;border-bottom:2px solid #e7e7e7;min-width:140px;">Features</th>
          {%- for block in section.blocks -%}
            <th style="text-align:center;padding:12px 16px;background:{{ section.settings.header_bg }};color:{{ section.settings.header_text }};font-size:14px;font-weight:700;border-bottom:2px solid #e7e7e7;{% if block.settings.highlight %}background:{{ section.settings.highlight_bg }};color:{{ section.settings.highlight_text }};{% endif %}">
              {{ block.settings.product_name }}
              {%- if block.settings.price != blank -%}
                <div style="font-size:13px;font-weight:400;margin-top:2px;opacity:0.8;">{{ block.settings.price }}</div>
              {%- endif -%}
            </th>
          {%- endfor -%}
        </tr>
      </thead>
      <tbody>
        {%- assign features = section.settings.features | split: ',' -%}
        {%- for feature in features -%}
          {%- assign trimmed = feature | strip -%}
          <tr>
            <td style="padding:10px 16px;font-size:13px;color:var(--amz-text,#0f1111);font-weight:500;border-bottom:1px solid #f0f0f0;">{{ trimmed }}</td>
            {%- for block in section.blocks -%}
              <td style="text-align:center;padding:10px 16px;font-size:13px;color:var(--amz-gray,#565959);border-bottom:1px solid #f0f0f0;{% if block.settings.highlight %}background:#fffbf0;{% endif %}">
                {%- assign feature_key = trimmed | handleize -%}
                {%- assign check = block.settings[feature_key] -%}
                {%- if check != blank -%}
                  {{ check }}
                {%- else -%}
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="{{ section.settings.tick_color }}" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
                {%- endif -%}
              </td>
            {%- endfor -%}
          </tr>
        {%- endfor -%}
      </tbody>
    </table>
  </div>
</div>
<style>
@media(max-width:600px){
  .cro-comparison__table{font-size:12px!important;}
  .cro-comparison__table th,.cro-comparison__table td{padding:8px 10px!important;}
}
</style>

{% schema %}
{
  "name": "CRO - Comparison Table",
  "tag": "section",
  "class": "cro-section cro-comparison-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Compare Products"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading Color",
      "default": "#0f1111"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Section Background",
      "default": "#eaeded"
    },
    {
      "type": "color",
      "id": "header_bg",
      "label": "Header Background",
      "default": "#232f3e"
    },
    {
      "type": "color",
      "id": "header_text",
      "label": "Header Text Color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "highlight_bg",
      "label": "Highlight Column Background",
      "default": "#fef0c7"
    },
    {
      "type": "color",
      "id": "highlight_text",
      "label": "Highlight Column Text",
      "default": "#0f1111"
    },
    {
      "type": "color",
      "id": "tick_color",
      "label": "Checkmark Color",
      "default": "#007600"
    },
    {
      "type": "textarea",
      "id": "features",
      "label": "Features (comma separated)",
      "default": "Price, Quality, Warranty, Shipping, Support",
      "info": "Each feature becomes a row in the table."
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding Top",
      "min": 0,
      "max": 80,
      "step": 4,
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding Bottom",
      "min": 0,
      "max": 80,
      "step": 4,
      "default": 40
    }
  ],
  "blocks": [
    {
      "type": "product",
      "name": "Product Column",
      "settings": [
        {
          "type": "text",
          "id": "product_name",
          "label": "Product Name",
          "default": "Product"
        },
        {
          "type": "text",
          "id": "price",
          "label": "Price",
          "default": "₹499"
        },
        {
          "type": "checkbox",
          "id": "highlight",
          "label": "Highlight This Column",
          "default": false
        },
        {
          "type": "header",
          "content": "Feature Values"
        },
        {
          "type": "text",
          "id": "price_value",
          "label": "Price Value",
          "default": "₹499"
        },
        {
          "type": "select",
          "id": "quality_value",
          "label": "Quality",
          "options": [
            { "value": "Premium", "label": "Premium" },
            { "value": "Standard", "label": "Standard" },
            { "value": "Basic", "label": "Basic" }
          ],
          "default": "Premium"
        },
        {
          "type": "text",
          "id": "warranty_value",
          "label": "Warranty",
          "default": "2 Years"
        },
        {
          "type": "text",
          "id": "shipping_value",
          "label": "Shipping",
          "default": "Free"
        },
        {
          "type": "text",
          "id": "support_value",
          "label": "Support",
          "default": "24/7"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "CRO - Comparison Table",
      "category": "CRO",
      "blocks": [
        { "type": "product", "settings": { "product_name": "Standard", "price": "₹299", "quality_value": "Basic", "warranty_value": "6 Months", "shipping_value": "Paid", "support_value": "Email" } },
        { "type": "product", "settings": { "product_name": "Premium", "price": "₹499", "highlight": true, "quality_value": "Premium", "warranty_value": "2 Years", "shipping_value": "Free", "support_value": "24/7" } },
        { "type": "product", "settings": { "product_name": "Pro", "price": "₹799", "quality_value": "Premium", "warranty_value": "3 Years", "shipping_value": "Free", "support_value": "24/7 Priority" } }
      ]
    }
  ]
}
{% endschema %}
