<div class="cro-delivery page-width" style="padding:{{ section.settings.padding_top }}px 16px {{ section.settings.padding_bottom }}px;background:{{ section.settings.bg_color }};">
  <div class="cro-delivery__inner" style="display:flex;align-items:center;gap:20px;flex-wrap:wrap;background:#fff;border:1px solid {{ section.settings.border_color }};border-radius:8px;padding:20px 24px;">
    <div style="flex-shrink:0;width:44px;height:44px;border-radius:50%;background:{{ section.settings.icon_bg }};display:flex;align-items:center;justify-content:center;">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="{{ section.settings.icon_color }}" stroke-width="1.5"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
    </div>
    <div style="flex:1;min-width:150px;">
      <div style="font-size:14px;font-weight:600;color:{{ section.settings.text_color }};margin-bottom:4px;">{{ section.settings.heading }}</div>
      <div style="font-size:20px;font-weight:700;color:{{ section.settings.date_color }};margin-bottom:4px;">{{ section.settings.estimated_date }}</div>
      <div style="font-size:12px;color:var(--amz-gray,#565959);">{{ section.settings.description }}</div>
    </div>
    {%- if section.settings.show_countdown -%}
      <div style="text-align:center;padding-left:16px;border-left:1px solid #e7e7e7;">
        <div class="cro-delivery__countdown" style="font-size:24px;font-weight:700;color:{{ section.settings.countdown_color }};" data-hours="{{ section.settings.countdown_hours }}">{{ section.settings.countdown_hours }}:00</div>
        <div style="font-size:11px;color:var(--amz-gray,#565959);">Order within</div>
      </div>
    {%- endif -%}
  </div>
</div>
<style>
@media(max-width:480px){
  .cro-delivery__inner{flex-direction:column;text-align:center;padding:16px!important;}
  .cro-delivery__inner>div:last-child{border-left:none!important;padding-left:0!important;padding-top:12px;border-top:1px solid #e7e7e7;}
}
</style>
<script>
document.addEventListener('DOMContentLoaded',function(){
  var cdEl=document.querySelector('.cro-delivery__countdown');
  if(!cdEl)return;
  var totalMinutes=parseInt(cdEl.dataset.hours)*60||300;
  function tick(){
    if(totalMinutes<=0){cdEl.textContent='Order Now!';return;}
    var h=Math.floor(totalMinutes/60);
    var m=totalMinutes%60;
    cdEl.textContent=String(h).padStart(2,'0')+':'+String(m).padStart(2,'0');
    totalMinutes--;
  }
  tick();
  setInterval(tick,60000);
});
</script>

{% schema %}
{
  "name": "CRO - Delivery Estimator",
  "tag": "section",
  "class": "cro-section cro-delivery-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "FREE Delivery"
    },
    {
      "type": "text",
      "id": "estimated_date",
      "label": "Estimated Delivery Date",
      "default": "Wednesday, June 3"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Order now and get it delivered by this date"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#0f1111"
    },
    {
      "type": "color",
      "id": "date_color",
      "label": "Date Color",
      "default": "#007600"
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "Border Color",
      "default": "#007600"
    },
    {
      "type": "color",
      "id": "icon_bg",
      "label": "Icon Background",
      "default": "#f0faf0"
    },
    {
      "type": "color",
      "id": "icon_color",
      "label": "Icon Color",
      "default": "#007600"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Section Background",
      "default": "#eaeded"
    },
    {
      "type": "checkbox",
      "id": "show_countdown",
      "label": "Show Countdown Timer",
      "default": true
    },
    {
      "type": "range",
      "id": "countdown_hours",
      "label": "Countdown Hours",
      "min": 1,
      "max": 24,
      "step": 1,
      "default": 5
    },
    {
      "type": "color",
      "id": "countdown_color",
      "label": "Countdown Color",
      "default": "#007600"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding Top",
      "min": 0,
      "max": 80,
      "step": 4,
      "default": 24
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding Bottom",
      "min": 0,
      "max": 80,
      "step": 4,
      "default": 24
    }
  ],
  "presets": [
    {
      "name": "CRO - Delivery Estimator",
      "category": "CRO"
    }
  ]
}
{% endschema %}
