<div class="cro-reviews-carousel page-width" style="padding:{{ section.settings.padding_top }}px 16px {{ section.settings.padding_bottom }}px;background:{{ section.settings.bg_color }};">
  {%- if section.settings.heading != blank -%}
    <h2 class="cro-section-title" style="text-align:center;font-size:24px;font-weight:700;margin-bottom:8px;color:{{ section.settings.heading_color }};">{{ section.settings.heading }}</h2>
  {%- endif -%}
  {%- if section.settings.subheading != blank -%}
    <p style="text-align:center;font-size:14px;color:var(--amz-gray,#565959);margin:0 0 28px;">{{ section.settings.subheading }}</p>
  {%- endif -%}
  <div class="cro-rc__track" style="display:flex;gap:20px;overflow-x:auto;scroll-snap-type:x mandatory;padding-bottom:16px;scrollbar-width:thin;">
    {%- for block in section.blocks -%}
      <div class="cro-rc__card" style="flex:0 0 calc(100%/{{ section.settings.columns_desktop }} - 16px);min-width:280px;background:#fff;border:1px solid #e7e7e7;border-radius:8px;padding:24px;scroll-snap-align:start;transition:box-shadow .2s;" onmouseover="this.style.boxShadow='0 4px 20px rgba(0,0,0,.08)'" onmouseout="this.style.boxShadow='none'">
        <div style="color:#ff9900;font-size:20px;margin-bottom:10px;">{{ block.settings.rating }}</div>
        <p style="font-size:14px;color:var(--amz-text,#0f1111);line-height:1.6;margin:0 0 16px;font-style:italic;">"{{ block.settings.review_text }}"</p>
        <div style="display:flex;align-items:center;gap:10px;">
          {%- if block.settings.avatar != blank -%}
            <img src="{{ block.settings.avatar | image_url: width: 60 }}" alt="" loading="lazy" style="width:36px;height:36px;border-radius:50%;object-fit:cover;">
          {%- else -%}
            <div style="width:36px;height:36px;border-radius:50%;background:var(--amz-orange,#ff9900);display:flex;align-items:center;justify-content:center;font-size:16px;font-weight:700;color:#fff;">{{ block.settings.author | slice: 0 | upcase }}</div>
          {%- endif -%}
          <div>
            <div style="font-size:14px;font-weight:600;color:var(--amz-text,#0f1111);">{{ block.settings.author }}</div>
            {%- if block.settings.date != blank -%}
              <div style="font-size:12px;color:var(--amz-gray,#565959);">{{ block.settings.date }}</div>
            {%- endif -%}
          </div>
        </div>
      </div>
    {%- endfor -%}
  </div>
</div>
<style>
.cro-rc__track::-webkit-scrollbar{height:6px;}
.cro-rc__track::-webkit-scrollbar-thumb{background:#ccc;border-radius:3px;}
.cro-rc__track::-webkit-scrollbar-track{background:transparent;}
@media(max-width:768px){
  .cro-rc__card{flex:0 0 calc(100%/2 - 12px)!important;min-width:0!important;}
}
@media(max-width:480px){
  .cro-rc__card{flex:0 0 100%!important;}
}
</style>

{% schema %}
{
  "name": "CRO - Reviews Carousel",
  "tag": "section",
  "class": "cro-section cro-rc-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "What Our Customers Are Saying"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Real reviews from real customers"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading Color",
      "default": "#0f1111"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#eaeded"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "label": "Columns Visible at Once",
      "min": 2,
      "max": 5,
      "step": 1,
      "default": 3
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding Top",
      "min": 0,
      "max": 80,
      "step": 4,
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding Bottom",
      "min": 0,
      "max": 80,
      "step": 4,
      "default": 40
    }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Review",
      "settings": [
        {
          "type": "image_picker",
          "id": "avatar",
          "label": "Customer Avatar"
        },
        {
          "type": "text",
          "id": "author",
          "label": "Customer Name",
          "default": "Verified Customer"
        },
        {
          "type": "text",
          "id": "date",
          "label": "Date",
          "default": "2 weeks ago"
        },
        {
          "type": "text",
          "id": "rating",
          "label": "Stars (HTML)",
          "default": "★★★★★",
          "info": "Use ★ and ☆ characters"
        },
        {
          "type": "textarea",
          "id": "review_text",
          "label": "Review Text",
          "default": "Absolutely love this product! The quality exceeded my expectations."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "CRO - Reviews Carousel",
      "category": "CRO",
      "blocks": [
        { "type": "review", "settings": { "author": "Ananya R.", "review_text": "Absolutely love this product!" } },
        { "type": "review", "settings": { "author": "Vikram S.", "review_text": "Great quality and fast shipping." } },
        { "type": "review", "settings": { "author": "Neha P.", "review_text": "Worth every penny! Highly recommend." } }
      ]
    }
  ]
}
{% endschema %}
