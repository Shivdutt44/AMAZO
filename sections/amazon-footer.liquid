<footer class="amazon-footer" style="background-color: {{ section.settings.bg_color }}; color: {{ section.settings.text_color }};">
  <div class="amz-back-to-top">
    <a href="#top" style="color: {{ section.settings.text_color }}; text-decoration: none; display: block; padding: 15px; text-align: center;">Back to top</a>
  </div>
  
  <div class="amz-footer-main" style="background-color: {{ section.settings.main_bg_color }};">
    <div class="amz-footer-container">
      <div class="amz-footer-links">
        {% for block in section.blocks %}
          {% if block.type == 'link_column' %}
            <div class="amz-footer-col">
              <h3>{{ block.settings.heading }}</h3>
              <ul>
                {% assign footer_menu = linklists[block.settings.menu] %}
                {% if footer_menu.links.size > 0 %}
                  {% for link in footer_menu.links %}
                    <li><a href="{{ link.url }}">{{ link.title }}</a></li>
                  {% endfor %}
                {% else %}
                  <li><a href="#">Sample Link 1</a></li>
                  <li><a href="#">Sample Link 2</a></li>
                  <li><a href="#">Sample Link 3</a></li>
                {% endif %}
              </ul>
            </div>
          {% elsif block.type == 'social_icons' %}
            <div class="amz-footer-col">
              <h3>{{ block.settings.heading | default: 'Connect With Us' }}</h3>
              <div class="amz-footer-social-icons">
                {% if block.settings.facebook_url != blank %}
                  <a href="{{ block.settings.facebook_url }}" class="amz-footer-social-icon" aria-label="Facebook" target="_blank" rel="noopener">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z"/></svg>
                  </a>
                {% else %}
                  <a href="#" class="amz-footer-social-icon amz-footer-social-icon--placeholder" aria-label="Facebook (placeholder)">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z"/></svg>
                  </a>
                {% endif %}
                {% if block.settings.twitter_url != blank %}
                  <a href="{{ block.settings.twitter_url }}" class="amz-footer-social-icon" aria-label="Twitter" target="_blank" rel="noopener">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M23 3a10.9 10.9 0 01-3.14 1.53 4.48 4.48 0 00-7.86 3v1A10.66 10.66 0 013 4s-4 9 5 13a11.64 11.64 0 01-7 2c9 5 20 0 20-11.5a4.5 4.5 0 00-.08-.83A7.72 7.72 0 0023 3z"/></svg>
                  </a>
                {% else %}
                  <a href="#" class="amz-footer-social-icon amz-footer-social-icon--placeholder" aria-label="Twitter (placeholder)">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M23 3a10.9 10.9 0 01-3.14 1.53 4.48 4.48 0 00-7.86 3v1A10.66 10.66 0 013 4s-4 9 5 13a11.64 11.64 0 01-7 2c9 5 20 0 20-11.5a4.5 4.5 0 00-.08-.83A7.72 7.72 0 0023 3z"/></svg>
                  </a>
                {% endif %}
                {% if block.settings.instagram_url != blank %}
                  <a href="{{ block.settings.instagram_url }}" class="amz-footer-social-icon" aria-label="Instagram" target="_blank" rel="noopener">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1112.63 8 4 4 0 0116 11.37zm1.5-4.87h.01"/></svg>
                  </a>
                {% else %}
                  <a href="#" class="amz-footer-social-icon amz-footer-social-icon--placeholder" aria-label="Instagram (placeholder)">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1112.63 8 4 4 0 0116 11.37zm1.5-4.87h.01"/></svg>
                  </a>
                {% endif %}
                {% if block.settings.youtube_url != blank %}
                  <a href="{{ block.settings.youtube_url }}" class="amz-footer-social-icon" aria-label="YouTube" target="_blank" rel="noopener">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M22.54 6.42a2.78 2.78 0 00-1.94-2C18.88 4 12 4 12 4s-6.88 0-8.6.46a2.78 2.78 0 00-1.94 2A29 29 0 001 11.75a29 29 0 00.46 5.33A2.78 2.78 0 003.4 19.1c1.72.46 8.6.46 8.6.46s6.88 0 8.6-.46a2.78 2.78 0 001.94-2 29 29 0 00.46-5.33 29 29 0 00-.46-5.33zM9.75 15.02V8.48l5.75 3.27-5.75 3.27z"/></svg>
                  </a>
                {% else %}
                  <a href="#" class="amz-footer-social-icon amz-footer-social-icon--placeholder" aria-label="YouTube (placeholder)">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M22.54 6.42a2.78 2.78 0 00-1.94-2C18.88 4 12 4 12 4s-6.88 0-8.6.46a2.78 2.78 0 00-1.94 2A29 29 0 001 11.75a29 29 0 00.46 5.33A2.78 2.78 0 003.4 19.1c1.72.46 8.6.46 8.6.46s6.88 0 8.6-.46a2.78 2.78 0 001.94-2 29 29 0 00.46-5.33 29 29 0 00-.46-5.33zM9.75 15.02V8.48l5.75 3.27-5.75 3.27z"/></svg>
                  </a>
                {% endif %}
                {% if block.settings.pinterest_url != blank %}
                  <a href="{{ block.settings.pinterest_url }}" class="amz-footer-social-icon" aria-label="Pinterest" target="_blank" rel="noopener">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.08 3.15 9.42 7.6 11.18-.1-.94-.19-2.38.04-3.41.21-.93 1.36-5.77 1.36-5.77s-.35-.7-.35-1.73c0-1.62.94-2.83 2.11-2.83 1 0 1.48.75 1.48 1.64 0 1-.64 2.5-.97 3.89-.27 1.16.58 2.1 1.72 2.1 2.07 0 3.66-2.18 3.66-5.33 0-2.79-2-4.74-4.87-4.74-3.32 0-5.27 2.49-5.27 5.06 0 1 .39 2.08.87 2.66.1.12.11.22.08.34l-.33 1.32c-.05.21-.17.26-.39.16-1.46-.68-2.37-2.81-2.37-4.52 0-3.67 2.67-7.04 7.7-7.04 4.04 0 7.18 2.88 7.18 6.73 0 4.02-2.53 7.25-6.05 7.25-1.18 0-2.29-.61-2.67-1.34l-.73 2.77c-.26 1.01-1 2.27-1.48 3.04A10 10 0 0012 24c6.63 0 12-5.37 12-12S18.63 0 12 0z"/></svg>
                  </a>
                {% else %}
                  <a href="#" class="amz-footer-social-icon amz-footer-social-icon--placeholder" aria-label="Pinterest (placeholder)">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.08 3.15 9.42 7.6 11.18-.1-.94-.19-2.38.04-3.41.21-.93 1.36-5.77 1.36-5.77s-.35-.7-.35-1.73c0-1.62.94-2.83 2.11-2.83 1 0 1.48.75 1.48 1.64 0 1-.64 2.5-.97 3.89-.27 1.16.58 2.1 1.72 2.1 2.07 0 3.66-2.18 3.66-5.33 0-2.79-2-4.74-4.87-4.74-3.32 0-5.27 2.49-5.27 5.06 0 1 .39 2.08.87 2.66.1.12.11.22.08.34l-.33 1.32c-.05.21-.17.26-.39.16-1.46-.68-2.37-2.81-2.37-4.52 0-3.67 2.67-7.04 7.7-7.04 4.04 0 7.18 2.88 7.18 6.73 0 4.02-2.53 7.25-6.05 7.25-1.18 0-2.29-.61-2.67-1.34l-.73 2.77c-.26 1.01-1 2.27-1.48 3.04A10 10 0 0012 24c6.63 0 12-5.37 12-12S18.63 0 12 0z"/></svg>
                  </a>
                {% endif %}
              </div>
            </div>
          {% elsif block.type == 'payment_icons' %}
            <div class="amz-footer-col amz-footer-col--full">
              <h3>{{ block.settings.heading | default: 'We Accept' }}</h3>
              <div class="amz-footer-payments">
                {% if block.settings.show_visa or block.settings.visa_text != blank %}
                  <span class="amz-payment-placeholder">VISA</span>
                {% else %}
                  <span class="amz-payment-placeholder amz-payment-placeholder--default">VISA</span>
                {% endif %}
                {% if block.settings.show_mastercard or block.settings.mastercard_text != blank %}
                  <span class="amz-payment-placeholder">MC</span>
                {% else %}
                  <span class="amz-payment-placeholder amz-payment-placeholder--default">MC</span>
                {% endif %}
                {% if block.settings.show_amex or block.settings.amex_text != blank %}
                  <span class="amz-payment-placeholder">AMEX</span>
                {% else %}
                  <span class="amz-payment-placeholder amz-payment-placeholder--default">AMEX</span>
                {% endif %}
                {% if block.settings.show_paypal or block.settings.paypal_text != blank %}
                  <span class="amz-payment-placeholder">PayPal</span>
                {% else %}
                  <span class="amz-payment-placeholder amz-payment-placeholder--default">PayPal</span>
                {% endif %}
              </div>
            </div>
          {% elsif block.type == 'contact_info' %}
            <div class="amz-footer-col">
              <h3>{{ block.settings.heading | default: 'Contact Us' }}</h3>
              <ul class="amz-footer-contact">
                {% if block.settings.email != blank %}
                  <li><a href="mailto:{{ block.settings.email }}">📧 {{ block.settings.email }}</a></li>
                {% else %}
                  <li class="amz-footer-placeholder">📧 support@example.com</li>
                {% endif %}
                {% if block.settings.phone != blank %}
                  <li><a href="tel:{{ block.settings.phone }}">📞 {{ block.settings.phone }}</a></li>
                {% else %}
                  <li class="amz-footer-placeholder">📞 +1 (555) 123-4567</li>
                {% endif %}
                {% if block.settings.address != blank %}
                  <li>📍 {{ block.settings.address }}</li>
                {% else %}
                  <li class="amz-footer-placeholder">📍 123 Commerce St, New York, NY 10001</li>
                {% endif %}
              </ul>
            </div>
          {% endif %}
        {% endfor %}
      </div>
    </div>
  </div>
  
  <div class="amz-footer-bottom" style="background-color: {{ section.settings.bottom_bg_color }};">
    <div class="amz-footer-logo">
      {% if section.settings.logo != blank %}
        <img src="{{ section.settings.logo | img_url: '200x' }}" alt="{{ shop.name }}" style="max-width: {{ section.settings.logo_width }}px;">
      {% else %}
        <span style="font-size: 24px; font-weight: bold;">{{ shop.name }}</span>
      {% endif %}
    </div>
    
    <div class="amz-footer-copy">
      <p>&copy; {{ 'now' | date: "%Y" }}, {{ shop.name }}, Inc. or its affiliates</p>
    </div>
  </div>
</footer>

<style>
  .amazon-footer { font-family: Arial, sans-serif; width: 100%; }
  .amz-back-to-top { background-color: #37475A; cursor: pointer; font-size: 13px; font-weight: bold; }
  .amz-back-to-top:hover { background-color: #485769; }
  
  .amz-footer-main { padding: 40px 0; border-bottom: 1px solid #3a4553; }
  .amz-footer-container { max-width: 1000px; margin: 0 auto; padding: 0 20px; }
  .amz-footer-links { display: flex; justify-content: space-between; flex-wrap: wrap; gap: 20px; }
  .amz-footer-col h3 { font-size: 16px; margin-bottom: 14px; color: #fff; font-weight: bold; }
  .amz-footer-col ul { list-style: none; padding: 0; margin: 0; }
  .amz-footer-col li { margin-bottom: 10px; }
  .amz-footer-col a { color: #DDD; text-decoration: none; font-size: 14px; }
  .amz-footer-col a:hover { text-decoration: underline; }
  .amz-footer-col--full { flex: 1 1 100%; min-width: 100%; text-align: center; margin-top: 10px; }
  .amz-footer-social-icons { display: flex; gap: 10px; flex-wrap: wrap; margin-top: 10px; }
  .amz-footer-social-icon {
    display: flex; align-items: center; justify-content: center;
    width: 38px; height: 38px; border-radius: 50%;
    border: 1px solid rgba(255,255,255,0.3);
    color: #DDD; transition: all 0.2s;
  }
  .amz-footer-social-icon:hover { border-color: #ff9900; color: #ff9900; }
  .amz-footer-social-icon--placeholder { opacity: 0.5; border-style: dashed; }
  .amz-footer-payments { display: flex; gap: 8px; flex-wrap: wrap; justify-content: center; margin-top: 10px; }
  .amz-payment-placeholder {
    display: inline-flex; align-items: center; justify-content: center;
    padding: 6px 12px; background: rgba(255,255,255,0.1);
    border: 1px solid rgba(255,255,255,0.2); border-radius: 4px;
    font-size: 11px; font-weight: 700; color: #DDD; letter-spacing: 0.5px;
  }
  .amz-payment-placeholder--default { opacity: 0.6; border-style: dashed; }
  .amz-footer-contact { list-style: none; padding: 0; margin: 0; }
  .amz-footer-contact li { margin-bottom: 10px; font-size: 14px; }
  .amz-footer-placeholder { opacity: 0.6; font-style: italic; }
  
  .amz-footer-bottom { text-align: center; padding: 30px 0; font-size: 12px; }
  .amz-footer-logo { margin-bottom: 20px; }
  .amz-footer-copy { color: #999; }
</style>

{% schema %}
{
  "name": "Amazon Style Footer",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Back to Top Background",
      "default": "#37475A"
    },
    {
      "type": "color",
      "id": "main_bg_color",
      "label": "Main Footer Background",
      "default": "#232F3E"
    },
    {
      "type": "color",
      "id": "bottom_bg_color",
      "label": "Bottom Area Background",
      "default": "#131A22"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#FFFFFF"
    },
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Footer Logo"
    },
    {
      "type": "range",
      "id": "logo_width",
      "min": 50,
      "max": 250,
      "step": 5,
      "unit": "px",
      "label": "Logo width",
      "default": 100
    }
  ],
  "blocks": [
    {
      "type": "link_column",
      "name": "Link Column",
      "limit": 5,
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Column Heading",
          "default": "Get to Know Us"
        },
        {
          "type": "link_list",
          "id": "menu",
          "label": "Column Menu"
        }
      ]
    },
    {
      "type": "social_icons",
      "name": "Social Icons",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Connect With Us"
        },
        {
          "type": "url",
          "id": "facebook_url",
          "label": "Facebook URL"
        },
        {
          "type": "url",
          "id": "twitter_url",
          "label": "Twitter / X URL"
        },
        {
          "type": "url",
          "id": "instagram_url",
          "label": "Instagram URL"
        },
        {
          "type": "url",
          "id": "youtube_url",
          "label": "YouTube URL"
        },
        {
          "type": "url",
          "id": "pinterest_url",
          "label": "Pinterest URL"
        }
      ]
    },
    {
      "type": "payment_icons",
      "name": "Payment Icons",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "We Accept"
        },
        { "type": "checkbox", "id": "show_visa", "label": "Show Visa", "default": true },
        { "type": "checkbox", "id": "show_mastercard", "label": "Show Mastercard", "default": true },
        { "type": "checkbox", "id": "show_amex", "label": "Show Amex", "default": true },
        { "type": "checkbox", "id": "show_paypal", "label": "Show PayPal", "default": true }
      ]
    },
    {
      "type": "contact_info",
      "name": "Contact Info",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Contact Us"
        },
        {
          "type": "text",
          "id": "email",
          "label": "Email"
        },
        {
          "type": "text",
          "id": "phone",
          "label": "Phone"
        },
        {
          "type": "textarea",
          "id": "address",
          "label": "Address"
        }
      ]
    }
  ],
  "templates": ["index"],
  "presets": [
    {
      "name": "Amazon Style Footer",
      "blocks": [
        { "type": "link_column" },
        { "type": "link_column" },
        { "type": "link_column" },
        { "type": "link_column" },
        { "type": "social_icons" },
        { "type": "payment_icons" },
        { "type": "contact_info" }
      ]
    }
  ]
}
{% endschema %}