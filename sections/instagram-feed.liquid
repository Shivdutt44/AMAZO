{% comment %}
  Amazo Theme — Instagram Feed / Collection Circles Section
  Fully automated: features collection/product circles with animated Instagram-style borders,
  support for images and videos, text truncation, and placeholder defaults.
{% endcomment %}

{%- style -%}
  #amz-insta-{{ section.id }} {
    background-color: {{ section.settings.background_color | default: '#ffffff' }};
    width: {{ section.settings.section_width }}%;
    min-height: {{ section.settings.section_min_height }}px;
    margin: {{ section.settings.margin_top }}px auto {{ section.settings.margin_bottom }}px auto;
    padding: {{ section.settings.padding_top }}px {{ section.settings.padding_right }}px {{ section.settings.padding_bottom }}px {{ section.settings.padding_left }}px;
  }

  #amz-insta-{{ section.id }} .section-header {
    text-align: {{ section.settings.header_position }};
    margin-bottom: 20px;
  }

  #amz-insta-{{ section.id }} .section-heading {
    color: {{ section.settings.heading_color }};
    font-size: {{ section.settings.heading_font_size }}px;
    margin-top: {{ section.settings.heading_margin_top }}px;
    margin-bottom: {{ section.settings.heading_margin_bottom }}px;
    font-weight: 600;
  }

  #amz-insta-{{ section.id }} .section-subheading {
    color: {{ section.settings.subheading_color }};
    font-size: {{ section.settings.subheading_font_size }}px;
    margin-top: {{ section.settings.subheading_margin_top }}px;
    margin-bottom: {{ section.settings.subheading_margin_bottom }}px;
    font-weight: 400;
  }

  #amz-insta-{{ section.id }} .amz-insta-scroll {
    display: flex;
    justify-content: center;
    align-items: flex-start;
    padding-bottom: 5px;
    overflow-x: auto;
    overflow-y: hidden;
    white-space: nowrap;
    -ms-overflow-style: none;
    scrollbar-width: none;
    -webkit-overflow-scrolling: touch;
    gap: 10px;
  }

  #amz-insta-{{ section.id }} .amz-insta-scroll::-webkit-scrollbar { display: none; }

  @media screen and (max-width: 768px) {
    #amz-insta-{{ section.id }} .amz-insta-scroll {
      justify-content: flex-start;
      padding-left: 10px;
      padding-right: 10px;
    }
  }

  #amz-insta-{{ section.id }} .amz-insta-column {
    flex: 0 0 auto;
    padding: 3px;
  }

  #amz-insta-{{ section.id }} .amz-insta-item {
    display: flex;
    justify-content: flex-start;
    flex-direction: column;
    align-items: center;
    padding: 5px;
  }

  #amz-insta-{{ section.id }} .amz-insta-circle-wrap {
    position: relative;
    width: {{ section.settings.circle_size }}px;
    height: {{ section.settings.circle_size }}px;
    margin: 0 auto;
  }

  #amz-insta-{{ section.id }} .amz-insta-image-container {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: {{ section.settings.image_container_size }}px;
    height: {{ section.settings.image_container_size }}px;
    border-radius: 50%;
    overflow: hidden;
    z-index: 1;
  }

  #amz-insta-{{ section.id }} .amz-insta-image-container img,
  #amz-insta-{{ section.id }} .amz-insta-image-container .media-video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    border-radius: 50%;
  }

  #amz-insta-{{ section.id }} .amz-insta-placeholder-img {
    width: {{ section.settings.image_container_size }}px;
    height: {{ section.settings.image_container_size }}px;
    background-color: #f5f5f5;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #999;
    border-radius: 50%;
    overflow: hidden;
  }

  #amz-insta-{{ section.id }} .amz-insta-placeholder-img svg {
    width: 40%;
    height: 40%;
    opacity: 0.5;
  }

  #amz-insta-{{ section.id }} .amz-insta-circle-border {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    fill: none;
    stroke: {{ section.settings.animation_start_color }};
    stroke-linecap: round;
    stroke-width: {{ section.settings.border_width }}px;
    stroke-dasharray: 1;
    stroke-dashoffset: 0;
    z-index: 2;
    {% if section.settings.enable_animation %}
    animation: amz-insta-draw-{{ section.id }} 6s ease-out infinite alternate;
    {% endif %}
  }

  #amz-insta-{{ section.id }} .amz-insta-item:hover .amz-insta-circle-border {
    stroke: {{ section.settings.animation_end_color }};
    {% if section.settings.enable_animation %}
    animation: amz-insta-draw-{{ section.id }} 10s ease-out infinite alternate;
    {% endif %}
    cursor: pointer;
  }

  {% if section.settings.enable_animation %}
  @keyframes amz-insta-draw-{{ section.id }} {
    from {
      stroke: {{ section.settings.animation_start_color }};
      stroke-dasharray: 1;
    }
    to {
      stroke: {{ section.settings.animation_end_color }};
      transform: rotate(180deg);
      stroke-dasharray: 8;
    }
  }
  {% endif %}

  #amz-insta-{{ section.id }} .amz-insta-link {
    display: block;
    color: {{ section.settings.font_color }};
    text-decoration: none;
    transition: transform 0.2s ease;
  }

  #amz-insta-{{ section.id }} .amz-insta-link:hover {
    transform: scale(1.05);
  }

  #amz-insta-{{ section.id }} .amz-insta-name {
    color: {{ section.settings.font_color }};
    font-size: {{ section.settings.font_size }}px;
    text-align: center;
    margin-top: 5px;
    line-height: 1.4;
    max-width: {{ section.settings.circle_size }}px;
  }

  #amz-insta-{{ section.id }} .amz-insta-name a {
    color: inherit;
    text-decoration: none;
    transition: color 0.2s ease;
    display: inline-block;
    width: 100%;
    {% if section.settings.enable_truncation %}
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    {% endif %}
  }

  #amz-insta-{{ section.id }} .amz-insta-name a:hover {
    color: #000;
  }

  /* Placeholder default items when no blocks configured */
  #amz-insta-{{ section.id }} .amz-insta-default-item {
    opacity: 0.8;
  }

  #amz-insta-{{ section.id }} .amz-insta-default-item .amz-insta-circle-border {
    stroke-dasharray: 4;
    opacity: 0.5;
  }

  #amz-insta-{{ section.id }} .amz-insta-default-item .amz-insta-name {
    opacity: 0.6;
    font-style: italic;
  }
{%- endstyle -%}

<div id="amz-insta-{{ section.id }}" class="amz-insta-section">
  <!-- Section Header -->
  {% if section.settings.section_heading != blank or section.settings.section_subheading != blank %}
    <div class="section-header">
      {% if section.settings.section_heading != blank %}
        <h2 class="section-heading">{{ section.settings.section_heading }}</h2>
      {% endif %}
      {% if section.settings.section_subheading != blank %}
        <p class="section-subheading">{{ section.settings.section_subheading }}</p>
      {% endif %}
    </div>
  {% endif %}

  <!-- Scrollable Items -->
  <div class="amz-insta-scroll">
    {% if section.blocks.size > 0 %}

      {% for block in section.blocks %}
        {%- liquid
          if block.settings.item_type == 'collection'
            assign item = collections[block.settings.single_cat]
            assign data_title = item.title | default: 'Collection'
            assign data_url = item.url | default: '#'
            assign item_image = item.image
            assign is_video = false
            assign should_show = true
          elsif block.settings.item_type == 'product'
            assign item = all_products[block.settings.single_product]
            assign data_title = item.title | default: 'Product'
            assign data_url = item.url | default: '#'
            assign item_image = item.featured_image
            assign is_video = false
            assign should_show = true
          elsif block.settings.item_type == 'manual'
            assign data_title = block.settings.custom_name | default: 'Media'
            assign data_url = block.settings.manual_link | default: '#'
            assign is_video = true
            assign should_show = true
            assign item_image = null
            if block.settings.media_type == 'image'
              assign item_image = block.settings.manual_image
              assign is_video = false
            elsif block.settings.media_type == 'video'
              assign video_url = block.settings.manual_video
            elsif block.settings.media_type == 'shopify_video'
              assign shopify_video = block.settings.shopify_video
            endif
          else
            assign should_show = false
          endif

          if should_show
            assign custom_name = block.settings.custom_name
            if custom_name == blank
              assign item_show_name = data_title
            else
              assign item_show_name = custom_name
            endif

            if section.settings.enable_truncation
              if section.settings.truncation_type == 'character'
                assign truncated_name = item_show_name | truncate: section.settings.max_characters, ''
                if section.settings.show_ellipsis and item_show_name.size > section.settings.max_characters
                  assign truncated_name = truncated_name | append: '...'
                endif
              elsif section.settings.truncation_type == 'word'
                assign words = item_show_name | split: ' '
                assign word_count = words | size
                if word_count > section.settings.max_words
                  assign truncated_name = ''
                  for i in (1..section.settings.max_words)
                    assign word_index = i | minus: 1
                    assign word = words[word_index]
                    assign truncated_name = truncated_name | append: word
                    unless i == section.settings.max_words
                      assign truncated_name = truncated_name | append: ' '
                    endunless
                  endfor
                  if section.settings.show_ellipsis
                    assign truncated_name = truncated_name | append: '...'
                  endif
                else
                  assign truncated_name = item_show_name
                endif
              endif
            else
              assign truncated_name = item_show_name
            endif

            assign image_size = section.settings.image_container_size | append: 'x' | append: section.settings.image_container_size
          endif
        -%}

        {% if should_show %}
          <div class="amz-insta-column" {{ block.shopify_attributes }}>
            <div class="amz-insta-item">
              <a href="{{ data_url }}" class="amz-insta-link" aria-label="{{ item_show_name }}">
                <div class="amz-insta-circle-wrap">
                  <div class="amz-insta-image-container">
                    {% if is_video %}
                      {% if block.settings.media_type == 'shopify_video' and shopify_video != blank %}
                        {{ shopify_video | video_tag: image_size: image_size, autoplay: true, muted: true, loop: true, controls: false, playsinline: true, width: section.settings.image_container_size, height: section.settings.image_container_size, class: 'media-video' }}
                      {% elsif block.settings.media_type == 'video' and video_url != blank %}
                        <video class="media-video" width="{{ section.settings.image_container_size }}" height="{{ section.settings.image_container_size }}" autoplay muted loop playsinline>
                          <source src="{{ video_url }}" type="video/mp4">
                          Your browser does not support the video tag.
                        </video>
                      {% else %}
                        <div class="amz-insta-placeholder-img">
                          <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                            <path d="M8 5v14l11-7z" fill="currentColor"/>
                          </svg>
                        </div>
                      {% endif %}
                    {% else %}
                      {% if item_image %}
                        <img loading="eager" width="{{ section.settings.image_container_size }}" height="{{ section.settings.image_container_size }}"
                             src="{{ item_image | img_url: image_size, crop: 'center' }}" alt="{{ item_show_name | escape }}">
                      {% else %}
                        <div class="amz-insta-placeholder-img">
                          <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                            <path d="M21 21H15V15H21V21ZM9 21H3V15H9V21ZM21 9H15V3H21V9ZM9 9H3V3H9V9Z" fill="currentColor"/>
                          </svg>
                        </div>
                      {% endif %}
                    {% endif %}
                  </div>
                  <svg class="amz-insta-circle-border" viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg">
                    <circle cx="50" cy="50" r="45"></circle>
                  </svg>
                </div>
              </a>
              <div class="amz-insta-name">
                <a href="{{ data_url }}" class="title-link" aria-label="{{ item_show_name }}">
                  <strong>{{ truncated_name }}</strong>
                </a>
              </div>
            </div>
          </div>
        {% endif %}
      {% endfor %}

    {% else %}
      <!-- ==============================================
           DEFAULT PLACEHOLDER ITEMS (no blocks configured)
           Shows 5 default circles with placeholder SVGs
           and sample names. Disappears when user adds blocks.
      ============================================== -->
      {%- assign default_names = 'Summer Collection, Autumn Collection, Featured Video, Spring Collection, Best Sellers' | split: ', ' -%}
      {%- assign default_links = '/collections/all, /collections/all, #, /collections/all, /collections/all' | split: ', ' -%}
      {%- assign default_icon = 'collection-1, collection-2, collection-3, collection-1, collection-2' | split: ', ' -%}
      {%- for i in (0..4) -%}
        <div class="amz-insta-column amz-insta-default-item">
          <div class="amz-insta-item">
            <a href="{{ default_links[i] }}" class="amz-insta-link" aria-label="{{ default_names[i] }}">
              <div class="amz-insta-circle-wrap">
                <div class="amz-insta-image-container">
                  {{ default_icon[i] | placeholder_svg_tag: 'amz-insta-placeholder-svg' }}
                </div>
                <svg class="amz-insta-circle-border" viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg">
                  <circle cx="50" cy="50" r="45"></circle>
                </svg>
              </div>
            </a>
            <div class="amz-insta-name">
              <a href="{{ default_links[i] }}" aria-label="{{ default_names[i] }}">
                <strong>{{ default_names[i] }}</strong>
              </a>
            </div>
          </div>
        </div>
      {%- endfor -%}
    {% endif %}
  </div>
</div>

{% schema %}
{
  "name": "Instagram Feed",
  "tag": "section",
  "class": "amz-insta-section-wrapper",
  "max_blocks": 30,
  "settings": [
    {
      "type": "header",
      "content": "Section Layout"
    },
    {
      "type": "range",
      "id": "section_width",
      "label": "Section Width",
      "min": 50,
      "max": 100,
      "step": 5,
      "default": 100,
      "unit": "%"
    },
    {
      "type": "range",
      "id": "section_min_height",
      "label": "Section Minimum Height",
      "info": "Set to 0 for automatic height",
      "min": 0,
      "max": 800,
      "step": 10,
      "default": 0,
      "unit": "px"
    },
    {
      "type": "header",
      "content": "Section Margin (Space Outside)"
    },
    {
      "type": "range",
      "id": "margin_top",
      "label": "Margin Top",
      "min": 0,
      "max": 100,
      "step": 1,
      "default": 0,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "margin_bottom",
      "label": "Margin Bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "default": 0,
      "unit": "px"
    },
    {
      "type": "header",
      "content": "Section Padding (Space Inside)"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding Top",
      "min": 0,
      "max": 100,
      "step": 1,
      "default": 10,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding Bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "default": 10,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_left",
      "label": "Padding Left",
      "min": 0,
      "max": 100,
      "step": 1,
      "default": 10,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_right",
      "label": "Padding Right",
      "min": 0,
      "max": 100,
      "step": 1,
      "default": 10,
      "unit": "px"
    },
    {
      "type": "header",
      "content": "Section Header"
    },
    {
      "type": "text",
      "id": "section_heading",
      "label": "Section Heading",
      "default": "Shop by Collection"
    },
    {
      "type": "text",
      "id": "section_subheading",
      "label": "Section Subheading",
      "default": "Find your perfect style"
    },
    {
      "type": "select",
      "id": "header_position",
      "label": "Header Position",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "center"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading Color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "subheading_color",
      "label": "Subheading Color",
      "default": "#666666"
    },
    {
      "type": "range",
      "id": "heading_font_size",
      "label": "Heading Font Size",
      "min": 16,
      "max": 40,
      "step": 1,
      "default": 28,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "subheading_font_size",
      "label": "Subheading Font Size",
      "min": 12,
      "max": 24,
      "step": 1,
      "default": 16,
      "unit": "px"
    },
    {
      "type": "header",
      "content": "Header Spacing"
    },
    {
      "type": "range",
      "id": "heading_margin_top",
      "label": "Heading Margin Top",
      "min": 0,
      "max": 50,
      "step": 1,
      "default": 0,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "heading_margin_bottom",
      "label": "Heading Margin Bottom",
      "min": 0,
      "max": 50,
      "step": 1,
      "default": 10,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "subheading_margin_top",
      "label": "Subheading Margin Top",
      "min": 0,
      "max": 50,
      "step": 1,
      "default": 0,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "subheading_margin_bottom",
      "label": "Subheading Margin Bottom",
      "min": 0,
      "max": 50,
      "step": 1,
      "default": 5,
      "unit": "px"
    },
    {
      "type": "header",
      "content": "Animation Settings"
    },
    {
      "type": "checkbox",
      "id": "enable_animation",
      "label": "Enable Animation",
      "default": true
    },
    {
      "type": "color",
      "id": "animation_start_color",
      "label": "Animation Start Color",
      "default": "#8a3ab9"
    },
    {
      "type": "color",
      "id": "animation_end_color",
      "label": "Animation End Color",
      "default": "#cd486b"
    },
    {
      "type": "range",
      "id": "border_width",
      "label": "Circle Border Width",
      "min": 1,
      "max": 10,
      "step": 1,
      "default": 3,
      "unit": "px"
    },
    {
      "type": "header",
      "content": "Circle Settings"
    },
    {
      "type": "range",
      "id": "circle_size",
      "label": "Circle Size",
      "min": 80,
      "max": 200,
      "step": 5,
      "default": 120,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "image_container_size",
      "label": "Image Container Size",
      "min": 60,
      "max": 180,
      "step": 5,
      "default": 90,
      "unit": "px",
      "info": "Size of the circular image inside the animated border"
    },
    {
      "type": "header",
      "content": "Collection Settings"
    },
    {
      "type": "range",
      "id": "font_size",
      "label": "Collection Font Size",
      "min": 10,
      "max": 24,
      "step": 1,
      "default": 14,
      "unit": "px"
    },
    {
      "type": "color",
      "id": "font_color",
      "label": "Collection Font Color",
      "default": "#785547"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Section Background Color",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Text Truncation"
    },
    {
      "type": "checkbox",
      "id": "enable_truncation",
      "label": "Enable Text Truncation",
      "default": true
    },
    {
      "type": "select",
      "id": "truncation_type",
      "label": "Truncation Type",
      "options": [
        { "value": "character", "label": "By Character" },
        { "value": "word", "label": "By Word" }
      ],
      "default": "character"
    },
    {
      "type": "range",
      "id": "max_characters",
      "label": "Maximum Characters",
      "min": 5,
      "max": 50,
      "step": 1,
      "default": 15,
      "unit": "ch"
    },
    {
      "type": "range",
      "id": "max_words",
      "label": "Maximum Words",
      "min": 1,
      "max": 10,
      "step": 1,
      "default": 3,
      "unit": "wd"
    },
    {
      "type": "checkbox",
      "id": "show_ellipsis",
      "label": "Show Ellipsis (...)",
      "default": true
    }
  ],
  "blocks": [
    {
      "type": "item",
      "name": "Collection or Product",
      "settings": [
        {
          "type": "select",
          "id": "item_type",
          "label": "Select Content Type",
          "options": [
            { "value": "collection", "label": "Collection (uses collection image)" },
            { "value": "product", "label": "Product (uses product image)" },
            { "value": "manual", "label": "Manual Media (upload custom media)" }
          ],
          "default": "collection"
        },
        {
          "id": "single_cat",
          "type": "collection",
          "label": "Select Collection",
          "info": "Collection image will be used automatically"
        },
        {
          "id": "single_product",
          "type": "product",
          "label": "Select Product",
          "info": "Product featured image will be used automatically"
        },
        {
          "type": "header",
          "content": "Manual Media Settings",
          "info": "Only used when 'Manual Media' is selected above"
        },
        {
          "type": "select",
          "id": "media_type",
          "label": "Media Type",
          "options": [
            { "value": "image", "label": "Image" },
            { "value": "video", "label": "Video URL" },
            { "value": "shopify_video", "label": "Shopify Video" }
          ],
          "default": "image"
        },
        {
          "id": "manual_image",
          "type": "image_picker",
          "label": "Select Image"
        },
        {
          "id": "manual_video",
          "type": "url",
          "label": "Video URL",
          "info": "Upload video to Shopify Files and paste URL here"
        },
        {
          "id": "shopify_video",
          "type": "video",
          "label": "Select Shopify Video"
        },
        {
          "id": "manual_link",
          "type": "url",
          "label": "Link URL",
          "info": "URL to navigate to when clicked (required for manual media)"
        },
        {
          "id": "custom_name",
