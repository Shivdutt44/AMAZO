<div class="cro-guarantee page-width" style="padding:{{ section.settings.padding_top }}px 16px {{ section.settings.padding_bottom }}px;background:{{ section.settings.bg_color }};">
  <div class="cro-guarantee__inner" style="display:flex;align-items:center;justify-content:center;gap:32px;flex-wrap:wrap;background:#fff;border-radius:12px;padding:40px 32px;border:2px solid {{ section.settings.border_color }};text-align:center;">
    <div style="flex-shrink:0;">
      {%- if section.settings.icon_image != blank -%}
        <img src="{{ section.settings.icon_image | image_url: width: 120 }}" alt="{{ section.settings.heading }}" loading="lazy" style="width:80px;height:80px;object-fit:contain;">
      {%- else -%}
        <div style="width:80px;height:80px;border-radius:50%;background:{{ section.settings.icon_bg }};display:flex;align-items:center;justify-content:center;margin:0 auto;">
          <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="{{ section.settings.icon_color }}" stroke-width="1.5"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><polyline points="9 12 11 14 15 10"/></svg>
        </div>
      {%- endif -%}
    </div>
    <div>
      <h3 style="font-size:22px;font-weight:700;margin:0 0 8px;color:{{ section.settings.heading_color }};">{{ section.settings.heading }}</h3>
      <p style="font-size:14px;color:var(--amz-gray,#565959);line-height:1.6;margin:0 0 16px;max-width:500px;">{{ section.settings.description }}</p>
      {%- if section.settings.button_text != blank and section.settings.button_url != blank -%}
        <a href="{{ section.settings.button_url }}" class="cro-guarantee__btn" style="display:inline-block;padding:10px 28px;background:{{ section.settings.btn_bg }};color:{{ section.settings.btn_text }};border-radius:var(--btn-radius,3px);font-size:14px;font-weight:600;text-decoration:none;transition:opacity .2s;" onmouseover="this.style.opacity='0.9'" onmouseout="this.style.opacity='1'">{{ section.settings.button_text }}</a>
      {%- endif -%}
    </div>
  </div>
</div>
<style>
@media(max-width:600px){
  .cro-guarantee__inner{flex-direction:column;padding:24px 16px!important;gap:16px!important;}
  .cro-guarantee__inner h3{font-size:18px!important;}
}
</style>

{% schema %}
{
  "name": "CRO - Guarantee Badge",
  "tag": "section",
  "class": "cro-section cro-guarantee-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "100% Satisfaction Guaranteed"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "We stand behind our products. If you're not completely satisfied, we'll refund your order — no questions asked."
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading Color",
      "default": "#0f1111"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Section Background",
      "default": "#eaeded"
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "Border Color",
      "default": "#007600"
    },
    {
      "type": "color",
      "id": "icon_bg",
      "label": "Icon Circle Background",
      "default": "#f0faf0"
    },
    {
      "type": "color",
      "id": "icon_color",
      "label": "Icon Color",
      "default": "#007600"
    },
    {
      "type": "image_picker",
      "id": "icon_image",
      "label": "Custom Icon Image"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "Learn More"
    },
    {
      "type": "url",
      "id": "button_url",
      "label": "Button URL"
    },
    {
      "type": "color",
      "id": "btn_bg",
      "label": "Button Background",
      "default": "#007600"
    },
    {
      "type": "color",
      "id": "btn_text",
      "label": "Button Text Color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding Top",
      "min": 0,
      "max": 80,
      "step": 4,
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding Bottom",
      "min": 0,
      "max": 80,
      "step": 4,
      "default": 40
    }
  ],
  "presets": [
    {
      "name": "CRO - Guarantee Badge",
      "category": "CRO"
    }
  ]
}
{% endschema %}
