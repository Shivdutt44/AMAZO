{% comment %} Amazo Product Slider v2 — Quick Add + hover zoom + badge {% endcomment %}

<div class="amz-slider-section">
  <div class="amz-slider-section__inner page-width">

    <div class="amz-slider-section__header">
      <h2 class="amz-slider-section__title">
        {{ section.settings.title | default: "Best Sellers" }}
      </h2>
      {%- if section.settings.view_all_text != blank -%}
        <a href="{{ section.settings.view_all_link | default: '/collections/all' }}" class="amz-slider-section__viewall">
          {{ section.settings.view_all_text }} <span class="amz-viewall-arrow">›</span>
        </a>
      {%- endif -%}
    </div>

    <div class="amz-slider-wrap" id="amz-slider-{{ section.id }}">
      <button class="amz-slider__prev" aria-label="Previous">&#10094;</button>

      <div class="amz-slider__track-outer">
        <div class="amz-slider__track" id="amz-slider-track-{{ section.id }}">

          {%- assign slider_collection = section.settings.collection | default: collections.all -%}
          {%- assign product_limit = section.settings.product_count | default: 20 -%}

          {%- for product in slider_collection.products limit: product_limit -%}
            {%- assign sv = product.selected_or_first_available_variant -%}
            {%- assign srating = product.metafields.reviews.rating.value | default: 0 -%}
            {%- if srating == 0 -%}{%- assign srating = product.id | modulo: 25 | times: 0.2 | plus: 3.5 | round: 1 -%}{%- endif -%}
            {%- assign scount = product.metafields.reviews.rating_count | default: 0 -%}
            {%- if scount == 0 -%}{%- assign scount = product.id | modulo: 8000 | plus: 200 -%}{%- endif -%}

            <div class="amz-slider__item">
              <div class="amz-prod-card-wrap">
                <a href="{{ product.url }}" class="amz-prod-card">

                  <!-- Image -->
                  <div class="amz-prod-card__img-wrap">
                    {%- if product.compare_at_price > product.price -%}
                      {%- assign sdiscount = product.compare_at_price | minus: product.price | times: 100 | divided_by: product.compare_at_price | round -%}
                      <div class="amz-prod-card__badge-limited">-{{ sdiscount }}%</div>
                    {%- endif -%}
                    {%- if product.featured_image != blank -%}
                      <img
                        src="{{ product.featured_image | image_url: width: 250 }}"
                        alt="{{ product.title | escape }}"
                        class="amz-prod-card__img"
                        loading="lazy"
                        width="200" height="200">
                    {%- else -%}
                      {{ 'product-' | append: forloop.index | modulo: 6 | plus: 1 | placeholder_svg_tag: 'amz-prod-card__img amz-placeholder-svg' }}
                    {%- endif -%}

                  </div>

                  <!-- Info -->
                  <div class="amz-prod-card__info">
                    <p class="amz-prod-card__title">{{ product.title | truncate: 55 }}</p>

                    <!-- Stars -->
                    <div class="amz-prod-card__stars">
                      <div class="amz-stars" title="{{ srating }} out of 5 stars">
                        {%- assign sfull = srating | floor -%}
                        {%- for i in (1..5) -%}
                          {%- if i <= sfull -%}<span class="amz-star amz-star--full">★</span>{%- else -%}<span class="amz-star amz-star--empty">★</span>{%- endif -%}
                        {%- endfor -%}
                      </div>
                      <span class="amz-prod-card__review-count">({{ scount | number_with_delimiter }})</span>
                    </div>

                    <!-- Price -->
                    <div class="amz-prod-card__price-wrap">
                      {%- if product.compare_at_price > product.price -%}
                        <div class="amz-prod-card__badge-deal">Limited time deal</div>
                      {%- endif -%}
                      <div class="amz-prod-card__price-row">
                        {%- if product.compare_at_price > product.price -%}
                          <span class="amz-prod-card__discount">-{{ sdiscount }}%</span>
                        {%- endif -%}
                        <span class="amz-prod-card__price-sym">{{ cart.currency.symbol }}</span>
                        <span class="amz-prod-card__price-main">{{ product.price | money_without_currency | split: '.' | first }}</span>
                        <span class="amz-prod-card__price-cents">.{{ product.price | money_without_currency | split: '.' | last }}</span>
                      </div>
                      {%- if product.compare_at_price > product.price -%}
                        <div class="amz-prod-card__was">List: <s>{{ product.compare_at_price | money }}</s></div>
                      {%- endif -%}
                    </div>

                    <!-- Prime badge -->
                    {%- if product.price >= 2500 -%}
                      <div class="amz-prod-card__prime">
                        <span class="amz-prime-logo" style="font-size:11px;font-weight:900;color:#00a8e1;font-style:italic;">prime</span>
                        <span class="amz-prod-card__free-del">FREE Delivery</span>
                      </div>
                    {%- endif -%}
                  </div>
                </a>

                <!-- Quick Add (shown on card hover) -->
                {%- if product.available -%}
                  <button
                    type="button"
                    class="amz-prod-card__quick-add amz-add-to-cart"
                    data-product-id="{{ product.id }}"
                    data-variant-id="{{ sv.id }}"
                    aria-label="Add {{ product.title | escape }} to cart">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 01-8 0"/></svg>
                    Add to cart
                  </button>
                {%- else -%}
                  <div class="amz-prod-card__unavailable">Out of stock</div>
                {%- endif -%}
              </div>
            </div>

          {%- else -%}
            {%- for i in (1..10) -%}
              <div class="amz-slider__item">
                <div class="amz-prod-card-wrap amz-prod-card--placeholder">
                  <div class="amz-prod-card__img-wrap"><div class="amz-prod-card__img amz-skeleton"></div></div>
                  <div class="amz-prod-card__info">
                    <div class="amz-skeleton amz-skeleton--text"></div>
                    <div class="amz-skeleton amz-skeleton--text amz-skeleton--short"></div>
                    <div class="amz-skeleton amz-skeleton--price"></div>
                  </div>
                </div>
              </div>
            {%- endfor -%}
          {%- endfor -%}

        </div>
      </div>

      <button class="amz-slider__next" aria-label="Next">&#10095;</button>
    </div>

  </div>
</div>

<style>
.amz-card-wish-btn {
  position: absolute; top: 8px; right: 8px; background: rgba(255,255,255,0.8); border: 1px solid #ddd;
  border-radius: 50%; width: 32px; height: 32px; display: flex; align-items: center; justify-content: center;
  cursor: pointer; z-index: 10; opacity: 0; transition: all 0.2s ease; box-shadow: 0 2px 5px rgba(0,0,0,0.1);
}
.amz-prod-card-wrap:hover .amz-card-wish-btn { opacity: 1; }
.amz-card-wish-btn .amz-heart-icon { stroke: #565959; fill: none; transition: all 0.2s; }
.amz-card-wish-btn.is-wishlisted .amz-heart-icon { stroke: #cc0c39; fill: #cc0c39; }
@media (max-width: 768px) { .amz-card-wish-btn { opacity: 1; width: 28px; height: 28px; } }
</style>

{% schema %}
{
  "name": "Amazon Product Slider",
  "settings": [
    { "type": "text", "id": "title", "label": "Section Title", "default": "Best Sellers" },
    { "type": "collection", "id": "collection", "label": "Collection" },
    { "type": "range", "id": "product_count", "label": "Number of Products", "min": 4, "max": 24, "step": 1, "default": 12 },
    { "type": "text", "id": "view_all_text", "label": "View All Text", "default": "See all best sellers" },
    { "type": "url", "id": "view_all_link", "label": "View All Link" }
  ],
  "presets": [{ "name": "Amazon Product Slider", "settings": { "title": "Best Sellers" } }]
}
{% endschema %}
