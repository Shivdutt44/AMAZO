{% comment %} Homepage Top Cards — 3 configurable product columns {% endcomment %}

{%- liquid
  assign wl = settings.enable_wishlist
  assign c1 = section.settings.card1_collection
  assign c2 = section.settings.card2_collection
  assign c3 = section.settings.card3_collection
  assign p1 = c1.products | default: collections.all.products
  assign p2 = c2.products | default: collections.all.products
  assign p3 = c3.products | default: collections.all.products
-%}

{%- capture card_inner -%}{%- endcapture -%}

{%- comment -%} Card 1 {%- endcomment -%}
<div class="amz-homepage-cards__card">
  <div class="amz-fc">
    <div class="amz-fc__inner">
      <h2 class="amz-fc__title">{{ section.settings.card1_title | default: 'Top Picks' }}</h2>
      <div class="amz-fc__grid">
        {%- for prod in p1 limit: 4 -%}
          {%- assign fav = prod.selected_or_first_available_variant -%}
          <div class="amz-fc__grid-item">
            <a href="{{ prod.url }}" class="amz-fc__product-link">
              <div class="amz-fc__img-wrap">
                {%- if prod.featured_image != blank -%}
                  <img src="{{ prod.featured_image | image_url: width: 200 }}" alt="{{ prod.title | escape }}" loading="lazy" class="amz-fc__grid-img" width="200" height="200">
                {%- else -%}
                  {{ 'product-' | append: forloop.index | placeholder_svg_tag: 'amz-fc__grid-img amz-placeholder-svg' }}
                {%- endif -%}
              </div>
              <p class="amz-fc__product-title">{{ prod.title | truncate: 28 }}</p>
              <p class="amz-fc__product-price"><strong>{{ fav.price | money }}</strong></p>
            </a>
            {%- if wl -%}
            <button class="amz-wishlist-btn amz-fc-wish-btn" aria-label="Save to wishlist"
              data-product-id="{{ prod.id }}" data-product-title="{{ prod.title | escape }}"
              data-product-url="{{ prod.url }}" data-product-image="{{ prod.featured_image | image_url: width: 150 }}"
              data-product-price="{{ fav.price }}" data-variant-id="{{ fav.id }}">
              <svg class="amz-heart-icon" viewBox="0 0 24 24" width="14" height="14"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
            </button>
            {%- endif -%}
          </div>
        {%- endfor -%}
      </div>
      <a href="{{ section.settings.card1_link | default: '/collections/all' }}" class="amz-fc__link">
        {{ section.settings.card1_link_text | default: 'See all recommendations' }}
      </a>
    </div>
  </div>
</div>

