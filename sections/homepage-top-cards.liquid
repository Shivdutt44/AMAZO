{% schema %}
{
  "name": "Homepage Top Cards",
  "class": "amz-top-cards-section",
  "settings": [
    { "type": "header", "content": "Card 1" },
    { "type": "text", "id": "card1_title", "label": "Title", "default": "Best Sellers" },
    { "type": "collection", "id": "card1_collection", "label": "Collection" },
    { "type": "url", "id": "card1_link", "label": "Link" },
    { "type": "text", "id": "card1_link_text", "label": "Link Text", "default": "See all recommendations" },

    { "type": "header", "content": "Card 2" },
    { "type": "text", "id": "card2_title", "label": "Title", "default": "New Arrivals" },
    { "type": "collection", "id": "card2_collection", "label": "Collection" },
    { "type": "range", "id": "card2_offset", "label": "Skip first N products", "min": 0, "max": 20, "step": 1, "default": 4 },
    { "type": "url", "id": "card2_link", "label": "Link" },
    { "type": "text", "id": "card2_link_text", "label": "Link Text", "default": "See all recommendations" },

    { "type": "header", "content": "Card 3" },
    { "type": "text", "id": "card3_title", "label": "Title", "default": "Top Rated" },
    { "type": "collection", "id": "card3_collection", "label": "Collection" },
    { "type": "range", "id": "card3_offset", "label": "Skip first N products", "min": 0, "max": 20, "step": 1, "default": 8 },
    { "type": "url", "id": "card3_link", "label": "Link" },
    { "type": "text", "id": "card3_link_text", "label": "Link Text", "default": "See all recommendations" }
  ],
  "presets": [{ "name": "Homepage Top Cards" }]
}
{% endschema %}
