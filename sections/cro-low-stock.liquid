<div class="cro-lowstock page-width" style="padding:{{ section.settings.padding_top }}px 16px {{ section.settings.padding_bottom }}px;background:{{ section.settings.bg_color }};">
  <div class="cro-lowstock__inner" style="display:flex;align-items:center;justify-content:center;gap:20px;flex-wrap:wrap;background:#fff;border:1px solid {{ section.settings.border_color }};border-radius:8px;padding:20px 24px;">
    <div style="flex-shrink:0;width:40px;height:40px;border-radius:50%;background:{{ section.settings.icon_bg }};display:flex;align-items:center;justify-content:center;">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="{{ section.settings.icon_color }}" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
    </div>
    <div style="flex:1;min-width:200px;">
      <span style="font-weight:600;color:{{ section.settings.text_color }};">{{ section.settings.heading }}</span>
      {%- if section.settings.description != blank -%}
        <p style="font-size:13px;color:var(--amz-gray,#565959);margin:4px 0 0;">{{ section.settings.description }}</p>
      {%- endif -%}
    </div>
    {%- if section.settings.button_text != blank and section.settings.button_url != blank -%}
      <a href="{{ section.settings.button_url }}" style="display:inline-block;padding:8px 20px;background:{{ section.settings.btn_bg }};color:{{ section.settings.btn_text }};border-radius:var(--btn-radius,3px);font-size:13px;font-weight:600;text-decoration:none;white-space:nowrap;transition:opacity .2s;" onmouseover="this.style.opacity='0.9'" onmouseout="this.style.opacity='1'">{{ section.settings.button_text }}</a>
    {%- endif -%}
  </div>
</div>
<style>
@media(max-width:600px){
  .cro-lowstock__inner{flex-direction:column;text-align:center;padding:16px!important;}
}
</style>

{% schema %}
{
  "name": "CRO - Low Stock",
  "tag": "section",
  "class": "cro-section cro-lowstock-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "🔥 Low Stock Alert — Selling Fast!"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Popular items are selling out quickly. Order soon to avoid disappointment."
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#b12704"
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "Border Color",
      "default": "#cc0c39"
    },
    {
      "type": "color",
      "id": "icon_bg",
      "label": "Icon Background",
      "default": "#fff0f0"
    },
    {
      "type": "color",
      "id": "icon_color",
      "label": "Icon Color",
      "default": "#cc0c39"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Section Background",
      "default": "#eaeded"
    },
    {
      "type": "color",
      "id": "btn_bg",
      "label": "Button Background",
      "default": "#cc0c39"
    },
    {
      "type": "color",
      "id": "btn_text",
      "label": "Button Text Color",
      "default": "#ffffff"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "button_url",
      "label": "Button URL"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding Top",
      "min": 0,
      "max": 80,
      "step": 4,
      "default": 24
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding Bottom",
      "min": 0,
      "max": 80,
      "step": 4,
      "default": 24
    }
  ],
  "presets": [
    {
      "name": "CRO - Low Stock",
      "category": "CRO"
    }
  ]
}
{% endschema %}
