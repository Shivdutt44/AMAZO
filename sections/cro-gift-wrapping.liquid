{{ 'amazo-cro.css' | asset_url | stylesheet_tag }}

{%- style -%}
  #cro-gift-{{ section.id }} {
    --gift-bg: {{ section.settings.bg_color }};
    --gift-text: {{ section.settings.text_color }};
    --gift-accent: {{ section.settings.accent_color }};
    --gift-card-bg: {{ section.settings.card_bg }};
    --gift-border: {{ section.settings.border_color }};
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }
{%- endstyle -%}

<div id="cro-gift-{{ section.id }}" class="cro-gift page-width">
  {%- if section.settings.heading != blank -%}
    <div class="cro-section-header">
      <h2 class="cro-section-title">{{ section.settings.heading }}</h2>
      {%- if section.settings.subheading != blank -%}
        <p class="cro-section-subtitle">{{ section.settings.subheading }}</p>
      {%- endif -%}
    </div>
  {%- endif -%}

  <div class="cro-gift__options">
    {%- for block in section.blocks -%}
      <div class="cro-gift__option" {{ block.shopify_attributes }}>
        <div class="cro-gift__option-inner" style="border-color: var(--gift-border); background: var(--gift-card-bg);">
          <div class="cro-gift__option-header">
            <div class="cro-gift__option-icon">
              {%- if block.settings.icon != blank -%}
                <img src="{{ block.settings.icon | img_url: '48x48' }}" alt="" loading="lazy" width="48" height="48">
              {%- else -%}
                <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="var(--gift-accent)" stroke-width="1.5">
                  <rect x="3" y="7" width="18" height="13" rx="2"/>
                  <path d="M3 7V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2v2"/>
                  <path d="M12 3v17"/>
                  <path d="M8 3s-2 2 0 4 4 0 4 0"/>
                  <path d="M16 3s2 2 0 4-4 0-4 0"/>
                </svg>
              {%- endif -%}
            </div>
            <div>
              <h3 class="cro-gift__option-title">{{ block.settings.title }}</h3>
              <div class="cro-gift__option-price">{{ block.settings.price_label }}</div>
            </div>
          </div>
          <p class="cro-gift__option-desc">{{ block.settings.description }}</p>
          {%- if block.settings.show_message_field -%}
            <div class="cro-gift__message-field">
              <label for="cro-gift-msg-{{ block.id }}" class="cro-gift__message-label">{{ block.settings.message_label }}</label>
              <textarea id="cro-gift-msg-{{ block.id }}" class="cro-gift__message-input" placeholder="{{ block.settings.message_placeholder }}" rows="3" maxlength="{{ block.settings.max_chars }}"></textarea>
              <span class="cro-gift__char-count">0/{{ block.settings.max_chars }}</span>
            </div>
          {%- endif -%}
          {%- if block.settings.show_add_btn -%}
            <button type="button" class="cro-gift__add-btn" data-variant-id="{{ block.settings.variant_id }}" data-property="gift_wrap">
              {{ block.settings.btn_text }}
            </button>
          {%- endif -%}
        </div>
      </div>
    {%- endfor -%}
  </div>
</div>

{% schema %}
{
  "name": "CRO - Gift Wrapping",
  "tag": "section",
  "class": "cro-section cro-gift-section",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Gift Wrapping Options"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Make your gift extra special"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background",
      "default": "#fef9ef"
    },
    {
      "type": "color",
      "id": "card_bg",
      "label": "Card background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text",
      "default": "#1a1a2e"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent",
      "default": "#e74c3c"
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "Border",
      "default": "#e8e8e8"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top padding",
      "default": 40,
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom padding",
      "default": 40,
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px"
    }
  ],
  "blocks": [
    {
      "type": "option",
      "name": "Gift Option",
      "settings": [
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Icon image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Premium Gift Wrap"
        },
        {
          "type": "text",
          "id": "price_label",
          "label": "Price label",
          "default": "+ $4.99"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "Beautiful premium wrapping paper with ribbon bow."
        },
        {
          "type": "checkbox",
          "id": "show_message_field",
          "label": "Show message field",
          "default": true
        },
        {
          "type": "text",
          "id": "message_label",
          "label": "Message field label",
          "default": "Gift Message"
        },
        {
          "type": "text",
          "id": "message_placeholder",
          "label": "Message placeholder",
          "default": "Write your gift message here..."
        },
        {
          "type": "range",
          "id": "max_chars",
          "label": "Max characters",
          "default": 200,
          "min": 50,
          "max": 500,
          "step": 10
        },
        {
          "type": "checkbox",
          "id": "show_add_btn",
          "label": "Show add to cart button",
          "default": true
        },
        {
          "type": "text",
          "id": "btn_text",
          "label": "Button text",
          "default": "Add Gift Wrap"
        },
        {
          "type": "number",
          "id": "variant_id",
          "label": "Variant ID (optional)",
          "info": "Product variant ID for gift wrap product"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "CRO - Gift Wrapping",
      "settings": {
        "heading": "Gift Wrapping Options",
        "subheading": "Make your gift extra special",
        "bg_color": "#fef9ef",
        "card_bg": "#ffffff",
        "text_color": "#1a1a2e",
        "accent_color": "#e74c3c",
        "border_color": "#e8e8e8"
      },
      "blocks": [
        {
          "type": "option",
          "settings": {
            "title": "Premium Gift Wrap",
            "price_label": "+ $4.99",
            "description": "Beautiful premium wrapping paper with ribbon bow.",
            "show_message_field": true,
            "message_label": "Gift Message",
            "message_placeholder": "Write your gift message here...",
            "max_chars": 200,
            "show_add_btn": true,
            "btn_text": "Add Gift Wrap"
          }
        },
        {
          "type": "option",
          "settings": {
            "title": "Luxury Gift Box",
            "price_label": "+ $9.99",
            "description": "Elegant gift box with tissue paper, ribbon, and a handwritten card.",
            "show_message_field": true,
            "message_label": "Gift Message",
            "message_placeholder": "Write your gift message here...",
            "max_chars": 200,
            "show_add_btn": true,
            "btn_text": "Add Gift Box"
          }
        }
      ]
    }
  ]
}
{% endschema %}
