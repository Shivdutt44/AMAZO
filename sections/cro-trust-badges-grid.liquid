<div class="cro-trust-grid page-width" style="padding:{{ section.settings.padding_top }}px 16px {{ section.settings.padding_bottom }}px;background:{{ section.settings.bg_color }};">
  {%- if section.settings.heading != blank -%}
    <h2 class="cro-section-title" style="text-align:center;font-size:22px;font-weight:700;margin-bottom:24px;color:{{ section.settings.heading_color }};">{{ section.settings.heading }}</h2>
  {%- endif -%}
  <div class="cro-trust-grid__inner" style="display:grid;grid-template-columns:repeat({{ section.settings.columns }},1fr);gap:20px;">
    {%- for block in section.blocks -%}
      <div class="cro-trust-card" style="text-align:center;padding:24px 16px;background:#fff;border-radius:8px;border:1px solid #e7e7e7;transition:transform .2s,box-shadow .2s;" onmouseover="this.style.boxShadow='0 4px 20px rgba(0,0,0,.08)';this.style.transform='translateY(-2px)'" onmouseout="this.style.boxShadow='none';this.style.transform='none'">
        {%- if block.settings.icon_image != blank -%}
          <img src="{{ block.settings.icon_image | image_url: width: 80 }}" alt="{{ block.settings.title }}" loading="lazy" style="width:60px;height:60px;object-fit:contain;margin-bottom:12px;">
        {%- elsif block.settings.icon_svg != blank -%}
          <div style="margin-bottom:12px;">{{ block.settings.icon_svg }}</div>
        {%- else -%}
          <div style="width:60px;height:60px;margin:0 auto 12px;border-radius:50%;background:var(--amz-orange,#ff9900);display:flex;align-items:center;justify-content:center;">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
          </div>
        {%- endif -%}
        <h3 style="font-size:15px;font-weight:600;margin:0 0 6px;color:{{ section.settings.text_color }};">{{ block.settings.title }}</h3>
        {%- if block.settings.description != blank -%}
          <p style="font-size:13px;color:var(--amz-gray,#565959);line-height:1.5;margin:0;">{{ block.settings.description }}</p>
        {%- endif -%}
      </div>
    {%- endfor -%}
  </div>
</div>
<style>
.cro-trust-grid{background:var(--amz-bg,#eaeded);}
@media(max-width:768px){
  .cro-trust-grid__inner{grid-template-columns:repeat(2,1fr)!important;}
  .cro-section-title{font-size:18px!important;}
}
@media(max-width:480px){
  .cro-trust-grid__inner{grid-template-columns:1fr!important;}
}
</style>

{% schema %}
{
  "name": "CRO - Trust Badges Grid",
  "tag": "section",
  "class": "cro-section cro-trust-grid-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Why Shop With Us"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading Color",
      "default": "#0f1111"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#0f1111"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#eaeded"
    },
    {
      "type": "range",
      "id": "columns",
      "label": "Columns",
      "min": 2,
      "max": 6,
      "step": 1,
      "default": 4
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding Top",
      "min": 0,
      "max": 80,
      "step": 4,
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding Bottom",
      "min": 0,
      "max": 80,
      "step": 4,
      "default": 40
    }
  ],
  "blocks": [
    {
      "type": "badge",
      "name": "Trust Badge",
      "settings": [
        {
          "type": "image_picker",
          "id": "icon_image",
          "label": "Icon Image"
        },
        {
          "type": "textarea",
          "id": "icon_svg",
          "label": "Icon SVG (optional)",
          "info": "Paste raw SVG code if no image selected"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Free Shipping"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "Free delivery on orders over ₹499"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "CRO - Trust Badges Grid",
      "category": "CRO",
      "blocks": [
        { "type": "badge", "settings": { "title": "Free Shipping", "description": "Free delivery on orders over ₹499" } },
        { "type": "badge", "settings": { "title": "Secure Payment", "description": "256-bit SSL encryption" } },
        { "type": "badge", "settings": { "title": "Easy Returns", "description": "30-day hassle-free returns" } },
        { "type": "badge", "settings": { "title": "24/7 Support", "description": "Round-the-clock customer service" } }
      ]
    }
  ]
}
{% endschema %}
