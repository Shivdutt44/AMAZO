<div class="cro-brands page-width" style="padding:{{ section.settings.padding_top }}px 16px {{ section.settings.padding_bottom }}px;background:{{ section.settings.bg_color }};">
  {%- if section.settings.heading != blank -%}
    <p style="text-align:center;font-size:{{ section.settings.heading_size }}px;font-weight:{{ section.settings.heading_weight }};margin:0 0 24px;color:{{ section.settings.heading_color }};letter-spacing:1px;text-transform:uppercase;">{{ section.settings.heading }}</p>
  {%- endif -%}
  <div class="cro-brands__inner" style="display:flex;flex-wrap:wrap;align-items:center;justify-content:center;gap:{{ section.settings.gap }}px;opacity:{{ section.settings.opacity }};">
    {%- for block in section.blocks -%}
      {%- if block.settings.link != blank -%}<a href="{{ block.settings.link }}" target="_blank" rel="noopener" style="display:inline-block;">{%- endif -%}
        {%- if block.settings.image != blank -%}
          <img src="{{ block.settings.image | image_url: width: 200 }}" alt="{{ block.settings.alt | default: block.settings.image.alt }}" loading="lazy" style="max-height:{{ section.settings.logo_height }}px;width:auto;display:block;transition:opacity .2s;" onmouseover="this.style.opacity='1'" onmouseout="this.style.opacity='{{ section.settings.opacity }}'">
        {%- else -%}
          <div style="height:{{ section.settings.logo_height }}px;padding:0 16px;display:flex;align-items:center;font-size:16px;font-weight:600;color:var(--amz-gray,#565959);border:1px dashed #ddd;border-radius:4px;">{{ block.settings.fallback_text | default: 'Brand Logo' }}</div>
        {%- endif -%}
      {%- if block.settings.link != blank -%}</a>{%- endif -%}
    {%- endfor -%}
  </div>
</div>
<style>
.cro-brands__inner img{filter:grayscale(100%);-webkit-filter:grayscale(100%);}
.cro-brands__inner img:hover{filter:grayscale(0%);-webkit-filter:grayscale(0%);}
@media(max-width:600px){
  .cro-brands__inner{gap:16px!important;}
  .cro-brands__inner img{max-height:30px!important;}
}
</style>

{% schema %}
{
  "name": "CRO - Brand Logos",
  "tag": "section",
  "class": "cro-section cro-brands-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "As Featured In"
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Heading Size",
      "min": 10,
      "max": 20,
      "step": 1,
      "default": 12
    },
    {
      "type": "select",
      "id": "heading_weight",
      "label": "Heading Weight",
      "options": [
        { "value": "400", "label": "Normal" },
        { "value": "600", "label": "Semi Bold" },
        { "value": "700", "label": "Bold" }
      ],
      "default": "600"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading Color",
      "default": "#565959"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#f9f9f9"
    },
    {
      "type": "range",
      "id": "logo_height",
      "label": "Logo Max Height (px)",
      "min": 20,
      "max": 80,
      "step": 5,
      "default": 40
    },
    {
      "type": "range",
      "id": "gap",
      "label": "Gap Between Logos",
      "min": 8,
      "max": 48,
      "step": 4,
      "default": 32
    },
    {
      "type": "range",
      "id": "opacity",
      "label": "Logo Opacity",
      "min": 0.1,
      "max": 1,
      "step": 0.1,
      "default": 0.6
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding Top",
      "min": 0,
      "max": 80,
      "step": 4,
      "default": 24
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding Bottom",
      "min": 0,
      "max": 80,
      "step": 4,
      "default": 24
    }
  ],
  "blocks": [
    {
      "type": "logo",
      "name": "Brand Logo",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Logo Image"
        },
        {
          "type": "text",
          "id": "fallback_text",
          "label": "Fallback Text",
          "default": "Brand Name"
        },
        {
          "type": "text",
          "id": "alt",
          "label": "Alt Text"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link URL"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "CRO - Brand Logos",
      "category": "CRO",
      "blocks": [
        { "type": "logo", "settings": { "fallback_text": "Forbes" } },
        { "type": "logo", "settings": { "fallback_text": "TechCrunch" } },
        { "type": "logo", "settings": { "fallback_text": "Business Insider" } },
        { "type": "logo", "settings": { "fallback_text": "The Verge" } }
      ]
    }
  ]
}
{% endschema %}
