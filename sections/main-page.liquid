<div class="page-width" style="padding: 40px 0;">
  {%- render 'breadcrumb' -%}
  <div class="amz-page-content">
    {%- if section.settings.show_title -%}
      <h1 class="page-content__title">{{ page.title | default: section.settings.default_title | default: 'Page Title' }}</h1>
    {%- endif -%}
    <div class="rich-text-section">
      {%- if page.content != blank -%}
        {{ page.content }}
      {%- elsif section.settings.default_content != blank -%}
        {{ section.settings.default_content }}
      {%- else -%}
        <div class="amz-page-placeholder">
          <div class="amz-page-placeholder__icon">📄</div>
          <h2 class="amz-page-placeholder__heading">{{ section.settings.placeholder_heading | default: 'Welcome to this page' }}</h2>
          <p class="amz-page-placeholder__text">{{ section.settings.placeholder_text | default: 'This page content will appear here once it is created. You can add content by editing this page in your Shopify admin.' }}</p>
          <div class="amz-page-placeholder__features">
            <div class="amz-page-placeholder__feature">
              <span class="amz-page-placeholder__icon">🚀</span>
              <h4>Fast Delivery</h4>
              <p>Get your orders delivered in 3-5 business days</p>
            </div>
            <div class="amz-page-placeholder__feature">
              <span class="amz-page-placeholder__icon">🛡️</span>
              <h4>Secure Shopping</h4>
              <p>SSL encrypted checkout with 100% protection</p>
            </div>
            <div class="amz-page-placeholder__feature">
              <span class="amz-page-placeholder__icon">💬</span>
              <h4>24/7 Support</h4>
              <p>Our team is here to help you anytime</p>
            </div>
          </div>
        </div>
      {%- endif -%}
    </div>
  </div>
</div>

<style>
  .amz-page-placeholder {
    text-align: center;
    padding: 40px 20px;
    max-width: 700px;
    margin: 0 auto;
  }
  .amz-page-placeholder__icon { font-size: 64px; margin-bottom: 16px; }
  .amz-page-placeholder__heading { font-size: 26px; font-weight: 700; color: #0f1111; margin-bottom: 12px; }
  .amz-page-placeholder__text { font-size: 15px; color: #565959; line-height: 1.7; margin-bottom: 36px; }
  .amz-page-placeholder__features {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }
  @media (max-width: 600px) {
    .amz-page-placeholder__features { grid-template-columns: 1fr; }
  }
  .amz-page-placeholder__feature {
    background: #fff;
    border: 1px solid #eee;
    border-radius: 12px;
    padding: 24px 16px;
    box-shadow: 0 2px 8px rgba(0,0,0,0.06);
    transition: transform 0.2s;
  }
  .amz-page-placeholder__feature:hover { transform: translateY(-3px); }
  .amz-page-placeholder__feature .amz-page-placeholder__icon { font-size: 36px; }
  .amz-page-placeholder__feature h4 { font-size: 15px; font-weight: 700; color: #0f1111; margin: 8px 0; }
  .amz-page-placeholder__feature p { font-size: 13px; color: #565959; margin: 0; line-height: 1.5; }
</style>

{% schema %}
{
  "name": "Page Content",
  "tag": "section",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_title",
      "label": "Show page title",
      "default": true
    },
    {
      "type": "text",
      "id": "default_title",
      "label": "Default page title",
      "info": "Shown when no page title exists"
    },
    {
      "type": "textarea",
      "id": "default_content",
      "label": "Default content (optional)",
      "info": "Custom default content shown when page has no content"
    },
    {
      "type": "header",
      "content": "Placeholder Content"
    },
    {
      "type": "text",
      "id": "placeholder_heading",
      "label": "Placeholder heading",
      "default": "Welcome to this page"
    },
    {
      "type": "textarea",
      "id": "placeholder_text",
      "label": "Placeholder text",
      "default": "This page content will appear here once it is created. You can add content by editing this page in your Shopify admin."
    }
  ],
  "presets": [{ "name": "Page Content" }]
}
{% endschema %}
