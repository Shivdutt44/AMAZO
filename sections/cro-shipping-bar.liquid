<div class="cro-shipping page-width" style="padding:{{ section.settings.padding_top }}px 16px {{ section.settings.padding_bottom }}px;background:{{ section.settings.bg_color }};">
  <div class="cro-shipping__inner" style="background:#fff;border:1px solid #e7e7e7;border-radius:8px;padding:20px 24px;text-align:center;">
    <div style="display:flex;align-items:center;justify-content:center;gap:8px;margin-bottom:12px;">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="{{ section.settings.icon_color }}" stroke-width="1.5"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
      <span style="font-size:14px;font-weight:600;color:var(--amz-text,#0f1111);">{{ section.settings.heading }}</span>
    </div>
    <div class="cro-shipping__bar-wrap" style="max-width:500px;margin:0 auto 10px;">
      <div class="cro-shipping__bar" style="height:8px;background:#e7e7e7;border-radius:4px;overflow:hidden;">
        <div class="cro-shipping__fill" style="height:100%;width:{{ section.settings.progress }}%;background:linear-gradient(90deg,{{ section.settings.bar_color_start }},{{ section.settings.bar_color_end }});border-radius:4px;transition:width .5s;"></div>
      </div>
    </div>
    <p style="font-size:13px;color:var(--amz-gray,#565959);margin:0;">{{ section.settings.description }}</p>
  </div>
</div>
<style>
@media(max-width:480px){
  .cro-shipping__inner{padding:16px!important;}
}
</style>

{% schema %}
{
  "name": "CRO - Shipping Bar",
  "tag": "section",
  "class": "cro-section cro-shipping-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "🚚 Free Shipping on Orders Over ₹499"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Add ₹X more to qualify for FREE delivery!"
    },
    {
      "type": "range",
      "id": "progress",
      "label": "Progress %",
      "min": 0,
      "max": 100,
      "step": 5,
      "default": 60
    },
    {
      "type": "color",
      "id": "bar_color_start",
      "label": "Bar Gradient Start",
      "default": "#ff9900"
    },
    {
      "type": "color",
      "id": "bar_color_end",
      "label": "Bar Gradient End",
      "default": "#007600"
    },
    {
      "type": "color",
      "id": "icon_color",
      "label": "Icon Color",
      "default": "#007600"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Section Background",
      "default": "#eaeded"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding Top",
      "min": 0,
      "max": 80,
      "step": 4,
      "default": 24
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding Bottom",
      "min": 0,
      "max": 80,
      "step": 4,
      "default": 24
    }
  ],
  "presets": [
    {
      "name": "CRO - Shipping Bar",
      "category": "CRO"
    }
  ]
}
{% endschema %}
