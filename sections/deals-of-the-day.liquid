{% comment %} Amazon Deals of the Day Section {% endcomment %}

<div class="amz-deals" id="amz-deals">
  <div class="amz-deals__inner page-width">

    <div class="amz-deals__header">
      <h2 class="amz-deals__title">{{ section.settings.title | default: "Deals of the Day" }}</h2>
      <div class="amz-deals__timer-wrap">
        <span class="amz-deals__timer-label">Ends in:</span>
        <div class="amz-deals__timer" id="amz-deals-timer">
          <div class="amz-timer__unit"><span class="amz-timer__num" id="amz-timer-h">--</span><span class="amz-timer__label">h</span></div>
          <span class="amz-timer__sep">:</span>
          <div class="amz-timer__unit"><span class="amz-timer__num" id="amz-timer-m">--</span><span class="amz-timer__label">m</span></div>
          <span class="amz-timer__sep">:</span>
          <div class="amz-timer__unit"><span class="amz-timer__num" id="amz-timer-s">--</span><span class="amz-timer__label">s</span></div>
        </div>
      </div>
      <a href="{{ section.settings.view_all_link | default: '/collections/sale' }}" class="amz-deals__viewall">
        See all deals ›
      </a>
    </div>

    <div class="amz-deals__slider-wrap">
      <button class="amz-deals__prev" aria-label="Previous deals">&#10094;</button>

      <div class="amz-deals__track-outer">
        <div class="amz-deals__track" id="amz-deals-track">

          {%- assign deals_collection = section.settings.deals_collection | default: collections.all -%}
          {%- for product in deals_collection.products limit: 8 -%}
            {%- if product.compare_at_price > product.price -%}
              {%- assign deal_pct = product.compare_at_price | minus: product.price | times: 100 | divided_by: product.compare_at_price | round -%}
            {%- else -%}
              {%- assign deal_pct = 20 -%}
            {%- endif -%}
            <div class="amz-deals__item">
              <a href="{{ product.url }}" class="amz-deals__card">
                <div class="amz-deals__card-img-wrap">
                  <span class="amz-deals__badge">-{{ deal_pct }}%</span>
                  {%- if product.featured_image != blank -%}
                    <img
                      src="{{ product.featured_image | image_url: width: 600 }}"
                      srcset="{{ product.featured_image | image_url: width: 300 }} 300w, {{ product.featured_image | image_url: width: 600 }} 600w, {{ product.featured_image | image_url: width: 900 }} 900w"
                      sizes="(max-width: 480px) 40vw, (max-width: 768px) 30vw, 200px"
                      alt="{{ product.title | escape }}"
                      loading="lazy"
                      width="600" height="600"
                    >
                  {%- else -%}
                    {{ 'product-' | append: forloop.index | modulo: 3 | plus: 1 | placeholder_svg_tag: 'amz-deals__img-placeholder' }}
                  {%- endif -%}

                  <!-- Wishlist -->
                  {%- if settings.enable_wishlist -%}
                  <button class="amz-wishlist-btn amz-deals-wish-btn"
                    aria-label="Save to wishlist"
                    data-product-id="{{ product.id }}"
                    data-product-title="{{ product.title | escape }}"
                    data-product-url="{{ product.url }}"
                    data-product-image="{{ product.featured_image | image_url: width: 150 }}"
                    data-product-price="{{ product.price }}"
                    data-variant-id="{{ product.selected_or_first_available_variant.id }}">
                    <svg class="amz-heart-icon" viewBox="0 0 24 24" width="14" height="14">
                      <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
                    </svg>
                  </button>
                  {%- endif -%}
                </div>
                <div class="amz-deals__progress-bar">
                  <div class="amz-deals__progress-fill" style="width: {{ deal_pct | plus: 20 | at_most: 90 }}%;"></div>
                </div>
                <p class="amz-deals__claimed">{{ deal_pct | plus: 15 }}% claimed</p>
                <div class="amz-deals__price-row">
                  <span class="amz-deals__price">{{ product.price | money }}</span>
                  {%- if product.compare_at_price > product.price -%}
                    <span class="amz-deals__was">{{ product.compare_at_price | money }}</span>
                  {%- endif -%}
                </div>
                <p class="amz-deals__name">{{ product.title | truncate: 45 }}</p>
                <div class="amz-deals__prime">
                  <svg viewBox="0 0 50 18" xmlns="http://www.w3.org/2000/svg" width="36" height="13"><text x="0" y="13" font-family="Arial, sans-serif" font-size="11" font-weight="bold" fill="#00A8E1">prime</text></svg>
                </div>
              </a>
            </div>
          {%- else -%}
            {%- assign deal_items = "Deal 1,Deal 2,Deal 3,Deal 4,Deal 5,Deal 6" | split: "," -%}
            {%- assign deal_colors = "#ff6b35,#4a90d9,#7ed321,#f5a623,#d0021b,#9013fe" | split: "," -%}
            {%- assign deal_discounts = "40,35,28,55,30,45" | split: "," -%}
            {%- for item in deal_items -%}
              {%- assign di = forloop.index0 -%}
              <div class="amz-deals__item">
                <div class="amz-deals__card">
                  <div class="amz-deals__card-img-wrap">
                    <span class="amz-deals__badge">-{{ deal_discounts[di] }}%</span>
                    {{ 'product-' | append: forloop.index | modulo: 3 | plus: 1 | placeholder_svg_tag: 'amz-deals__img-placeholder' }}
                  </div>
                  <div class="amz-deals__progress-bar"><div class="amz-deals__progress-fill" style="width: {{ deal_discounts[di] | plus: 20 }}%;"></div></div>
                  <p class="amz-deals__claimed">{{ deal_discounts[di] | plus: 15 }}% claimed</p>
                  <p class="amz-deals__name">Sample Product {{ forloop.index }}</p>
                </div>
              </div>
            {%- endfor -%}
          {%- endfor -%}

        </div>
      </div>

      <button class="amz-deals__next" aria-label="Next deals">&#10095;</button>
    </div>

  </div>
</div>

<style>
.amz-deals__card-img-wrap { position: relative; }
.amz-deals-wish-btn {
  position: absolute; top: 8px; right: 8px; background: rgba(255,255,255,0.9); border: 1px solid #ddd;
  border-radius: 50%; width: 28px; height: 28px; display: flex; align-items: center; justify-content: center;
  cursor: pointer; z-index: 10; transition: all 0.2s;
}
.amz-deals-wish-btn .amz-heart-icon { stroke: #565959; fill: none; }
.amz-deals-wish-btn.is-wishlisted .amz-heart-icon { stroke: #cc0c39; fill: #cc0c39; }
@media (max-width: 768px) { .amz-deals-wish-btn { width: 24px; height: 24px; } }
</style>

<script>
(function () {
  var track = document.getElementById('amz-deals-track');
  if (!track) return;
  var wrap = track.closest('.amz-deals__slider-wrap');
  if (!wrap) return;
  var prevBtn = wrap.querySelector('.amz-deals__prev');
  var nextBtn = wrap.querySelector('.amz-deals__next');
  var items = track.querySelectorAll('.amz-deals__item');
  var cur = 0;

  function getItemWidth() {
    if (!items[0]) return 200;
    return items[0].offsetWidth + parseInt(getComputedStyle(track).gap || 12, 10);
  }

  function getVisible() {
    return Math.max(1, Math.floor(track.parentElement.offsetWidth / getItemWidth()));
  }

  function maxIndex() {
    return Math.max(0, items.length - getVisible());
  }

  function update() {
    track.style.transform = 'translateX(-' + (cur * getItemWidth()) + 'px)';
    if (prevBtn) prevBtn.style.opacity = cur > 0 ? '1' : '0.3';
    if (nextBtn) nextBtn.style.opacity = cur < maxIndex() ? '1' : '0.3';
  }

  if (prevBtn) prevBtn.addEventListener('click', function () {
    cur = Math.max(0, cur - getVisible());
    update();
  });
  if (nextBtn) nextBtn.addEventListener('click', function () {
    cur = Math.min(maxIndex(), cur + getVisible());
    update();
  });

  window.addEventListener('resize', function () {
    cur = Math.min(cur, maxIndex());
    update();
  });

  update();
})();
</script>

{% schema %}
{
  "name": "Amazon Deals of the Day",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "title", "label": "Section Title", "default": "Deals of the Day" },
    { "type": "collection", "id": "deals_collection", "label": "Deals Collection" },
    { "type": "url", "id": "view_all_link", "label": "View All Link" }
  ],
  "presets": [{ "name": "Amazon Deals of the Day" }]
}
{% endschema %}
