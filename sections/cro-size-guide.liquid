<div class="cro-sizeguide page-width" style="padding:{{ section.settings.padding_top }}px 16px {{ section.settings.padding_bottom }}px;background:{{ section.settings.bg_color }};">
  <div class="cro-sizeguide__inner" style="text-align:center;background:#fff;border:1px solid #e7e7e7;border-radius:8px;padding:32px 24px;">
    <div style="margin-bottom:12px;">
      <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="{{ section.settings.icon_color }}" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><line x1="3" y1="9" x2="21" y2="9"/><line x1="9" y1="21" x2="9" y2="9"/></svg>
    </div>
    <h3 style="font-size:20px;font-weight:700;margin:0 0 8px;color:{{ section.settings.heading_color }};">{{ section.settings.heading }}</h3>
    <p style="font-size:14px;color:var(--amz-gray,#565959);margin:0 0 20px;max-width:400px;margin-left:auto;margin-right:auto;">{{ section.settings.description }}</p>
    <button type="button" class="cro-sizeguide__btn" style="padding:10px 28px;background:{{ section.settings.btn_bg }};color:{{ section.settings.btn_text }};border:none;border-radius:var(--btn-radius,3px);font-size:14px;font-weight:600;cursor:pointer;transition:opacity .2s;" onclick="document.getElementById('SizeGuideModal').classList.add('is-open');document.body.classList.add('modal-open');" onmouseover="this.style.opacity='0.9'" onmouseout="this.style.opacity='1'">{{ section.settings.button_text }}</button>
  </div>
</div>

<div class="cro-sizeguide-modal" id="SizeGuideModal" style="position:fixed;inset:0;z-index:9999;display:flex;align-items:center;justify-content:center;pointer-events:none;" aria-hidden="true">
  <div class="cro-sizeguide-overlay" style="position:absolute;inset:0;background:rgba(0,0,0,0.5);opacity:0;transition:opacity .25s;" onclick="document.getElementById('SizeGuideModal').classList.remove('is-open');document.body.classList.remove('modal-open');"></div>
  <div class="cro-sizeguide-container" style="background:#fff;border-radius:8px;max-width:600px;width:calc(100%-32px);max-height:80vh;overflow-y:auto;position:relative;z-index:1;padding:32px;transform:scale(.95) translateY(20px);opacity:0;transition:transform .25s,opacity .25s;">
    <button type="button" style="position:absolute;top:12px;right:12px;background:none;border:none;cursor:pointer;font-size:24px;color:#565959;padding:4px;line-height:1;" onclick="document.getElementById('SizeGuideModal').classList.remove('is-open');document.body.classList.remove('modal-open');" aria-label="Close">&times;</button>
    <h3 style="font-size:20px;font-weight:700;margin:0 0 16px;">{{ section.settings.modal_heading | default: section.settings.heading }}</h3>
    <div style="overflow-x:auto;">
      <table style="width:100%;border-collapse:collapse;">
        <thead>
          <tr style="background:#f7f7f7;">
            <th style="padding:8px 12px;font-size:13px;font-weight:600;text-align:left;border-bottom:1px solid #e7e7e7;">Size</th>
            {%- for block in section.blocks -%}
              <th style="padding:8px 12px;font-size:13px;font-weight:600;text-align:center;border-bottom:1px solid #e7e7e7;">{{ block.settings.size_label }}</th>
            {%- endfor -%}
          </tr>
        </thead>
        <tbody>
          <tr><td style="padding:8px 12px;font-size:13px;font-weight:500;border-bottom:1px solid #f0f0f0;">{{ section.settings.row1_label }}</td>{% for block in section.blocks %}<td style="padding:8px 12px;font-size:13px;text-align:center;border-bottom:1px solid #f0f0f0;">{{ block.settings.row1 }}</td>{% endfor %}</tr>
          <tr><td style="padding:8px 12px;font-size:13px;font-weight:500;border-bottom:1px solid #f0f0f0;">{{ section.settings.row2_label }}</td>{% for block in section.blocks %}<td style="padding:8px 12px;font-size:13px;text-align:center;border-bottom:1px solid #f0f0f0;">{{ block.settings.row2 }}</td>{% endfor %}</tr>
          <tr><td style="padding:8px 12px;font-size:13px;font-weight:500;border-bottom:1px solid #f0f0f0;">{{ section.settings.row3_label }}</td>{% for block in section.blocks %}<td style="padding:8px 12px;font-size:13px;text-align:center;border-bottom:1px solid #f0f0f0;">{{ block.settings.row3 }}</td>{% endfor %}</tr>
        </tbody>
      </table>
    </div>
  </div>
</div>
<style>
.cro-sizeguide-modal.is-open{pointer-events:auto!important;}
.cro-sizeguide-modal.is-open .cro-sizeguide-overlay{opacity:1!important;}
.cro-sizeguide-modal.is-open .cro-sizeguide-container{transform:scale(1) translateY(0)!important;opacity:1!important;}
@media(max-width:600px){
  .cro-sizeguide-container{padding:24px 16px!important;width:calc(100%-16px)!important;}
}
</style>

{% schema %}
{
  "name": "CRO - Size Guide",
  "tag": "section",
  "class": "cro-section cro-sizeguide-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Not Sure About Your Size?"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Use our size guide to find the perfect fit. Measure yourself and compare with our chart."
    },
    {
      "type": "text",
      "id": "modal_heading",
      "label": "Modal Heading",
      "default": "Size Guide"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading Color",
      "default": "#0f1111"
    },
    {
      "type": "color",
      "id": "icon_color",
      "label": "Icon Color",
      "default": "#007185"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Section Background",
      "default": "#eaeded"
    },
    {
      "type": "color",
      "id": "btn_bg",
      "label": "Button Background",
      "default": "#007185"
    },
    {
      "type": "color",
      "id": "btn_text",
      "label": "Button Text Color",
      "default": "#ffffff"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "View Size Guide"
    },
    {
      "type": "text",
      "id": "row1_label",
      "label": "Row 1 Label",
      "default": "Chest (inches)"
    },
    {
      "type": "text",
      "id": "row2_label",
      "label": "Row 2 Label",
      "default": "Waist (inches)"
    },
    {
      "type": "text",
      "id": "row3_label",
      "label": "Row 3 Label",
      "default": "Hip (inches)"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding Top",
      "min": 0,
      "max": 80,
      "step": 4,
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding Bottom",
      "min": 0,
      "max": 80,
      "step": 4,
      "default": 40
    }
  ],
  "blocks": [
    {
      "type": "size",
      "name": "Size Column",
      "limit": 8,
      "settings": [
        {
          "type": "text",
          "id": "size_label",
          "label": "Size Label",
          "default": "S"
        },
        {
          "type": "text",
          "id": "row1",
          "label": "Row 1 Value",
          "default": "36"
        },
        {
          "type": "text",
          "id": "row2",
          "label": "Row 2 Value",
          "default": "30"
        },
        {
          "type": "text",
          "id": "row3",
          "label": "Row 3 Value",
          "default": "36"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "CRO - Size Guide",
      "category": "CRO",
      "blocks": [
        { "type": "size", "settings": { "size_label": "S", "row1": "36", "row2": "30", "row3": "36" } },
        { "type": "size", "settings": { "size_label": "M", "row1": "38", "row2": "32", "row3": "38" } },
        { "type": "size", "settings": { "size_label": "L", "row1": "40", "row2": "34", "row3": "40" } },
        { "type": "size", "settings": { "size_label": "XL", "row1": "42", "row2": "36", "row3": "42" } }
      ]
    }
  ]
}
{% endschema %}
