{{ 'amazo-cro.css' | asset_url | stylesheet_tag }}

{%- style -%}
  #cro-price-match-{{ section.id }} {
    --pm-bg: {{ section.settings.bg_color }};
    --pm-text: {{ section.settings.text_color }};
    --pm-accent: {{ section.settings.accent_color }};
    --pm-card-bg: {{ section.settings.card_bg }};
    --pm-btn-bg: {{ section.settings.btn_bg }};
    --pm-btn-text: {{ section.settings.btn_text_color }};
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }
{%- endstyle -%}

<div id="cro-price-match-{{ section.id }}" class="cro-price-match page-width">
  <div class="cro-price-match__inner" style="background: var(--pm-card-bg);">
    <div class="cro-price-match__content">
      {%- if section.settings.icon != blank -%}
        <div class="cro-price-match__icon">
          <img src="{{ section.settings.icon | img_url: '80x80' }}" alt="" loading="lazy" width="80" height="80">
        </div>
      {%- else -%}
        <div class="cro-price-match__icon">
          <svg width="56" height="56" viewBox="0 0 24 24" fill="none" stroke="var(--pm-accent)" stroke-width="1.5">
            <circle cx="12" cy="12" r="10"/>
            <path d="M8 12l2 2 4-4"/>
            <path d="M16 8l-2 2"/>
          </svg>
        </div>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2 class="cro-price-match__heading">{{ section.settings.heading }}</h2>
      {%- endif -%}
      {%- if section.settings.subheading != blank -%}
        <p class="cro-price-match__subheading">{{ section.settings.subheading }}</p>
      {%- endif -%}
      <div class="cro-price-match__details">
        {%- for i in (1..4) -%}
          {%- capture detail_key -%}detail_{{ i }}{%- endcapture -%}
          {%- assign detail = section.settings[detail_key] -%}
          {%- if detail != blank -%}
            <div class="cro-price-match__detail">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--pm-accent)" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
              <span>{{ detail }}</span>
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
      {%- if section.settings.show_form -%}
        <form class="cro-price-match__form" id="cro-price-match-form-{{ section.id }}">
          <div class="cro-price-match__form-grid">
            <input type="url" class="cro-price-match__input" placeholder="{{ section.settings.url_placeholder }}" aria-label="{{ section.settings.url_placeholder }}" required>
            <input type="number" class="cro-price-match__input" placeholder="{{ section.settings.price_placeholder }}" aria-label="{{ section.settings.price_placeholder }}" min="0" step="0.01" required>
          </div>
          <button type="submit" class="cro-price-match__btn">{{ section.settings.btn_text }}</button>
        </form>
      {%- endif -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "CRO - Price Match",
  "tag": "section",
  "class": "cro-section cro-price-match-section",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "image_picker",
      "id": "icon",
      "label": "Icon image"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Price Match Guarantee"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Found a lower price elsewhere? We'll match it!"
    },
    {
      "type": "text",
      "id": "detail_1",
      "label": "Detail 1",
      "default": "30-day price match window"
    },
    {
      "type": "text",
      "id": "detail_2",
      "label": "Detail 2",
      "default": "Identical product must be in stock"
    },
    {
      "type": "text",
      "id": "detail_3",
      "label": "Detail 3",
      "default": "Includes competitor sale prices"
    },
    {
      "type": "text",
      "id": "detail_4",
      "label": "Detail 4",
      "default": "Refund issued within 24 hours"
    },
    {
      "type": "header",
      "content": "Form"
    },
    {
      "type": "checkbox",
      "id": "show_form",
      "label": "Show submission form",
      "default": true
    },
    {
      "type": "text",
      "id": "url_placeholder",
      "label": "URL placeholder",
      "default": "Paste competitor URL"
    },
    {
      "type": "text",
      "id": "price_placeholder",
      "label": "Price placeholder",
      "default": "Lower price ($)"
    },
    {
      "type": "text",
      "id": "btn_text",
      "label": "Button text",
      "default": "Request Price Match"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background",
      "default": "#f0f8ff"
    },
    {
      "type": "color",
      "id": "card_bg",
      "label": "Card background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text",
      "default": "#1a1a2e"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent",
      "default": "#2ecc71"
    },
    {
      "type": "color",
      "id": "btn_bg",
      "label": "Button background",
      "default": "#2ecc71"
    },
    {
      "type": "color",
      "id": "btn_text_color",
      "label": "Button text color",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top padding",
      "default": 40,
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom padding",
      "default": 40,
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px"
    }
  ],
  "presets": [
    {
      "name": "CRO - Price Match",
      "settings": {
        "heading": "Price Match Guarantee",
        "subheading": "Found a lower price elsewhere? We'll match it!",
        "detail_1": "30-day price match window",
        "detail_2": "Identical product must be in stock",
        "detail_3": "Includes competitor sale prices",
        "detail_4": "Refund issued within 24 hours",
        "show_form": true,
        "url_placeholder": "Paste competitor URL",
        "price_placeholder": "Lower price ($)",
        "btn_text": "Request Price Match",
        "bg_color": "#f0f8ff",
        "card_bg": "#ffffff",
        "text_color": "#1a1a2e",
        "accent_color": "#2ecc71",
        "btn_bg": "#2ecc71",
        "btn_text_color": "#ffffff"
      }
    }
  ]
}
{% endschema %}
