<div class="cro-wcu page-width" style="padding:{{ section.settings.padding_top }}px 16px {{ section.settings.padding_bottom }}px;background:{{ section.settings.bg_color }};">
  {%- if section.settings.heading != blank -%}
    <h2 class="cro-section-title" style="text-align:center;font-size:26px;font-weight:700;margin-bottom:8px;color:{{ section.settings.heading_color }};">{{ section.settings.heading }}</h2>
  {%- endif -%}
  {%- if section.settings.subheading != blank -%}
    <p style="text-align:center;font-size:15px;color:var(--amz-gray,#565959);margin:0 0 32px;max-width:600px;margin-left:auto;margin-right:auto;">{{ section.settings.subheading }}</p>
  {%- endif -%}
  <div class="cro-wcu__grid" style="display:grid;grid-template-columns:repeat({{ section.settings.columns }},1fr);gap:24px;">
    {%- for block in section.blocks -%}
      <div class="cro-wcu__card" style="background:#fff;border-radius:8px;padding:28px 20px;border:1px solid #e7e7e7;text-align:{{ block.settings.align }};transition:box-shadow .2s;" onmouseover="this.style.boxShadow='0 8px 30px rgba(0,0,0,.1)'" onmouseout="this.style.boxShadow='none'">
        <div style="margin-bottom:14px;{% if block.settings.align == 'center' %}text-align:center;{% endif %}">
          {%- if block.settings.icon_image != blank -%}
            <img src="{{ block.settings.icon_image | image_url: width: 80 }}" alt="{{ block.settings.title }}" loading="lazy" style="width:48px;height:48px;object-fit:contain;">
          {%- else -%}
            <div style="width:48px;height:48px;border-radius:8px;background:{{ section.settings.icon_bg }};display:inline-flex;align-items:center;justify-content:center;">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="{{ section.settings.icon_color }}" stroke-width="1.5"><path d="{{ block.settings.icon_path | default: 'M22 11.08V12a10 10 0 1 1-5.93-9.14' }}"/><polyline points="{{ block.settings.icon_polyline | default: '22 4 12 14.01 9 11.01' }}"/></svg>
            </div>
          {%- endif -%}
        </div>
        <h3 style="font-size:17px;font-weight:600;margin:0 0 8px;color:{{ section.settings.text_color }};">{{ block.settings.title }}</h3>
        {%- if block.settings.description != blank -%}
          <p style="font-size:14px;color:var(--amz-gray,#565959);line-height:1.6;margin:0;">{{ block.settings.description }}</p>
        {%- endif -%}
      </div>
    {%- endfor -%}
  </div>
</div>
<style>
@media(max-width:900px){
  .cro-wcu__grid{grid-template-columns:repeat(2,1fr)!important;}
}
@media(max-width:600px){
  .cro-wcu__grid{grid-template-columns:1fr!important;}
}
</style>

{% schema %}
{
  "name": "CRO - Why Choose Us",
  "tag": "section",
  "class": "cro-section cro-wcu-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Why Choose Us"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "We're committed to providing the best experience for our customers."
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading Color",
      "default": "#0f1111"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#0f1111"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "icon_bg",
      "label": "Icon Background",
      "default": "#fef0c7"
    },
    {
      "type": "color",
      "id": "icon_color",
      "label": "Icon Color",
      "default": "#ff9900"
    },
    {
      "type": "range",
      "id": "columns",
      "label": "Columns",
      "min": 1,
      "max": 4,
      "step": 1,
      "default": 3
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding Top",
      "min": 0,
      "max": 80,
      "step": 4,
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding Bottom",
      "min": 0,
      "max": 80,
      "step": 4,
      "default": 40
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature",
      "settings": [
        {
          "type": "image_picker",
          "id": "icon_image",
          "label": "Icon Image"
        },
        {
          "type": "textarea",
          "id": "icon_path",
          "label": "SVG Path (optional)"
        },
        {
          "type": "text",
          "id": "icon_polyline",
          "label": "SVG Polyline (optional)"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Premium Quality"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "We source only the finest materials to ensure durability and customer satisfaction."
        },
        {
          "type": "select",
          "id": "align",
          "label": "Text Alignment",
          "options": [
            { "value": "left", "label": "Left" },
            { "value": "center", "label": "Center" }
          ],
          "default": "center"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "CRO - Why Choose Us",
      "category": "CRO",
      "blocks": [
        { "type": "feature", "settings": { "title": "Premium Quality", "description": "Finest materials for lasting durability." } },
        { "type": "feature", "settings": { "title": "Fast Shipping", "description": "Free delivery on orders over ₹499." } },
        { "type": "feature", "settings": { "title": "24/7 Support", "description": "We're here whenever you need us." } }
      ]
    }
  ]
}
{% endschema %}
