{% comment %} Amazo Promo Strip — v2.0 Block-based with placeholders {% endcomment %}
{%- if section.blocks.size > 0 -%}
<div class="amz-promo-strip" id="amz-promo-strip-{{ section.id }}" style="background:{{ section.settings.bg_color | default: '#232f3e' }};">
  <div class="amz-promo-strip__inner">
    {%- for block in section.blocks -%}
      {%- if block.type == 'message' -%}
        {%- assign _bg = block.settings.bg_color | default: 'transparent' -%}
        {%- assign _color = block.settings.text_color | default: '#ffffff' -%}
        <div class="amz-promo-strip__item" style="background:{{ _bg }};color:{{ _color }};" {{ block.shopify_attributes }}>
          {%- if block.settings.icon_emoji != blank -%}
            <span class="amz-promo-strip__emoji" aria-hidden="true">{{ block.settings.icon_emoji }}</span>
          {%- endif -%}
          <span class="amz-promo-strip__text">
            {{ block.settings.text | default: '🌟 Deal of the Day: Up to 70% off' }}
          </span>
          {%- if block.settings.link_text != blank and block.settings.link != blank -%}
            <a href="{{ block.settings.link }}" class="amz-promo-strip__link" style="color:{{ _color }};">
              {{ block.settings.link_text }} <span aria-hidden="true">›</span>
            </a>
          {%- endif -%}
        </div>
      {%- endif -%}
    {%- endfor -%}
  </div>
</div>

<style>
#amz-promo-strip-{{ section.id }} {
  overflow: hidden;
}
.amz-promo-strip__inner {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  justify-content: center;
}
.amz-promo-strip__item {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  padding: 10px 24px;
  font-size: 14px;
  font-weight: 500;
  text-align: center;
  flex: 1 1 auto;
  min-width: 200px;
  min-height: 44px;
}
.amz-promo-strip__emoji {
  font-size: 16px;
  flex-shrink: 0;
}
.amz-promo-strip__text {
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
.amz-promo-strip__link {
  font-weight: 700;
  text-decoration: none;
  white-space: nowrap;
  flex-shrink: 0;
  padding: 4px 10px;
  border-radius: 4px;
  transition: opacity 0.2s;
}
.amz-promo-strip__link:hover {
  opacity: 0.85;
  text-decoration: underline;
}
@media (max-width: 768px) {
  .amz-promo-strip__inner { flex-direction: column; }
  .amz-promo-strip__item { width: 100%; padding: 8px 16px; font-size: 13px; min-height: 38px; }
}
</style>
{%- endif -%}

{% schema %}
{
  "name": "Amazon Promo Strip",
  "tag": "section",
  "templates": ["index"],
  "max_blocks": 6,
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Strip Background Color",
      "default": "#232f3e"
    }
  ],
  "blocks": [
    {
      "type": "message",
      "name": "Promo Message",
      "settings": [
        {
          "type": "text",
          "id": "icon_emoji",
          "label": "Emoji / Icon",
          "default": "🌟",
          "info": "e.g. 🎉, 🔥, 💥, 🚚. Leave empty to hide."
        },
        {
          "type": "text",
          "id": "text",
          "label": "Promo Text",
          "default": "Deal of the Day: Up to 70% off",
          "placeholder": "Enter promo message..."
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link (optional)"
        },
        {
          "type": "text",
          "id": "link_text",
          "label": "Link Text",
          "default": "Shop Now",
          "placeholder": "e.g. Shop Now"
        },
        {
          "type": "header",
          "content": "Colors (optional)"
        },
        {
          "type": "color",
          "id": "bg_color",
          "label": "Item Background",
          "info": "Leave empty to use section background."
        },
        {
          "type": "color",
          "id": "text_color",
          "label": "Text Color",
          "default": "#ffffff"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Amazon Promo Strip",
      "blocks": [
        {
          "type": "message",
          "settings": {
            "icon_emoji": "🌟",
            "text": "Deal of the Day: Up to 70% off",
            "link": "/collections/sale",
            "link_text": "Shop Now"
          }
        },
        {
          "type": "message",
          "settings": {
            "icon_emoji": "🚚",
            "text": "Free Shipping on orders over $35",
            "link": "/pages/shipping",
            "link_text": "Learn More"
          }
        },
        {
          "type": "message",
          "settings": {
            "icon_emoji": "🔥",
            "text": "Summer Sale — Up to 50% off top brands!",
            "link": "/collections/sale",
            "link_text": "Shop Sale"
          }
        }
      ]
    }
  ]
}
{% endschema %}
