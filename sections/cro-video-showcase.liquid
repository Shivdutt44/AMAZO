<div class="cro-video page-width" style="padding:{{ section.settings.padding_top }}px 16px {{ section.settings.padding_bottom }}px;background:{{ section.settings.bg_color }};">
  {%- if section.settings.heading != blank -%}
    <h2 class="cro-section-title" style="text-align:center;font-size:24px;font-weight:700;margin-bottom:8px;color:{{ section.settings.heading_color }};">{{ section.settings.heading }}</h2>
  {%- endif -%}
  {%- if section.settings.subheading != blank -%}
    <p style="text-align:center;font-size:14px;color:var(--amz-gray,#565959);margin:0 0 28px;">{{ section.settings.subheading }}</p>
  {%- endif -%}
  <div style="display:grid;grid-template-columns:repeat({{ section.settings.columns }},1fr);gap:20px;">
    {%- for block in section.blocks -%}
      <div style="aspect-ratio:16/9;border-radius:8px;overflow:hidden;background:#000;position:relative;">
        {%- if block.settings.video_url != blank -%}
          <iframe src="{{ block.settings.video_url }}" title="{{ block.settings.title }}" frameborder="0" allow="accelerometer;autoplay;clipboard-write;encrypted-media;gyroscope;picture-in-picture" allowfullscreen style="width:100%;height:100%;"></iframe>
        {%- elsif block.settings.cover_image != blank -%}
          <img src="{{ block.settings.cover_image | image_url: width: 600 }}" alt="{{ block.settings.title }}" loading="lazy" style="width:100%;height:100%;object-fit:cover;display:block;">
          <div style="position:absolute;inset:0;display:flex;align-items:center;justify-content:center;background:rgba(0,0,0,0.3);"><svg width="48" height="48" viewBox="0 0 24 24" fill="#fff"><polygon points="5 3 19 12 5 21 5 3"/></svg></div>
        {%- else -%}
          <div style="width:100%;height:100%;display:flex;align-items:center;justify-content:center;background:#f7f7f7;color:#ccc;font-size:13px;">Video Placeholder</div>
        {%- endif -%}
      </div>
    {%- endfor -%}
  </div>
</div>
<style>
@media(max-width:768px){
  .cro-video>div:last-child{grid-template-columns:1fr!important;}
}
</style>

{% schema %}
{
  "name": "CRO - Video Showcase",
  "tag": "section",
  "class": "cro-section cro-video-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "See It In Action"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Watch product demos and customer reviews"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading Color",
      "default": "#0f1111"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "columns",
      "label": "Columns",
      "min": 1,
      "max": 3,
      "step": 1,
      "default": 2
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding Top",
      "min": 0,
      "max": 80,
      "step": 4,
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding Bottom",
      "min": 0,
      "max": 80,
      "step": 4,
      "default": 40
    }
  ],
  "blocks": [
    {
      "type": "video",
      "name": "Video",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Product Video"
        },
        {
          "type": "textarea",
          "id": "video_url",
          "label": "Embed URL",
          "default": "https://www.youtube.com/embed/example",
          "info": "Full iframe embed URL from YouTube/Vimeo"
        },
        {
          "type": "image_picker",
          "id": "cover_image",
          "label": "Cover Image (fallback)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "CRO - Video Showcase",
      "category": "CRO",
      "blocks": [
        { "type": "video", "settings": { "title": "Product Demo" } },
        { "type": "video", "settings": { "title": "Customer Review" } }
      ]
    }
  ]
}
{% endschema %}
