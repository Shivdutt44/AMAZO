<div class="cro-bundle page-width" style="padding:{{ section.settings.padding_top }}px 16px {{ section.settings.padding_bottom }}px;background:{{ section.settings.bg_color }};">
  {%- if section.settings.heading != blank -%}
    <h2 class="cro-section-title" style="font-size:20px;font-weight:700;margin-bottom:20px;color:{{ section.settings.heading_color }};">{{ section.settings.heading }}</h2>
  {%- endif -%}
  <div class="cro-bundle__inner" style="display:flex;align-items:center;gap:16px;flex-wrap:wrap;background:#fff;border:1px solid #e7e7e7;border-radius:8px;padding:24px;">
    <div style="display:flex;align-items:center;gap:8px;flex:1;min-width:200px;flex-wrap:wrap;">
      {%- for block in section.blocks -%}
        <div class="cro-bundle__product" style="text-align:center;max-width:120px;">
          {%- if block.settings.image != blank -%}
            <img src="{{ block.settings.image | image_url: width: 120 }}" alt="{{ block.settings.title }}" loading="lazy" style="width:80px;height:80px;object-fit:contain;border:1px solid #e7e7e7;border-radius:4px;display:block;margin:0 auto 6px;">
          {%- else -%}
            <div style="width:80px;height:80px;border:1px dashed #ddd;border-radius:4px;display:flex;align-items:center;justify-content:center;font-size:11px;color:#ccc;margin:0 auto 6px;">No Image</div>
          {%- endif -%}
          <div style="font-size:12px;color:var(--amz-text,#0f1111);font-weight:500;line-height:1.3;">{{ block.settings.title }}</div>
          {%- if block.settings.price != blank -%}
            <div style="font-size:12px;color:var(--amz-gray,#565959);margin-top:2px;">{{ block.settings.price }}</div>
          {%- endif -%}
        </div>
        {%- unless forloop.last -%}
          <div style="font-size:20px;color:var(--amz-gray,#565959);align-self:center;">+</div>
        {%- endunless -%}
      {%- endfor -%}
    </div>
    <div style="text-align:center;min-width:150px;border-left:1px solid #e7e7e7;padding-left:20px;">
      <div style="font-size:13px;color:var(--amz-gray,#565959);margin-bottom:6px;">Total Price</div>
      <div style="font-size:22px;font-weight:700;color:{{ section.settings.price_color }};margin-bottom:12px;">{{ section.settings.total_price }}</div>
      {%- if section.settings.saving_text != blank -%}
        <div style="font-size:12px;color:#cc0c39;font-weight:600;margin-bottom:10px;">{{ section.settings.saving_text }}</div>
      {%- endif -%}
      {%- if section.settings.button_text != blank -%}
        <button type="button" class="cro-bundle__btn" style="padding:10px 20px;background:{{ section.settings.btn_bg }};color:{{ section.settings.btn_text }};border:none;border-radius:var(--btn-radius,3px);font-size:13px;font-weight:600;cursor:pointer;width:100%;transition:opacity .2s;" onmouseover="this.style.opacity='0.9'" onmouseout="this.style.opacity='1'">{{ section.settings.button_text }}</button>
      {%- endif -%}
    </div>
  </div>
</div>
<style>
@media(max-width:600px){
  .cro-bundle__inner{flex-direction:column;padding:16px!important;}
  .cro-bundle__inner>div:last-child{border-left:none!important;padding-left:0!important;padding-top:16px;border-top:1px solid #e7e7e7;width:100%;}
}
</style>

{% schema %}
{
  "name": "CRO - Bundle Deals",
  "tag": "section",
  "class": "cro-section cro-bundle-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "✨ Frequently Bought Together"
    },
    {
      "type": "text",
      "id": "total_price",
      "label": "Total Price",
      "default": "₹799"
    },
    {
      "type": "text",
      "id": "saving_text",
      "label": "Saving Text",
      "default": "Save ₹200 with this bundle!"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading Color",
      "default": "#0f1111"
    },
    {
      "type": "color",
      "id": "price_color",
      "label": "Price Color",
      "default": "#b12704"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Section Background",
      "default": "#eaeded"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "Add Bundle to Cart"
    },
    {
      "type": "color",
      "id": "btn_bg",
      "label": "Button Background",
      "default": "#ffd814"
    },
    {
      "type": "color",
      "id": "btn_text",
      "label": "Button Text Color",
      "default": "#0f1111"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding Top",
      "min": 0,
      "max": 80,
      "step": 4,
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding Bottom",
      "min": 0,
      "max": 80,
      "step": 4,
      "default": 40
    }
  ],
  "blocks": [
    {
      "type": "product",
      "name": "Bundle Product",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Product Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Product Title",
          "default": "Product Name"
        },
        {
          "type": "text",
          "id": "price",
          "label": "Price",
          "default": "₹499"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "CRO - Bundle Deals",
      "category": "CRO",
      "blocks": [
        { "type": "product", "settings": { "title": "Main Product", "price": "₹499" } },
        { "type": "product", "settings": { "title": "Accessory 1", "price": "₹199" } },
        { "type": "product", "settings": { "title": "Accessory 2", "price": "₹299" } }
      ]
    }
  ]
}
{% endschema %}
