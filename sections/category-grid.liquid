          {%- else -%}
            <div class="amz-cats__4grid-item"><div class="amz-cats__4grid-placeholder" style="background: #d32f2f;"></div><p>Fiction</p></div>
            <div class="amz-cats__4grid-item"><div class="amz-cats__4grid-placeholder" style="background: #1565c0;"></div><p>Non-Fiction</p></div>
