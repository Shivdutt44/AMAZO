{% comment %} Amazon Category Grid - 4x2 Grid Layout exactly like Amazon.com homepage cards {% endcomment %}

<div class="amz-cats" id="amz-cats">
  <div class="amz-cats__grid">

    {%- for block in section.blocks -%}
      {%- if block.type == 'category' -%}
        <div class="amz-cats__card" {{ block.shopify_attributes }}>
          <div class="amz-cats__card-inner">
            <h2 class="amz-cats__title">{{ block.settings.title }}</h2>
            <div class="amz-cats__img-wrap">
              {%- if block.settings.image != blank -%}
                <img
                  src="{{ block.settings.image | image_url: width: 370 }}"
                  alt="{{ block.settings.title | escape }}"
                  class="amz-cats__img"
                  loading="lazy"
                  width="370" height="280"
                >
              {%- else -%}
                <div class="amz-cats__img-placeholder" style="background: {{ block.settings.bg_color | default: '#f3f3f3' }};overflow:hidden;">
                  {{ 'collection-' | append: forloop.index | modulo: 6 | plus: 1 | placeholder_svg_tag: 'amz-cats__img amz-placeholder-svg' }}
                </div>
              {%- endif -%}
            </div>
            <a href="{{ block.settings.link | default: '#' }}" class="amz-cats__link">
              {{ block.settings.link_text | default: 'See more' }}
            </a>
          </div>
        </div>
      {%- endif -%}
    {%- else -%}

    <!-- DEFAULT CATEGORY CARDS - Exact Amazon style -->

    <!-- Card 1: Top Deals -->
    <div class="amz-cats__card">
      <div class="amz-cats__card-inner">
        <h2 class="amz-cats__title">Top deals</h2>
        <div class="amz-cats__4grid">
          {%- assign deal_collections = collections | slice: 0, 4 -%}
          {%- for col in deal_collections -%}
            <div class="amz-cats__4grid-item">
              {%- if col.image != blank -%}
                <img src="{{ col.image | image_url: width: 160 }}" alt="{{ col.title | escape }}" loading="lazy" width="160" height="160">
              {%- else -%}
                {%- assign fp = col.products.first -%}
                {%- if fp != blank and fp.featured_image != blank -%}
                  <img src="{{ fp.featured_image | image_url: width: 160 }}" alt="{{ fp.title | escape }}" loading="lazy" width="160" height="160">
                {%- else -%}
                  {{ 'collection-' | append: forloop.index | placeholder_svg_tag: 'amz-cats__4grid-placeholder amz-placeholder-svg' }}
                {%- endif -%}
              {%- endif -%}
              <p>{{ col.title | truncate: 20 }}</p>
            </div>
          {%- else -%}
            <div class="amz-cats__4grid-item">{{ 'product-1' | placeholder_svg_tag: 'amz-cats__4grid-placeholder amz-placeholder-svg' }}<p>Electronics</p></div>
            <div class="amz-cats__4grid-item">{{ 'product-2' | placeholder_svg_tag: 'amz-cats__4grid-placeholder amz-placeholder-svg' }}<p>Fashion</p></div>
            <div class="amz-cats__4grid-item">{{ 'product-3' | placeholder_svg_tag: 'amz-cats__4grid-placeholder amz-placeholder-svg' }}<p>Home</p></div>
            <div class="amz-cats__4grid-item">{{ 'product-4' | placeholder_svg_tag: 'amz-cats__4grid-placeholder amz-placeholder-svg' }}<p>Toys</p></div>
          {%- endfor -%}
        </div>
        <a href="/collections/all" class="amz-cats__link">See all deals</a>
      </div>
    </div>

    <!-- Card 2: New in Electronics -->
    <div class="amz-cats__card">
      <div class="amz-cats__card-inner">
        <h2 class="amz-cats__title">New in Electronics</h2>
        <div class="amz-cats__4grid">
          {%- assign elec_products = collections['electronics'].products | default: collections.all.products -%}
          {%- for prod in elec_products limit: 4 -%}
            <div class="amz-cats__4grid-item">
              {%- if prod.featured_image != blank -%}
                <img src="{{ prod.featured_image | image_url: width: 160 }}" alt="{{ prod.title | escape }}" loading="lazy" width="160" height="160">
              {%- else -%}
                {{ 'product-' | append: forloop.index | placeholder_svg_tag: 'amz-cats__4grid-placeholder amz-placeholder-svg' }}
              {%- endif -%}

              <!-- Wishlist mini button -->
              {%- if settings.enable_wishlist -%}
              <button class="amz-wishlist-btn amz-cat-wish-btn"
                 aria-label="Save to wishlist"
                 data-product-id="{{ prod.id }}"
                 data-product-title="{{ prod.title | escape }}"
                 data-product-url="{{ prod.url }}"
                 data-product-image="{{ prod.featured_image | image_url: width: 150 }}"
                 data-product-price="{{ prod.price }}"
                 data-variant-id="{{ prod.selected_or_first_available_variant.id }}">
                 <svg class="amz-heart-icon" viewBox="0 0 24 24" width="10" height="10">
                   <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
                 </svg>
              </button>
              {%- endif -%}
              <p>{{ prod.title | truncate: 18 }}</p>
            </div>
          {%- else -%}
            <div class="amz-cats__4grid-item">{{ 'product-1' | placeholder_svg_tag: 'amz-cats__4grid-placeholder amz-placeholder-svg' }}<p>Laptops</p></div>
            <div class="amz-cats__4grid-item">{{ 'product-2' | placeholder_svg_tag: 'amz-cats__4grid-placeholder amz-placeholder-svg' }}<p>Phones</p></div>
            <div class="amz-cats__4grid-item">{{ 'product-3' | placeholder_svg_tag: 'amz-cats__4grid-placeholder amz-placeholder-svg' }}<p>Tablets</p></div>
            <div class="amz-cats__4grid-item">{{ 'product-4' | placeholder_svg_tag: 'amz-cats__4grid-placeholder amz-placeholder-svg' }}<p>Cameras</p></div>
          {%- endfor -%}
        </div>
        <a href="/collections/electronics" class="amz-cats__link">Explore Electronics</a>
      </div>
    </div>

