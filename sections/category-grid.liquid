{% comment %} Amazon Category Grid - 4x2 Grid Layout exactly like Amazon.com homepage cards {% endcomment %}

<div class="amz-cats" id="amz-cats">
  <div class="amz-cats__grid">

    {%- for block in section.blocks -%}
      {%- if block.type == 'category' -%}
        <div class="amz-cats__card" {{ block.shopify_attributes }}>
          <div class="amz-cats__card-inner">
            <h2 class="amz-cats__title">{{ block.settings.title }}</h2>
            <div class="amz-cats__img-wrap">
              {%- if block.settings.image != blank -%}
                <img 
                  src="{{ block.settings.image | img_url: '370x280', crop: 'center' }}" 
                  alt="{{ block.settings.title | escape }}"
                  class="amz-cats__img"
                  loading="lazy"
                >
              {%- else -%}
                <div class="amz-cats__img-placeholder" style="background: {{ block.settings.bg_color | default: '#f3f3f3' }};">
                  <div class="amz-cats__placeholder-grid">
                    {%- for i in (1..4) -%}
                      <div class="amz-cats__placeholder-item" style="background: {{ block.settings.accent_color | default: '#e0e0e0' }};"></div>
                    {%- endfor -%}
                  </div>
                </div>
              {%- endif -%}
            </div>
            <a href="{{ block.settings.link | default: '#' }}" class="amz-cats__link">
              {{ block.settings.link_text | default: 'See more' }}
            </a>
          </div>
        </div>
      {%- endif -%}
    {%- else -%}

    <!-- DEFAULT CATEGORY CARDS - Exact Amazon style -->

    <!-- Card 1: Top Deals -->
    <div class="amz-cats__card">
      <div class="amz-cats__card-inner">
        <h2 class="amz-cats__title">Top deals</h2>
        <div class="amz-cats__4grid">
          {%- assign deal_collections = collections | slice: 0, 4 -%}
          {%- for col in deal_collections -%}
            <div class="amz-cats__4grid-item">
              {%- if col.image -%}
                <img src="{{ col.image | img_url: '160x160', crop: 'center' }}" alt="{{ col.title }}" loading="lazy">
              {%- else -%}
                {%- assign fp = col.products.first -%}
                {%- if fp -%}
                  <img src="{{ fp.featured_image | img_url: '160x160', crop: 'center' }}" alt="{{ fp.title }}" loading="lazy">
                {%- else -%}
                  <div class="amz-cats__4grid-placeholder" style="background: #e0e0e0;"></div>
                {%- endif -%}
              {%- endif -%}
              <p>{{ col.title | truncate: 20 }}</p>
            </div>
          {%- else -%}
            <div class="amz-cats__4grid-item"><div class="amz-cats__4grid-placeholder" style="background: #ffb347;"></div><p>Electronics</p></div>
            <div class="amz-cats__4grid-item"><div class="amz-cats__4grid-placeholder" style="background: #87ceeb;"></div><p>Fashion</p></div>
            <div class="amz-cats__4grid-item"><div class="amz-cats__4grid-placeholder" style="background: #90ee90;"></div><p>Home</p></div>
            <div class="amz-cats__4grid-item"><div class="amz-cats__4grid-placeholder" style="background: #dda0dd;"></div><p>Toys</p></div>
          {%- endfor -%}
        </div>
        <a href="/collections/all" class="amz-cats__link">See all deals</a>
      </div>
    </div>

    <!-- Card 2: New in Electronics -->
    <div class="amz-cats__card">
      <div class="amz-cats__card-inner">
        <h2 class="amz-cats__title">New in Electronics</h2>
        <div class="amz-cats__4grid">
          {%- assign elec_products = collections['electronics'].products | default: collections.all.products -%}
          {%- for prod in elec_products limit: 4 -%}
            <div class="amz-cats__4grid-item">
              <img src="{{ prod.featured_image | img_url: '160x160', crop: 'center' }}" alt="{{ prod.title }}" loading="lazy">
              <p>{{ prod.title | truncate: 18 }}</p>
            </div>
          {%- else -%}
            <div class="amz-cats__4grid-item"><div class="amz-cats__4grid-placeholder" style="background: #333;"></div><p>Laptops</p></div>
            <div class="amz-cats__4grid-item"><div class="amz-cats__4grid-placeholder" style="background: #555;"></div><p>Phones</p></div>
            <div class="amz-cats__4grid-item"><div class="amz-cats__4grid-placeholder" style="background: #777;"></div><p>Tablets</p></div>
            <div class="amz-cats__4grid-item"><div class="amz-cats__4grid-placeholder" style="background: #999;"></div><p>Cameras</p></div>
          {%- endfor -%}
        </div>
        <a href="/collections/electronics" class="amz-cats__link">Explore Electronics</a>
      </div>
    </div>

    <!-- Card 3: Fashion & Clothing -->
    <div class="amz-cats__card">
      <div class="amz-cats__card-inner">
        <h2 class="amz-cats__title">Fashion & Clothing</h2>
        <div class="amz-cats__4grid">
          {%- assign fashion_products = collections['clothing'].products | default: collections.all.products -%}
          {%- for prod in fashion_products limit: 4 -%}
            <div class="amz-cats__4grid-item">
              <img src="{{ prod.featured_image | img_url: '160x160', crop: 'center' }}" alt="{{ prod.title }}" loading="lazy">
              <p>{{ prod.title | truncate: 18 }}</p>
            </div>
          {%- else -%}
            <div class="amz-cats__4grid-item"><div class="amz-cats__4grid-placeholder" style="background: #f8bbd0;"></div><p>Women</p></div>
            <div class="amz-cats__4grid-item"><div class="amz-cats__4grid-placeholder" style="background: #bbdefb;"></div><p>Men</p></div>
            <div class="amz-cats__4grid-item"><div class="amz-cats__4grid-placeholder" style="background: #c8e6c9;"></div><p>Kids</p></div>
            <div class="amz-cats__4grid-item"><div class="amz-cats__4grid-placeholder" style="background: #fff9c4;"></div><p>Shoes</p></div>
          {%- endfor -%}
        </div>
        <a href="/collections/clothing" class="amz-cats__link">Shop Fashion</a>
      </div>
    </div>

    <!-- Card 4: Home & Kitchen -->
    <div class="amz-cats__card">
      <div class="amz-cats__card-inner">
