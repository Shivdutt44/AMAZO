<style>
.amz-cats__4grid-item { position: relative; }
.amz-cat-wish-btn {
  position: absolute; top: 2px; right: 2px; background: rgba(255,255,255,0.9); border: 1px solid #ddd;
  border-radius: 50%; width: 20px; height: 20px; display: flex; align-items: center; justify-content: center;
  cursor: pointer; z-index: 5; opacity: 0; transition: opacity 0.2s; padding: 0;
}
.amz-cats__4grid-item:hover .amz-cat-wish-btn { opacity: 1; }
.amz-cat-wish-btn .amz-heart-icon { stroke: #565959; fill: none; }
.amz-cat-wish-btn.is-wishlisted .amz-heart-icon { stroke: #cc0c39; fill: #cc0c39; }
@media (max-width: 768px) { .amz-cat-wish-btn { opacity: 1; } }
</style>

{% schema %}
{
  "name": "Amazon Category Grid",
  "max_blocks": 12,
  "settings": [],
  "blocks": [
    {
      "type": "category",
      "name": "Category Card",
      "settings": [
        { "type": "text", "id": "title", "label": "Category Title", "default": "Shop by Category" },
        { "type": "image_picker", "id": "image", "label": "Category Image" },
        { "type": "color", "id": "bg_color", "label": "Background Color", "default": "#f3f3f3" },
        { "type": "color", "id": "accent_color", "label": "Accent Color", "default": "#e0e0e0" },
        { "type": "url", "id": "link", "label": "Category Link" },
        { "type": "text", "id": "link_text", "label": "Link Text", "default": "See more" }
      ]
    }
  ],
  "presets": [{ "name": "Amazon Category Grid" }]
}
{% endschema %}
