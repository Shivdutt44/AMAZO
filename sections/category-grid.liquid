    <!-- Card 7: Beauty -->
    <div class="amz-cats__card">
      <div class="amz-cats__card-inner">
        <h2 class="amz-cats__title">Beauty & Personal Care</h2>
        <div class="amz-cats__4grid">
          {%- for prod in collections.all.products limit: 4 offset: 16 -%}
            <div class="amz-cats__4grid-item">
              <img src="{{ prod.featured_image | img_url: '160x160', crop: 'center' }}" alt="{{ prod.title }}" loading="lazy">
              <p>{{ prod.title | truncate: 18 }}</p>
            </div>
          {%- else -%}
            <div class="amz-cats__4grid-item"><div class="amz-cats__4grid-placeholder" style="background: #f48fb1;"></div><p>Makeup</p></div>
            <div class="amz-cats__4grid-item"><div class="amz-cats__4grid-placeholder" style="background: #e91e63;"></div><p>Skin Care</p></div>
            <div class="amz-cats__4grid-item"><div class="amz-cats__4grid-placeholder" style="background: #9c27b0;"></div><p>Hair Care</p></div>
            <div class="amz-cats__4grid-item"><div class="amz-cats__4grid-placeholder" style="background: #7b1fa2;"></div><p>Fragrance</p></div>
