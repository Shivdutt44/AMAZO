          {%- else -%}
            <div class="amz-cats__4grid-item"><div class="amz-cats__4grid-placeholder" style="background: #ffe0b2;"></div><p>Furniture</p></div>
            <div class="amz-cats__4grid-item"><div class="amz-cats__4grid-placeholder" style="background: #f3e5f5;"></div><p>Kitchen</p></div>
            <div class="amz-cats__4grid-item"><div class="amz-cats__4grid-placeholder" style="background: #e0f7fa;"></div><p>Bedding</p></div>
            <div class="amz-cats__4grid-item"><div class="amz-cats__4grid-placeholder" style="background: #fce4ec;"></div><p>Bath</p></div>
          {%- endfor -%}
