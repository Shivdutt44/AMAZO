      <div class="amz-cats__card-inner">
        <h2 class="amz-cats__title">Sports & Outdoors</h2>
        <div class="amz-cats__4grid">
          {%- for prod in collections.all.products limit: 4 offset: 12 -%}
            <div class="amz-cats__4grid-item">
              <img src="{{ prod.featured_image | img_url: '160x160', crop: 'center' }}" alt="{{ prod.title }}" loading="lazy">
              <p>{{ prod.title | truncate: 18 }}</p>
            </div>
          {%- else -%}
            <div class="amz-cats__4grid-item"><div class="amz-cats__4grid-placeholder" style="background: #43a047;"></div><p>Exercise</p></div>
            <div class="amz-cats__4grid-item"><div class="amz-cats__4grid-placeholder" style="background: #00897b;"></div><p>Outdoor</p></div>
            <div class="amz-cats__4grid-item"><div class="amz-cats__4grid-placeholder" style="background: #0288d1;"></div><p>Team Sports</p></div>
            <div class="amz-cats__4grid-item"><div class="amz-cats__4grid-placeholder" style="background: #f57f17;"></div><p>Golf</p></div>
          {%- endfor -%}
