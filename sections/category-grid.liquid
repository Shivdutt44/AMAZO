    <!-- Card 8: Toys & Games -->
    <div class="amz-cats__card">
      <div class="amz-cats__card-inner">
        <h2 class="amz-cats__title">Toys & Games</h2>
        <div class="amz-cats__4grid">
          {%- for prod in collections.all.products limit: 4 offset: 20 -%}
            <div class="amz-cats__4grid-item">
              <img src="{{ prod.featured_image | img_url: '160x160', crop: 'center' }}" alt="{{ prod.title }}" loading="lazy">
              <p>{{ prod.title | truncate: 18 }}</p>
            </div>
          {%- else -%}
            <div class="amz-cats__4grid-item"><div class="amz-cats__4grid-placeholder" style="background: #ffcc02;"></div><p>Action Figures</p></div>
            <div class="amz-cats__4grid-item"><div class="amz-cats__4grid-placeholder" style="background: #ff5722;"></div><p>Board Games</p></div>
            <div class="amz-cats__4grid-item"><div class="amz-cats__4grid-placeholder" style="background: #4caf50;"></div><p>Dolls</p></div>
            <div class="amz-cats__4grid-item"><div class="amz-cats__4grid-placeholder" style="background: #2196f3;"></div><p>Building Sets</p></div>
          {%- endfor -%}
        </div>
        <a href="/collections/toys" class="amz-cats__link">Shop Toys</a>
      </div>
    </div>

    {%- endfor -%}
  </div>
</div>

{% schema %}
{
  "name": "Amazon Category Grid",
  "max_blocks": 12,
  "settings": [],
  "blocks": [
    {
      "type": "category",
      "name": "Category Card",
      "settings": [
        { "type": "text", "id": "title", "label": "Category Title", "default": "Shop by Category" },
        { "type": "image_picker", "id": "image", "label": "Category Image" },
        { "type": "color", "id": "bg_color", "label": "Background Color", "default": "#f3f3f3" },
        { "type": "color", "id": "accent_color", "label": "Accent Color", "default": "#e0e0e0" },
        { "type": "url", "id": "link", "label": "Category Link" },
        { "type": "text", "id": "link_text", "label": "Link Text", "default": "See more" }
      ]
    }
  ],
  "presets": [{ "name": "Amazon Category Grid" }]
}
{% endschema %}
