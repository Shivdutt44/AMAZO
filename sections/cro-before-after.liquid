<div class="cro-beforeafter page-width" style="padding:{{ section.settings.padding_top }}px 16px {{ section.settings.padding_bottom }}px;background:{{ section.settings.bg_color }};">
  {%- if section.settings.heading != blank -%}
    <h2 class="cro-section-title" style="text-align:center;font-size:24px;font-weight:700;margin-bottom:8px;color:{{ section.settings.heading_color }};">{{ section.settings.heading }}</h2>
  {%- endif -%}
  {%- if section.settings.subheading != blank -%}
    <p style="text-align:center;font-size:14px;color:var(--amz-gray,#565959);margin:0 0 28px;">{{ section.settings.subheading }}</p>
  {%- endif -%}
  <div style="display:grid;grid-template-columns:repeat({{ section.settings.columns }},1fr);gap:24px;">
    {%- for block in section.blocks -%}
      <div class="cro-ba__container" style="position:relative;width:100%;aspect-ratio:1/1;overflow:hidden;border-radius:8px;border:1px solid #e7e7e7;cursor:ew-resize;user-select:none;">
        {%- if block.settings.after_image != blank -%}
          <img src="{{ block.settings.after_image | image_url: width: 600 }}" alt="After" loading="lazy" style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;display:block;">
        {%- else -%}
          <div style="position:absolute;inset:0;display:flex;align-items:center;justify-content:center;background:#f7f7f7;color:#ccc;font-size:13px;">After</div>
        {%- endif -%}
        {%- if block.settings.before_image != blank -%}
          <div class="cro-ba__before" style="position:absolute;top:0;left:0;height:100%;width:50%;overflow:hidden;z-index:2;">
            <img src="{{ block.settings.before_image | image_url: width: 600 }}" alt="Before" style="display:block;width:100%;height:100%;object-fit:cover;max-width:none;position:absolute;left:0;top:0;">
          </div>
        {%- endif -%}
        <div class="cro-ba__handle" style="position:absolute;top:0;bottom:0;left:50%;width:3px;background:#fff;z-index:3;transform:translateX(-50%);box-shadow:0 0 6px rgba(0,0,0,0.3);">
          <div style="position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);width:32px;height:32px;border-radius:50%;background:#fff;box-shadow:0 2px 8px rgba(0,0,0,0.3);display:flex;align-items:center;justify-content:center;">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#333" stroke-width="2"><polyline points="15 18 9 12 15 6"/></svg>
          </div>
        </div>
        <span style="position:absolute;bottom:8px;left:8px;background:rgba(0,0,0,0.6);color:#fff;font-size:11px;padding:2px 8px;border-radius:3px;z-index:3;">Before</span>
        <span style="position:absolute;bottom:8px;right:8px;background:rgba(0,0,0,0.6);color:#fff;font-size:11px;padding:2px 8px;border-radius:3px;z-index:3;">After</span>
      </div>
    {%- endfor -%}
  </div>
</div>
<style>
@media(max-width:768px){
  .cro-beforeafter>div:last-child{grid-template-columns:1fr!important;}
}
</style>
<script>
document.addEventListener('DOMContentLoaded',function(){
  document.querySelectorAll('.cro-ba__container').forEach(function(container){
    var before=container.querySelector('.cro-ba__before');
    var handle=container.querySelector('.cro-ba__handle');
    if(!before||!handle)return;
    function move(x){
      var rect=container.getBoundingClientRect();
      var pct=Math.max(5,Math.min(95,((x-rect.left)/rect.width)*100));
      before.style.width=pct+'%';
      handle.style.left=pct+'%';
    }
    container.addEventListener('mousedown',function(e){
      e.preventDefault();
      move(e.clientX);
      function onMove(e){move(e.clientX);}
      function onUp(){document.removeEventListener('mousemove',onMove);document.removeEventListener('mouseup',onUp);}
      document.addEventListener('mousemove',onMove);
      document.addEventListener('mouseup',onUp);
    });
    container.addEventListener('touchstart',function(e){
      move(e.touches[0].clientX);
      function onMove(e){e.preventDefault();move(e.touches[0].clientX);}
      function onUp(){document.removeEventListener('touchmove',onMove);document.removeEventListener('touchend',onUp);}
      document.addEventListener('touchmove',onMove,{passive:false});
      document.addEventListener('touchend',onUp);
    });
  });
});
</script>

{% schema %}
{
  "name": "CRO - Before/After Slider",
  "tag": "section",
  "class": "cro-section cro-ba-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "See The Transformation"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Drag slider to compare before and after"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading Color",
      "default": "#0f1111"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#eaeded"
    },
    {
      "type": "range",
      "id": "columns",
      "label": "Columns",
      "min": 1,
      "max": 3,
      "step": 1,
      "default": 1
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding Top",
      "min": 0,
      "max": 80,
      "step": 4,
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding Bottom",
      "min": 0,
      "max": 80,
      "step": 4,
      "default": 40
    }
  ],
  "blocks": [
    {
      "type": "comparison",
      "name": "Comparison Image",
      "settings": [
        {
          "type": "image_picker",
          "id": "before_image",
          "label": "Before Image"
        },
        {
          "type": "image_picker",
          "id": "after_image",
          "label": "After Image"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "CRO - Before/After Slider",
      "category": "CRO",
      "blocks": [
        { "type": "comparison", "settings": {} }
      ]
    }
  ]
}
{% endschema %}
