<div class="collection-banner">
  <div class="collection-banner__inner">
    {%- render 'breadcrumb' -%}
    <h1 class="collection-banner__title">
      {%- if search.performed and search.results_count > 0 -%}
        {{ search.results_count }} results for &ldquo;{{ search.terms | escape }}&rdquo;
      {%- elsif search.performed -%}
        No results for &ldquo;{{ search.terms | escape }}&rdquo;
      {%- else -%}
        Search
      {%- endif -%}
    </h1>
  </div>
</div>

<div style="background:#fff; padding:20px 0; min-height:60vh;">
  <div class="page-width" style="max-width:1500px;">

    <form action="{{ routes.search_url }}" method="get" style="display:flex; margin-bottom:28px; max-width:700px; box-shadow:0 1px 4px rgba(0,0,0,0.1); border-radius:4px; overflow:hidden;" role="search">
      <input type="hidden" name="type" value="product">
      <input type="search" name="q" value="{{ search.terms | escape }}" placeholder="{{ section.settings.placeholder }}"
        style="flex:1; padding:12px 16px; border:1px solid var(--amz-orange); border-right:none; border-radius:4px 0 0 4px; font-size:15px; outline:none; color:var(--amz-text);"
        aria-label="Search products" autofocus>
      <button type="submit"
        style="background:var(--amz-orange); border:1px solid var(--amz-orange); border-left:none; padding:0 20px; border-radius:0 4px 4px 0; cursor:pointer; display:flex; align-items:center;"
        aria-label="Search">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="#000" aria-hidden="true"><path d="M15.5 14h-.79l-.28-.27A6.471 6.471 0 0 0 16 9.5 6.5 6.5 0 1 0 9.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z"/></svg>
      </button>
    </form>

    {%- if search.performed -%}
      {%- if search.results_count > 0 -%}
        <div class="products-grid" style="--products-per-row: 4;">
          {%- for item in search.results -%}
            {%- if item.object_type == 'product' -%}
              {%- render 'product-card', product: item -%}
            {%- endif -%}
          {%- endfor -%}
        </div>
      {%- else -%}
        <div style="text-align:center; padding:60px 20px;">
          <div style="font-size:54px; margin-bottom:20px;">🔍</div>
          <h2 style="font-size:24px; font-weight:700; margin-bottom:10px; color:var(--amz-text);">No results found</h2>
          <p style="font-size:14px; color:var(--amz-gray); margin-bottom:8px;">Try different keywords or check your spelling.</p>
          <a href="/collections/all" style="display:inline-block; background:linear-gradient(to bottom,#f7dfa5,var(--amz-yellow)); border:1px solid #a88734; border-radius:3px; padding:10px 28px; color:var(--amz-text); font-size:14px; font-weight:600; text-decoration:none;">Browse All Products</a>
        </div>
      {%- endif -%}
    {%- else -%}
      <div style="text-align:center; padding:60px 20px; color:var(--amz-gray);">
        <p style="font-size:16px;">Enter a search term above to find products.</p>
      </div>
    {%- endif -%}

  </div>
</div>

{% schema %}
{
  "name": "Search Results",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "placeholder",
      "label": "Search placeholder text",
      "default": "Search for products..."
    }
  ],
  "templates": ["search"],
  "presets": [{ "name": "Search Results" }]
}
{% endschema %}
