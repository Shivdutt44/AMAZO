{% comment %}
  Amazo Theme — About Page Section
  Fully automated, dynamic section with schema and presets
{% endcomment %}

{%- style -%}
  #amz-about-{{ section.id }} .amz-about-hero {
    background: linear-gradient(135deg, {{ section.settings.hero_bg_1 | default: '#131921' }} 0%, {{ section.settings.hero_bg_2 | default: '#232f3e' }} 100%);
    color: #fff;
    text-align: center;
    padding: 60px 20px 50px;
  }
  #amz-about-{{ section.id }} .amz-about-hero h1 {
    font-size: 36px;
    font-weight: 800;
    margin-bottom: 16px;
    color: {{ section.settings.hero_accent_color | default: '#ff9900' }};
  }
  #amz-about-{{ section.id }} .amz-about-hero p {
    font-size: 18px;
    color: #ccc;
    max-width: 600px;
    margin: 0 auto;
    line-height: 1.7;
  }
  #amz-about-{{ section.id }} .amz-about-section {
    padding: 60px 16px;
  }
  #amz-about-{{ section.id }} .amz-about-mission {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 60px;
    align-items: center;
    margin-bottom: 70px;
  }
  #amz-about-{{ section.id }} .amz-about-mission h2 {
    font-size: 28px;
    font-weight: 700;
    color: #0f1111;
    margin-bottom: 16px;
  }
  #amz-about-{{ section.id }} .amz-about-mission p {
    font-size: 15px;
    color: #333;
    line-height: 1.8;
    margin-bottom: 14px;
  }
  #amz-about-{{ section.id }} .amz-about-icon-box {
    background: linear-gradient(135deg, #fff3e0, #ffe0b2);
    border-radius: 16px;
    padding: 40px;
    text-align: center;
  }
  #amz-about-{{ section.id }} .amz-about-icon-box svg {
    width: 80px;
    height: 80px;
  }
  #amz-about-{{ section.id }} .amz-about-icon-box p {
    font-size: 22px;
    font-weight: 700;
    color: #e65c00;
    margin-top: 16px;
  }
  #amz-about-{{ section.id }} .amz-about-stats {
    background: #f8f9fa;
    border-radius: 16px;
    padding: 50px 40px;
    margin-bottom: 70px;
    text-align: center;
  }
  #amz-about-{{ section.id }} .amz-about-stats h2 {
    font-size: 26px;
    font-weight: 700;
    margin-bottom: 40px;
    color: #0f1111;
  }
  #amz-about-{{ section.id }} .amz-about-stats-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 30px;
  }
  #amz-about-{{ section.id }} .amz-about-stat-num {
    font-size: 40px;
    font-weight: 800;
    color: #ff9900;
  }
  #amz-about-{{ section.id }} .amz-about-stat-label {
    font-size: 14px;
    color: #565959;
    margin-top: 6px;
  }
  #amz-about-{{ section.id }} .amz-about-reasons-title {
    font-size: 26px;
    font-weight: 700;
    margin-bottom: 30px;
    text-align: center;
    color: #0f1111;
  }
  #amz-about-{{ section.id }} .amz-about-reasons-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
    margin-bottom: 70px;
  }
  #amz-about-{{ section.id }} .amz-about-reason-card {
    background: #fff;
    border: 1px solid #eee;
    border-radius: 12px;
    padding: 28px 24px;
    text-align: center;
    box-shadow: 0 2px 12px rgba(0,0,0,0.06);
    transition: transform 0.2s;
  }
  #amz-about-{{ section.id }} .amz-about-reason-card:hover {
    transform: translateY(-4px);
  }
  #amz-about-{{ section.id }} .amz-about-reason-icon {
    width: 52px;
    height: 52px;
    background: linear-gradient(135deg, #fff3e0, #ffe0b2);
    border-radius: 50%;
    margin: 0 auto 16px;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  #amz-about-{{ section.id }} .amz-about-reason-card h3 {
    font-size: 15px;
    font-weight: 700;
    color: #0f1111;
    margin-bottom: 8px;
  }
  #amz-about-{{ section.id }} .amz-about-reason-card p {
    font-size: 13px;
    color: #565959;
    line-height: 1.6;
  }
  #amz-about-{{ section.id }} .amz-about-cta {
    background: linear-gradient(135deg, #131921, #232f3e);
    border-radius: 16px;
    padding: 50px;
    text-align: center;
    color: #fff;
  }
  #amz-about-{{ section.id }} .amz-about-cta h2 {
    font-size: 28px;
    font-weight: 700;
    margin-bottom: 12px;
  }
  #amz-about-{{ section.id }} .amz-about-cta p {
    font-size: 16px;
    color: #ccc;
    margin-bottom: 28px;
  }
  #amz-about-{{ section.id }} .amz-about-cta a {
    display: inline-block;
    background: #FFD814;
    color: #0f1111;
    font-weight: 700;
    font-size: 16px;
    padding: 14px 40px;
    border-radius: 8px;
    text-decoration: none;
    transition: background 0.15s;
  }
  #amz-about-{{ section.id }} .amz-about-cta a:hover {
    background: #F7CA00;
  }
  @media (max-width: 768px) {
    #amz-about-{{ section.id }} .amz-about-mission { grid-template-columns: 1fr !important; }
    #amz-about-{{ section.id }} .amz-about-stats-grid { grid-template-columns: repeat(2, 1fr) !important; }
    #amz-about-{{ section.id }} .amz-about-reasons-grid { grid-template-columns: 1fr !important; }
  }
{%- endstyle -%}

<div id="amz-about-{{ section.id }}" class="amz-about-page">
  
  <!-- Hero -->
  <div class="amz-about-hero">
    <div class="page-width">
      <h1>{{ section.settings.hero_heading | default: 'About ' | append: shop.name }}</h1>
      <p>{{ section.settings.hero_text | default: 'We are dedicated to bringing you the best products at unbeatable prices — delivered right to your door.' }}</p>
    </div>
  </div>

  <div class="page-width amz-about-section">

    <!-- Mission -->
    <div class="amz-about-mission">
      <div>
        <h2>{{ section.settings.mission_heading | default: 'Our Mission' }}</h2>
        <p>{{ section.settings.mission_text_1 | default: 'At ' | append: shop.name | append: ', our mission is simple: to be the most customer-centric company in the world. We work every day to earn and keep customer trust by delivering quality products fast, at fair prices, with hassle-free returns.' }}</p>
        <p>{{ section.settings.mission_text_2 | default: 'We believe shopping should be easy, secure, and enjoyable for everyone — whether you are buying for yourself, your family, or your business.' }}</p>
      </div>
      <div class="amz-about-icon-box">
        <svg viewBox="0 0 24 24" fill="none" stroke="#ff9900" stroke-width="1.5" aria-hidden="true">
          <path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/>
          <polyline points="9 22 9 12 15 12 15 22"/>
        </svg>
        <p>{{ section.settings.mission_icon_text | default: 'Customer First, Always' }}</p>
      </div>
    </div>

    <!-- Stats -->
    <div class="amz-about-stats">
      <h2>{{ section.settings.stats_heading | default: 'By the Numbers' }}</h2>
      <div class="amz-about-stats-grid">
        {%- assign stat_items = section.settings.stats | default: '10K+|Products Available,50K+|Happy Customers,4.8★|Average Rating,99%|On-Time Delivery' | split: ',' -%}
        {%- for item in stat_items -%}
          {%- assign parts = item | split: '|' -%}
          <div>
            <div class="amz-about-stat-num">{{ parts[0] }}</div>
            <div class="amz-about-stat-label">{{ parts[1] }}</div>
          </div>
        {%- endfor -%}
      </div>
    </div>

    <!-- Why Choose Us -->
    <h2 class="amz-about-reasons-title">{{ section.settings.reasons_heading | default: 'Why Shop With Us?' }}</h2>
    <div class="amz-about-reasons-grid">
      {%- assign reasons = section.settings.reasons | default: 'Lowest Prices|We price match and offer daily deals to ensure you always get the best value.,Quality Guarantee|Every product is quality-checked before it ships to your door.,Fast Delivery|Free delivery on eligible orders delivered in 3-5 business days.,Easy Returns|30-day hassle-free returns with no questions asked.,Secure Payments|SSL encrypted checkout with all major payment methods accepted.,24/7 Support|Our support team is available 7 days a week to help you.' | split: ',' -%}
      {%- for reason in reasons -%}
        {%- assign parts = reason | split: '|' -%}
        <div class="amz-about-reason-card">
          <div class="amz-about-reason-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#ff9900" stroke-width="2" aria-hidden="true">
              <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
            </svg>
          </div>
          <h3>{{ parts[0] }}</h3>
          <p>{{ parts[1] }}</p>
        </div>
      {%- endfor -%}
    </div>

    <!-- CTA -->
    <div class="amz-about-cta">
      <h2>{{ section.settings.cta_heading | default: 'Ready to Start Shopping?' }}</h2>
      <p>{{ section.settings.cta_text | default: 'Join thousands of happy customers today.' }}</p>
      <a href="{{ section.settings.cta_link | default: '/collections/all' }}">{{ section.settings.cta_button_text | default: 'Shop All Products' }}</a>
    </div>

  </div>
</div>

{% schema %}
{
  "name": "About Page Content",
  "tag": "section",
  "settings": [
    {
      "type": "header",
      "content": "Hero Section"
    },
    {
      "type": "text",
      "id": "hero_heading",
      "label": "Hero Heading",
      "default": "About"
    },
    {
      "type": "textarea",
      "id": "hero_text",
      "label": "Hero Text",
      "default": "We are dedicated to bringing you the best products at unbeatable prices — delivered right to your door."
    },
    {
      "type": "color",
      "id": "hero_bg_1",
      "label": "Hero Gradient Color 1",
      "default": "#131921"
    },
    {
      "type": "color",
      "id": "hero_bg_2",
      "label": "Hero Gradient Color 2",
      "default": "#232f3e"
    },
    {
      "type": "color",
      "id": "hero_accent_color",
      "label": "Hero Accent Color",
      "default": "#ff9900"
    },
    {
      "type": "header",
      "content": "Mission Section"
    },
    {
      "type": "text",
      "id": "mission_heading",
      "label": "Mission Heading",
      "default": "Our Mission"
    },
    {
      "type": "textarea",
      "id": "mission_text_1",
      "label": "Mission Text 1"
    },
    {
      "type": "textarea",
      "id": "mission_text_2",
      "label": "Mission Text 2"
    },
    {
      "type": "text",
      "id": "mission_icon_text",
      "label": "Mission Icon Text",
      "default": "Customer First, Always"
    },
    {
      "type": "header",
      "content": "Stats Section"
    },
    {
      "type": "text",
      "id": "stats_heading",
      "label": "Stats Heading",
      "default": "By the Numbers"
    },
    {
      "type": "textarea",
      "id": "stats",
      "label": "Statistics (comma separated, format: Number|Label)",
      "default": "10K+|Products Available,50K+|Happy Customers,4.8★|Average Rating,99%|On-Time Delivery",
      "info": "Separate each stat with a comma. Use | to separate number from label."
    },
    {
      "type": "header",
      "content": "Reasons Section"
    },
    {
      "type": "text",
      "id": "reasons_heading",
      "label": "Reasons Heading",
      "default": "Why Shop With Us?"
    },
    {
      "type": "textarea",
      "id": "reasons",
      "label": "Reasons (comma separated, format: Title|Description)",
      "default": "Lowest Prices|We price match and offer daily deals to ensure you always get the best value.,Quality Guarantee|Every product is quality-checked before it ships to your door.,Fast Delivery|Free delivery on eligible orders delivered in 3-5 business days.,Easy Returns|30-day hassle-free returns with no questions asked.,Secure Payments|SSL encrypted checkout with all major payment methods accepted.,24/7 Support|Our support team is available 7 days a week to help you."
    },
    {
      "type": "header",
      "content": "CTA Section"
    },
    {
      "type": "text",
      "id": "cta_heading",
      "label": "CTA Heading",
      "default": "Ready to Start Shopping?"
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "CTA Text",
      "default": "Join thousands of happy customers today."
    },
    {
      "type": "text",
      "id": "cta_button_text",
      "label": "CTA Button Text",
      "default": "Shop All Products"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "CTA Link"
    }
  ],
  "presets": [
    {
      "name": "About Page Content",
      "category": "Content"
    }
  ]
}
{% endschema %}