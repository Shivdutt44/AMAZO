[
  {
    "name": "theme_info",
    "theme_name": "Amazo",
    "theme_version": "4.0.0",
    "theme_author": "Amazo Theme",
    "theme_documentation_url": "https://amazo-theme.com",
    "theme_support_url": "https://amazo-theme.com/support"
  },
  {
    "name": "🛒 Wishlist & Quick View",
    "settings": [
      {
        "type": "header",
        "content": "Wishlist Settings"
      },
      {
        "type": "checkbox",
        "id": "enable_wishlist",
        "label": "Enable Wishlist Button",
        "default": true,
        "info": "Shows heart/save button on all product cards and product pages"
      },
      {
        "type": "header",
        "content": "Quick View Settings"
      },
      {
        "type": "checkbox",
        "id": "enable_quick_view",
        "label": "Enable Quick View",
        "default": true,
        "info": "Shows Quick View popup on product card hover"
      }
    ]
  },
  {
    "name": "🛍 Cart & Checkout Buttons",
    "settings": [
      {
        "type": "header",
        "content": "Add to Cart Button"
      },
      {
        "type": "checkbox",
        "id": "enable_add_to_cart",
        "label": "Enable Add to Cart (Product Page)",
        "default": true,
        "info": "Shows Add to Cart button on product detail page"
      },
      {
        "type": "checkbox",
        "id": "enable_add_to_cart_card",
        "label": "Enable Add to Cart (Product Cards)",
        "default": true,
        "info": "Shows Add to Cart button on collection grid cards"
      },
      {
        "type": "header",
        "content": "Buy Now Button"
      },
      {
        "type": "checkbox",
        "id": "enable_buy_now",
        "label": "Enable Buy Now (Product Page)",
        "default": true,
        "info": "Shows Buy Now button on product detail page — goes directly to checkout"
      },
      {
        "type": "checkbox",
        "id": "enable_buy_now_card",
        "label": "Enable Buy Now (Product Cards)",
        "default": false,
        "info": "Shows Buy Now button on collection grid cards"
      }
    ]
  },
  {
    "name": "⭐ Product Reviews",
    "settings": [
      {
        "type": "checkbox",
        "id": "enable_reviews",
        "label": "Enable Customer Reviews",
        "default": true,
        "info": "Shows review section on product pages with write-review form"
      },
      {
        "type": "checkbox",
        "id": "show_rating",
        "label": "Show Star Ratings on Products",
        "default": true,
        "info": "Shows star rating on product cards and product pages"
      },
      {
        "type": "checkbox",
        "id": "show_review_count",
        "label": "Show Review Count",
        "default": true,
        "info": "Shows number of reviews next to star rating"
      }
    ]
  },
  {
    "name": "📈 CRO & Conversion Boosters",
    "settings": [
      {
        "type": "header",
        "content": "Social Proof"
      },
      {
        "type": "checkbox",
        "id": "enable_cro_social_proof",
        "label": "Enable Social Proof (Live Viewer Count)",
        "default": true,
        "info": "Shows '12 people viewing this' on product cards and pages"
      },
      {
        "type": "header",
        "content": "Urgency / Scarcity"
      },
      {
        "type": "checkbox",
        "id": "enable_cro_urgency",
        "label": "Enable Urgency (Low Stock Warning)",
        "default": true,
        "info": "Shows 'Only 3 left in stock' when inventory is low"
      },
      {
        "type": "header",
        "content": "Trust Badges"
      },
      {
        "type": "checkbox",
        "id": "enable_trust_badges",
        "label": "Enable Trust Badges in Buy Box",
        "default": true,
        "info": "Shows Secure, Free Returns, and Delivery badges"
      },
      {
        "type": "checkbox",
        "id": "show_secure_transaction",
        "label": "Show Secure Transaction Badge",
        "default": true
      },
      {
        "type": "checkbox",
        "id": "show_return_policy",
        "label": "Show Free Returns Badge",
        "default": true
      },
      {
        "type": "header",
        "content": "Recently Viewed"
      },
      {
        "type": "checkbox",
        "id": "enable_cro_recently_viewed",
        "label": "Enable Recently Viewed Products",
        "default": true,
        "info": "Shows recently viewed products section on product pages"
      }
    ]
  },
