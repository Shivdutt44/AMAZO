        "type": "color",
        "id": "color_buy_now_bg",
        "label": "Buy Now Button Color",
        "default": "#ffa41c"
      }
    ]
  },
  {
    "name": "Typography",
    "settings": [
      {
        "type": "font_picker",
        "id": "type_body_font",
        "label": "Body Font",
        "default": "assistant_n4"
      },
      {
        "type": "font_picker",
        "id": "type_header_font",
        "label": "Heading Font",
        "default": "assistant_n7"
      },
      {
        "type": "range",
        "id": "font_size_base",
        "label": "Base Font Size",
        "min": 12,
        "max": 20,
        "step": 1,
        "unit": "px",
        "default": 14
      },
      {
        "type": "range",
        "id": "heading_scale",
        "label": "Heading Scale",
        "min": 100,
        "max": 150,
        "step": 5,
        "unit": "%",
        "default": 120
      }
    ]
  },
  {
    "name": "Layout",
    "settings": [
      {
        "type": "range",
        "id": "page_width",
        "label": "Page Width",
        "min": 1000,
        "max": 1600,
        "step": 20,
        "unit": "px",
        "default": 1500
      },
      {
        "type": "range",
        "id": "border_radius",
        "label": "Base Border Radius",
        "min": 0,
        "max": 12,
        "step": 1,
        "unit": "px",
        "default": 4
      },
      {
        "type": "range",
        "id": "product_card_radius",
        "label": "Product Card Radius",
        "min": 0,
        "max": 16,
        "step": 1,
        "unit": "px",
        "default": 4
      },
      {
        "type": "range",
        "id": "button_radius",
        "label": "Button Radius",
        "min": 0,
        "max": 50,
        "step": 1,
        "unit": "px",
        "default": 3
      }
    ]
  },
  {
    "name": "Favicon",
    "settings": [
      {
        "type": "image_picker",
        "id": "favicon",
        "label": "Favicon Image",
        "info": "32x32px .ico, .gif, or .png"
      }
    ]
  },
  {
    "name": "Header",
    "settings": [
      {
        "type": "image_picker",
        "id": "logo",
        "label": "Logo Image"
      },
      {
        "type": "range",
        "id": "logo_width",
        "label": "Logo Width",
        "min": 80,
        "max": 300,
        "step": 10,
        "unit": "px",
        "default": 130
      },
      {
        "type": "text",
        "id": "logo_text",
        "label": "Logo Text (if no image)",
        "default": "amazo"
      },
      {
        "type": "checkbox",
        "id": "show_delivery_location",
        "label": "Show Delivery Location",
        "default": true
      },
      {
        "type": "text",
        "id": "delivery_location_text",
        "label": "Delivery Location Text",
        "default": "New York 10001"
      },
      {
        "type": "checkbox",
        "id": "sticky_header",
        "label": "Sticky Header",
        "default": true
      }
    ]
  },
  {
    "name": "Search",
    "settings": [
      {
        "type": "checkbox",
        "id": "enable_predictive_search",
        "label": "Enable Predictive Search",
        "default": true
      },
      {
        "type": "checkbox",
        "id": "show_search_categories",
        "label": "Show Category Dropdown in Search",
        "default": true
      },
      {
        "type": "range",
        "id": "predictive_search_results",
        "label": "Number of Predictive Results",
        "min": 4,
        "max": 12,
        "step": 2,
        "default": 8
      }
    ]
  },
  {
    "name": "Cart",
    "settings": [
      {
        "type": "select",
        "id": "cart_type",
        "label": "Cart Type",
        "options": [
          { "value": "drawer", "label": "Drawer (Slide-in)" },
          { "value": "page",   "label": "Cart Page" },
          { "value": "popup",  "label": "Popup" }
        ],
        "default": "drawer"
      },
      {
        "type": "checkbox",
        "id": "cart_show_free_shipping",
        "label": "Show Free Shipping Progress Bar",
        "default": true
      },
      {
        "type": "text",
        "id": "free_shipping_threshold",
        "label": "Free Shipping Threshold",
        "default": "35",
        "info": "Amount in store currency"
      }
    ]
  },
  {
    "name": "Product Cards",
    "settings": [
      {
        "type": "checkbox",
        "id": "show_vendor",
        "label": "Show Vendor/Brand",
        "default": true
      },
      {
        "type": "checkbox",
        "id": "show_compare_price",
        "label": "Show Compare At Price",
        "default": true
      },
      {
        "type": "checkbox",
        "id": "show_savings_amount",
        "label": "Show Savings Amount",
        "default": true
      },
      {
        "type": "checkbox",
        "id": "show_prime_badge",
        "label": "Show Prime-style Badge",
        "default": true
      },
      {
        "type": "select",
        "id": "product_image_ratio",
        "label": "Product Image Ratio",
        "options": [
          { "value": "1/1", "label": "Square" },
          { "value": "4/3", "label": "Landscape" },
          { "value": "3/4", "label": "Portrait" }
        ],
        "default": "1/1"
      },
      {
        "type": "select",
        "id": "product_image_fit",
        "label": "Product Image Fit",
        "options": [
          { "value": "contain", "label": "Contain (show full image)" },
          { "value": "cover",   "label": "Cover (fill space)" }
        ],
        "default": "contain"
      }
    ]
  },
  {
    "name": "Product Page",
    "settings": [
      {
        "type": "checkbox",
        "id": "show_product_breadcrumb",
        "label": "Show Breadcrumb",
        "default": true
      },
      {
        "type": "checkbox",
        "id": "enable_zoom",
        "label": "Enable Image Zoom on Hover",
        "default": true
      },
      {
        "type": "checkbox",
        "id": "show_quantity_selector",
        "label": "Show Quantity Selector",
        "default": true
      },
      {
        "type": "checkbox",
        "id": "show_delivery_date",
        "label": "Show Estimated Delivery Date",
        "default": true
      },
      {
        "type": "checkbox",
        "id": "show_product_tabs",
        "label": "Show Product Detail Tabs (Description, Specs, Reviews, Q&A)",
        "default": true
      },
      {
        "type": "checkbox",
        "id": "enable_related_products",
        "label": "Show Related Products",
        "default": true
      }
    ]
  },
  {
    "name": "Collection Page",
    "settings": [
      {
        "type": "range",
        "id": "products_per_page",
        "label": "Products Per Page",
        "min": 12,
        "max": 48,
        "step": 4,
        "default": 24
      },
      {
        "type": "select",
        "id": "default_products_per_row_desktop",
        "label": "Products Per Row (Desktop)",
        "options": [
          { "value": "3", "label": "3 columns" },
          { "value": "4", "label": "4 columns" },
          { "value": "5", "label": "5 columns" }
        ],
        "default": "4"
      },
      {
        "type": "select",
        "id": "default_products_per_row_mobile",
        "label": "Products Per Row (Mobile)",
        "options": [
          { "value": "1", "label": "1 column" },
          { "value": "2", "label": "2 columns" }
        ],
        "default": "2"
      },
      {
        "type": "checkbox",
        "id": "enable_filtering",
        "label": "Enable Filtering",
        "default": true
      },
      {
        "type": "checkbox",
        "id": "enable_sorting",
        "label": "Enable Sorting",
        "default": true
      }
    ]
  },
  {
    "name": "Social Media",
    "settings": [
      {
        "type": "header",
        "content": "Social Media Links"
      },
      {
        "type": "text",
        "id": "social_facebook_link",
        "label": "Facebook URL"
      },
      {
        "type": "text",
        "id": "social_twitter_link",
        "label": "Twitter/X URL"
      },
      {
        "type": "text",
        "id": "social_instagram_link",
        "label": "Instagram URL"
      },
      {
        "type": "text",
        "id": "social_youtube_link",
        "label": "YouTube URL"
      },
      {
        "type": "text",
        "id": "social_pinterest_link",
        "label": "Pinterest URL"
      }
    ]
  },
  {
    "name": "SEO",
    "settings": [
      {
        "type": "checkbox",
        "id": "seo_enable_structured_data",
        "label": "Enable Structured Data (Schema.org)",
        "default": true
      },
      {
        "type": "checkbox",
        "id": "seo_enable_breadcrumbs",
        "label": "Enable Breadcrumb Schema",
        "default": true
      }
    ]
  },
  {
    "name": "Performance",
    "settings": [
      {
        "type": "checkbox",
        "id": "enable_lazy_loading",
        "label": "Enable Lazy Loading Images",
        "default": true,
        "info": "Improves page speed"
      },
      {
        "type": "checkbox",
        "id": "enable_image_srcset",
        "label": "Enable Responsive Images (srcset)",
        "default": true
      },
      {
        "type": "checkbox",
        "id": "critical_css_inline",
        "label": "Inline Critical CSS",
        "default": true
      }
    ]
  },
  {
    "name": "Animations",
    "settings": [
      {
        "type": "checkbox",
        "id": "enable_animations",
        "label": "Enable Animations",
        "default": true
      },
      {
        "type": "select",
        "id": "animation_speed",
        "label": "Animation Speed",
        "options": [
          { "value": "fast",   "label": "Fast (150ms)" },
          { "value": "normal", "label": "Normal (300ms)" },
          { "value": "slow",   "label": "Slow (500ms)" }
        ],
        "default": "normal"
      }
    ]
  }
]
