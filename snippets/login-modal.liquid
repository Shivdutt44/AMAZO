{% comment %}
  Amazo Theme – Login Prompt Modal
  Shown when a non-logged-in user tries to write a review
  (or any action that requires authentication)
{% endcomment %}

<div id="LoginModal" class="amz-login-modal" aria-hidden="true" role="dialog" aria-modal="true" aria-labelledby="LoginModalTitle">
  <div class="amz-login-overlay" id="LoginModalOverlay"></div>
  <div class="amz-login-container">
    <button type="button" class="amz-login-close" id="LoginModalClose" aria-label="Close">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
    </button>

    <div class="amz-login-icon">
      <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="#ff9900" stroke-width="1.5"><circle cx="12" cy="8" r="4"/><path d="M4 21v-1a6 6 0 016-6h4a6 6 0 016 6v1"/></svg>
    </div>

    <h2 class="amz-login-title" id="LoginModalTitle">Sign in to write a review</h2>
    <p class="amz-login-desc">Please sign in to your account to share your thoughts with other customers.</p>

    <div class="amz-login-actions">
      <a href="{{ routes.account_login_url }}?return_to={{ request.path | url_encode }}" class="amz-btn amz-btn--login">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M15 3h4a2 2 0 012 2v14a2 2 0 01-2 2h-4"/><polyline points="10 17 15 12 10 7"/><line x1="15" y1="12" x2="3" y2="12"/></svg>
        Sign In
      </a>
      <a href="{{ routes.account_register_url }}" class="amz-btn amz-btn--create-account">Create Account</a>
    </div>

    <div class="amz-login-footer">
      <span>By signing in, you agree to our</span>
      <a href="/pages/terms">Terms &amp; Conditions</a>
    </div>
  </div>
</div>
