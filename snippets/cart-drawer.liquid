{% comment %} Amazo - Cart Drawer Snippet - Fully Functional {% endcomment %}

<!-- Cart Drawer Overlay -->
<div class="cart-drawer-overlay" id="cartDrawerOverlay" aria-hidden="true"></div>

<!-- Cart Drawer -->
<div class="cart-drawer" id="cartDrawer" role="dialog" aria-modal="true" aria-label="Shopping Cart" aria-hidden="true" tabindex="-1">

  <div class="cart-drawer__header">
    <h3>
      <svg width="22" height="22" viewBox="0 0 24 24" fill="white" style="vertical-align:middle;margin-right:6px;" aria-hidden="true">
        <path d="M7 18c-1.1 0-1.99.9-1.99 2S5.9 22 7 22s2-.9 2-2-.9-2-2-2zM1 2v2h2l3.6 7.59-1.35 2.45c-.16.28-.25.61-.25.96C5 16.1 6.1 17 7.5 17h11.5v-2H7.83c-.13 0-.21-.07-.21-.2l.03-.12.9-1.68H17c.75 0 1.41-.41 1.75-1.03l3.58-6.49A1 1 0 0 0 21.46 4H5.21l-.94-2H1zm16 16c-1.1 0-1.99.9-1.99 2s.89 2 1.99 2 2-.9 2-2-.9-2-2-2z"/>
      </svg>
      Shopping Cart
    </h3>
    <button class="cart-drawer__close" id="cartDrawerClose" aria-label="Close cart">✕</button>
  </div>

  <!-- Free Shipping Progress Bar -->
  <div class="cart-drawer__shipping-bar" id="cartShippingBar" style="display:none;">
    <div class="cart-shipping-text" id="cartShippingText"></div>
    <div class="cart-shipping-progress">
      <div class="cart-shipping-fill" id="cartShippingFill"></div>
    </div>
  </div>

  <!-- Items -->
  <div class="cart-drawer__body" id="cartDrawerBody">
    <div class="cart-drawer__empty" id="cartDrawerEmpty">
      <svg width="60" height="60" viewBox="0 0 24 24" fill="#ccc" aria-hidden="true"><path d="M7 18c-1.1 0-1.99.9-1.99 2S5.9 22 7 22s2-.9 2-2-.9-2-2-2zM1 2v2h2l3.6 7.59-1.35 2.45c-.16.28-.25.61-.25.96C5 16.1 6.1 17 7.5 17h11.5v-2H7.83c-.13 0-.21-.07-.21-.2l.03-.12.9-1.68H17c.75 0 1.41-.41 1.75-1.03l3.58-6.49A1 1 0 0 0 21.46 4H5.21l-.94-2H1zm16 16c-1.1 0-1.99.9-1.99 2s.89 2 1.99 2 2-.9 2-2-.9-2-2-2z"/></svg>
      <p class="cart-drawer__empty-title">Your cart is empty</p>
      <p class="cart-drawer__empty-sub">Shop today's deals</p>
      <a href="/collections" class="cart-drawer__shop-btn">Shop now</a>
    </div>
    <div class="cart-drawer__items" id="cartDrawerItems"></div>
  </div>

  <!-- Footer -->
  <div class="cart-drawer__footer" id="cartDrawerFooter" style="display:none;">
    <div class="cart-drawer__subtotal-row">
      <span>Subtotal (<span id="cartItemCount">0</span> items):</span>
      <strong class="cart-drawer__subtotal" id="cartSubtotal">{{ cart.total_price | money }}</strong>
    </div>
    <p class="cart-drawer__emi-note">EMI available. &nbsp;<a href="/pages/emi-options">Learn more</a></p>
    <div class="cart-drawer__actions">
      <a href="/cart" class="cart-drawer__view-cart">View Cart</a>
      <a href="/checkout" class="cart-drawer__checkout">Proceed to Buy</a>
    </div>
  </div>

</div>

<style>
/* ── CART DRAWER ─────────────────────────────────────── */
.cart-drawer-overlay {
  display: none;
  position: fixed;
  inset: 0;
  background: rgba(0,0,0,0.5);
  z-index: 9998;
  backdrop-filter: blur(1px);
}
.cart-drawer-overlay.active { display: block; }

.cart-drawer {
  position: fixed;
  top: 0; right: -420px;
  width: 400px; max-width: 100vw;
  height: 100vh;
  background: #fff;
  z-index: 9999;
  display: flex;
  flex-direction: column;
  box-shadow: -4px 0 24px rgba(0,0,0,0.18);
  transition: right 0.3s cubic-bezier(0.4,0,0.2,1);
  font-family: "Open Sans", Arial, sans-serif;
}
.cart-drawer.is-open { right: 0; }

.cart-drawer__header {
  background: #232f3e;
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 14px 18px;
  flex-shrink: 0;
}
.cart-drawer__header h3 {
  margin: 0;
  font-size: 16px;
  font-weight: 700;
  display: flex;
  align-items: center;
}
.cart-drawer__close {
  background: none;
  border: none;
  color: #fff;
  font-size: 20px;
  cursor: pointer;
  padding: 4px 8px;
  border-radius: 3px;
  line-height: 1;
  transition: background 0.15s;
}
.cart-drawer__close:hover { background: rgba(255,255,255,0.15); }

/* Shipping bar */
.cart-drawer__shipping-bar {
  background: #f0f9f0;
  border-bottom: 1px solid #c3e6cb;
  padding: 8px 16px;
  flex-shrink: 0;
}
.cart-shipping-text { font-size: 12px; color: #155724; margin-bottom: 5px; font-weight: 500; }
.cart-shipping-progress {
  height: 5px; border-radius: 3px;
  background: #d4edda;
  overflow: hidden;
}
.cart-shipping-fill {
  height: 100%;
  background: linear-gradient(90deg, #28a745, #20c997);
  border-radius: 3px;
  transition: width 0.4s ease;
}

/* Body */
.cart-drawer__body {
  flex: 1;
  overflow-y: auto;
  overscroll-behavior: contain;
  -webkit-overflow-scrolling: touch;
}

.cart-drawer__empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 40px 20px;
  text-align: center;
  height: 100%;
}
.cart-drawer__empty-title {
  margin-top: 15px;
  font-size: 18px;
  font-weight: 700;
  color: #0f1111;
}
.cart-drawer__empty-sub { color: #565959; font-size: 13px; margin: 8px 0 20px; }
.cart-drawer__shop-btn {
  display: inline-block;
  background: #FFD814;
  border: 1px solid #FCD200;
  border-radius: 8px;
  padding: 10px 24px;
  font-size: 14px;
  font-weight: 600;
  color: #0f1111;
  text-decoration: none;
  transition: background 0.15s;
}
.cart-drawer__shop-btn:hover { background: #F7CA00; }

/* Cart Items */
.cart-drawer-item {
  display: flex;
  gap: 12px;
  padding: 14px 16px;
  border-bottom: 1px solid #f0f0f0;
  align-items: flex-start;
  transition: background 0.1s;
}
.cart-drawer-item:hover { background: #fafafa; }
.cart-drawer-item__img {
  width: 72px; height: 72px;
  object-fit: contain;
  border: 1px solid #eee;
  border-radius: 4px;
  flex-shrink: 0;
  background: #fff;
}
.cart-drawer-item__info { flex: 1; min-width: 0; }
.cart-drawer-item__title {
  font-size: 13px;
  color: #0f1111;
  line-height: 1.4;
  margin-bottom: 4px;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}
.cart-drawer-item__price {
  font-size: 15px;
  font-weight: 700;
  color: #B12704;
  margin: 4px 0;
}
.cart-drawer-item__qty-row {
  display: flex;
  align-items: center;
  gap: 8px;
  margin-top: 6px;
}
.cart-drawer-item__qty-btn {
  width: 26px; height: 26px;
  border: 1px solid #ddd;
  border-radius: 3px;
  background: #f7f8f8;
  font-size: 14px;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: background 0.1s, border-color 0.1s;
}
.cart-drawer-item__qty-btn:hover { background: #eee; border-color: #999; }
.cart-drawer-item__qty-num { font-size: 13px; font-weight: 600; min-width: 20px; text-align: center; }
.cart-drawer-item__remove {
  font-size: 11px;
  color: #007185;
  cursor: pointer;
  background: none;
  border: none;
  padding: 0;
  text-decoration: underline;
  margin-left: 4px;
}
.cart-drawer-item__remove:hover { color: #c45500; }

/* Footer */
.cart-drawer__footer {
  border-top: 2px solid #eee;
  padding: 14px 18px;
  background: #fff;
  flex-shrink: 0;
}
.cart-drawer__subtotal-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 6px;
  font-size: 14px;
  color: #0f1111;
}
.cart-drawer__subtotal { font-size: 18px; font-weight: 700; color: #0f1111; }
.cart-drawer__emi-note {
  font-size: 11px;
  color: #565959;
  margin-bottom: 12px;
}
.cart-drawer__emi-note a { color: #007185; }
.cart-drawer__actions {
  display: flex;
  flex-direction: column;
  gap: 8px;
}
.cart-drawer__view-cart {
  display: block;
  text-align: center;
  padding: 9px;
  border: 1px solid #ddd;
  border-radius: 8px;
  font-size: 14px;
  font-weight: 600;
  color: #0f1111;
  text-decoration: none;
  background: #f7f8f8;
  transition: background 0.15s;
}
.cart-drawer__view-cart:hover { background: #eee; }
.cart-drawer__checkout {
  display: block;
  text-align: center;
  padding: 10px;
  background: #FFD814;
  border: 1px solid #FCD200;
  border-radius: 8px;
  font-size: 14px;
  font-weight: 700;
  color: #0f1111;
  text-decoration: none;
  transition: background 0.15s;
}
.cart-drawer__checkout:hover { background: #F7CA00; }

body.cart-is-open { overflow: hidden; }

@media (max-width: 480px) {
  .cart-drawer { width: 100vw; }
}
</style>
