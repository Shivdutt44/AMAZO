{% comment %}
  Amazo Theme - Product Card v4.0 PRO
  Full CRO-optimized product card with:
  - Wishlist (localStorage based, global toggle)
  - Quick View modal trigger
  - Add to Cart (AJAX)
  - Buy Now button
  - Star Ratings + Review count
  - CRO: Urgency, Social Proof, Trust Badges, Stock Counter
  Usage: {% render 'product-card', product: product %}
{% endcomment %}

{%- liquid
  assign featured_image = product.featured_image
  assign second_image = product.images[1]
  assign product_url = product.url

  assign discount_percentage = 0
  if product.compare_at_price > product.price
    assign saved_amount = product.compare_at_price | minus: product.price
    assign discount_percentage = saved_amount | times: 100 | divided_by: product.compare_at_price | round
  endif

  assign review_count = product.metafields.reviews.rating_count | default: 0
  assign review_rating = product.metafields.reviews.rating.value | default: 0
  if review_rating == 0
    assign review_rating = product.id | modulo: 25 | times: 0.2 | plus: 3.5 | round: 1
    assign review_count = product.id | modulo: 8000 | plus: 200
  endif

  assign stock_count = product.variants.first.inventory_quantity | default: 0
  assign low_stock = false
  if stock_count > 0 and stock_count <= 10
    assign low_stock = true
  endif

  assign viewers_count = product.id | modulo: 40 | plus: 8
-%}

<article class="product-card amz-card"
  data-product-id="{{ product.id }}"
  data-product-handle="{{ product.handle }}"
  itemscope
  itemtype="http://schema.org/Product"
  aria-label="{{ product.title | escape }}">

  <!-- ─── IMAGE ZONE ─── -->
  <div class="product-card__media">
    <a href="{{ product_url }}" class="product-card__img-link" aria-label="{{ product.title | escape }}" tabindex="-1">
      {%- if featured_image != blank -%}
        <img
          src="{{ featured_image | image_url: width: 300 }}"
          srcset="{{ featured_image | image_url: width: 150 }} 150w, {{ featured_image | image_url: width: 300 }} 300w, {{ featured_image | image_url: width: 450 }} 450w"
          sizes="(max-width: 480px) 130px, (max-width: 768px) 150px, 200px"
          alt="{{ featured_image.alt | default: product.title | escape }}"
          class="product-card__image product-card__image--primary"
          loading="lazy" width="300" height="300" itemprop="image">
        {%- if second_image != blank -%}
          <img
            src="{{ second_image | image_url: width: 300 }}"
            alt="{{ second_image.alt | default: product.title | escape }}"
            class="product-card__image product-card__image--hover"
            loading="lazy" width="300" height="300">
        {%- endif -%}
      {%- else -%}
        <div class="product-card__placeholder">
          {{ 'product-1' | placeholder_svg_tag: 'product-card__image' }}
        </div>
      {%- endif -%}
    </a>

    <!-- Badges -->
    <div class="product-card__badges">
      {%- if discount_percentage >= 5 -%}
        <span class="badge badge--sale">-{{ discount_percentage }}%</span>
      {%- elsif product.tags contains 'new' -%}
        <span class="badge badge--new">New</span>
      {%- endif -%}
      {%- if product.tags contains 'bestseller' or product.tags contains 'best-seller' -%}
        <span class="badge badge--bestseller">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="10" height="10" fill="currentColor" aria-hidden="true"><path d="M12 2l2.4 7.4H22l-6.2 4.5 2.4 7.4L12 17l-6.2 4.3 2.4-7.4L2 9.4h7.6z"/></svg>
          Best Seller
        </span>
      {%- endif -%}
      {%- if product.tags contains 'prime' -%}
        <span class="badge badge--prime">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="10" height="10" fill="currentColor" aria-hidden="true"><path d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
          Prime
        </span>
      {%- endif -%}
      {%- if low_stock -%}
        <span class="badge badge--stock">Only {{ stock_count }} left!</span>
      {%- endif -%}
    </div>

    <!-- ── WISHLIST BUTTON (Global Toggle) ── -->
    {%- if settings.enable_wishlist -%}
    <button class="product-card__wishlist amz-wishlist-btn"
            aria-label="Save {{ product.title | escape }} to wishlist"
            data-product-id="{{ product.id }}"
            data-product-title="{{ product.title | escape }}"
            data-product-url="{{ product_url }}"
            data-product-image="{{ featured_image | image_url: width: 150 }}"
            data-product-price="{{ product.price }}"
            data-variant-id="{{ product.first_available_variant.id }}">
      <svg class="amz-heart-icon" viewBox="0 0 24 24" width="16" height="16" aria-hidden="true">
        <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
      </svg>
      <span class="amz-wishlist-tooltip">Save to Wishlist</span>
    </button>
    {%- endif -%}

    <!-- ── QUICK VIEW BUTTON (Global Toggle) ── -->
    {%- if settings.enable_quick_view -%}
    <button class="product-card__quickview amz-quickview-btn"
            data-product-handle="{{ product.handle }}"
            data-product-id="{{ product.id }}"
            aria-label="Quick view {{ product.title | escape }}">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
      Quick View
    </button>
    {%- endif -%}
  </div>

  <!-- ─── INFO ZONE ─── -->
  <div class="product-card__info">

    {%- if product.vendor != blank and settings.show_vendor -%}
      <div class="product-card__brand">{{ product.vendor }}</div>
    {%- endif -%}

    <a href="{{ product_url }}" class="product-card__title" itemprop="name">
      {{ product.title | truncate: 70 }}
    </a>

    <!-- ── STAR RATING ── -->
    {%- if settings.show_rating -%}
    <div class="product-card__rating" itemprop="aggregateRating" itemscope itemtype="http://schema.org/AggregateRating">
      <meta itemprop="ratingValue" content="{{ review_rating }}">
      <meta itemprop="reviewCount" content="{{ review_count }}">
      <a href="{{ product_url }}#product-reviews" class="product-card__rating-link" aria-label="{{ review_rating }} out of 5 stars, {{ review_count }} ratings">
        <span class="rating-stars" style="color:#ff9900;">
          {%- assign full = review_rating | floor -%}
          {%- assign decimal_part = review_rating | minus: full -%}
          {%- assign half_star_pos = full | plus: 1 -%}
          {%- for s in (1..5) -%}
            {%- if s <= full -%}★{%- elsif decimal_part >= 0.3 and decimal_part <= 0.7 and s == half_star_pos -%}★{%- else -%}☆{%- endif -%}
          {%- endfor -%}
        </span>
        {%- if settings.show_review_count -%}
          <span class="rating-count">({{ review_count | number_with_delimiter }})</span>
        {%- endif -%}
      </a>
    </div>
    {%- endif -%}

    <!-- ── PRICE ── -->
    <div class="product-card__price" itemprop="offers" itemscope itemtype="http://schema.org/Offer">
      <meta itemprop="priceCurrency" content="{{ cart.currency.iso_code }}">
      <meta itemprop="availability" content="{% if product.available %}InStock{% else %}OutOfStock{% endif %}">
      <span class="price-current" itemprop="price" content="{{ product.price | divided_by: 100.0 }}">
        {{ product.price | money }}
      </span>
      {%- if product.compare_at_price > product.price and settings.show_compare_price -%}
        <span class="price-compare">{{ product.compare_at_price | money }}</span>
        <span class="price-discount badge--inline">Save {{ discount_percentage }}%</span>
      {%- endif -%}
    </div>

    <!-- ── CRO: Social Proof Viewer Count ── -->
    {%- if settings.enable_cro_social_proof -%}
    <div class="product-card__social-proof">
      <span class="pulse-dot"></span>
      <span class="social-proof-text">{{ viewers_count }} people viewing this</span>
    </div>
    {%- endif -%}

    <!-- ── CRO: Low Stock Urgency ── -->
    {%- if settings.enable_cro_urgency and low_stock -%}
    <div class="product-card__urgency">
      <svg width="12" height="12" viewBox="0 0 24 24" fill="#cc0c39" aria-hidden="true"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/></svg>
      Only {{ stock_count }} left in stock – order soon!
    </div>
    {%- elsif settings.enable_cro_urgency -%}
    <div class="product-card__delivery">
      <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#007600" stroke-width="2.5" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
      FREE delivery available
    </div>
    {%- endif -%}

    <!-- ── ACTION BUTTONS ── -->
    <div class="product-card__actions">
      {%- if product.available -%}

        <!-- ADD TO CART -->
        {%- if settings.enable_add_to_cart_card -%}
        <button type="button"
          class="btn btn--atc product-card__add-btn amz-add-to-cart"
          data-product-id="{{ product.id }}"
          data-variant-id="{{ product.first_available_variant.id }}"
          data-product-title="{{ product.title | escape }}"
          aria-label="Add {{ product.title | escape }} to cart">
          <svg class="btn-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 01-8 0"/></svg>
          <span class="btn-text">Add to Cart</span>
          <span class="btn-loading" aria-hidden="true">Adding…</span>
        </button>
        {%- endif -%}

        <!-- BUY NOW — FIX: button triggers AJAX add + /checkout redirect -->
        {%- if settings.enable_buy_now_card -%}
        <button type="button"
           class="btn btn--buy product-card__buy-btn amz-buy-now"
           data-product-id="{{ product.id }}"
           data-variant-id="{{ product.first_available_variant.id }}">
          Buy Now
        </button>
        {%- endif -%}

      {%- else -%}
        <span class="product-card__unavailable">Currently unavailable</span>
      {%- endif -%}
    </div>

  </div>
</article>
