<!doctype html>
<html lang="{{ request.locale.iso_code }}">
  <head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="robots" content="noindex,nofollow">
    <title>{{ shop.name }} - Password Protected</title>
    {{ content_for_header }}
    {{ 'amazo-base.css' | asset_url | stylesheet_tag }}
    <style>
      body { background: #131921; color: #fff; display: flex; align-items: center; justify-content: center; min-height: 100vh; margin: 0; font-family: Arial, sans-serif; }
      .password-page { text-align: center; max-width: 400px; padding: 40px; }
      .password-page__logo { font-size: 2.5rem; font-weight: 700; color: #ff9900; margin-bottom: 20px; }
      .password-page__form input { width: 100%; padding: 10px; margin: 10px 0; border-radius: 4px; border: 1px solid #ddd; font-size: 14px; box-sizing: border-box; }
      .password-page__form button { width: 100%; padding: 10px; background: #ff9900; border: none; border-radius: 4px; font-size: 16px; font-weight: 600; cursor: pointer; }
    </style>
  </head>
  <body>
    {{ content_for_layout }}
    <div class="password-page">
      <div class="password-page__logo">amazo</div>
      <h1>{{ shop.name }}</h1>
      <p>We're currently building something amazing. Enter the password to access.</p>
      {% form 'storefront_password' %}
        <div class="password-page__form">
          <input type="password" name="password" placeholder="Enter password" autocomplete="current-password">
          <button type="submit">Enter Store</button>
        </div>
        {{ form.errors | default_errors }}
      {% endform %}
    </div>
  </body>
</html>
